<Window x:Class="Orynivo.ArtistMergeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L_MergeArtistsTitle}"
        Icon="Assets/Orynivo.ico"
        Width="540"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppSurfaceBrush}"
        SourceInitialized="ArtistMergeDialog_OnSourceInitialized">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="MessageTextBlock"
                   FontSize="14"
                   LineHeight="21"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource AppPrimaryTextBrush}"/>
        <StackPanel Grid.Row="1" Margin="0,20,0,20">
            <Button x:Name="CurrentArtistButton"
                    Height="40"
                    Margin="0,0,0,10"
                    Background="#6C63FF"
                    Foreground="White"
                    BorderThickness="0"
                    Click="CurrentArtistButton_OnClick"/>
            <Button x:Name="MatchingArtistButton"
                    Height="40"
                    Background="#6C63FF"
                    Foreground="White"
                    BorderThickness="0"
                    Click="MatchingArtistButton_OnClick"/>
        </StackPanel>
        <Button Grid.Row="2"
                Width="100"
                Height="34"
                HorizontalAlignment="Right"
                Content="{DynamicResource L_Cancel}"
                IsCancel="True"
                Background="{DynamicResource AppButtonBrush}"
                Foreground="{DynamicResource AppButtonTextBrush}"
                BorderBrush="{DynamicResource AppButtonBorderBrush}"
                Click="CancelButton_OnClick"/>
    </Grid>
</Window>
