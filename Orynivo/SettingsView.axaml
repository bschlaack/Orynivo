<UserControl x:Class="Orynivo.SettingsView"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Orynivo.Controls"
        Background="{DynamicResource AppContentBrush}"
        Foreground="{DynamicResource AppPrimaryTextBrush}">
    <UserControl.Resources>
        <ControlTheme x:Key="SettingsNavItemTheme" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource AppNavTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bd"
                            Background="Transparent"
                            BorderThickness="3,0,0,0"
                            BorderBrush="Transparent"
                            Padding="21,8,12,8">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:selected /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource AppNavSelectedBrush}"/>
                <Setter Property="BorderBrush" Value="#6C63FF"/>
            </Style>
            <Style Selector="^:selected">
                <Setter Property="Foreground" Value="{DynamicResource AppNavSelectedTextBrush}"/>
            </Style>
            <Style Selector="^:pointerover:not(:selected) /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource AppNavHoverBrush}"/>
            </Style>
            <Style Selector="^:pointerover:not(:selected)">
                <Setter Property="Foreground" Value="{DynamicResource AppNavHoverTextBrush}"/>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="SettingsButtonTheme" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppButtonBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppButtonTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource AppButtonHoverBrush}"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource AppButtonPressedBrush}"/>
            </Style>
            <Style Selector="^:disabled">
                <Setter Property="Opacity" Value="0.55"/>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="SettingsCheckBoxTheme" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="CheckBorder"
                                Width="16"
                                Height="16"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Background="{DynamicResource AppInputBrush}"
                                BorderBrush="{DynamicResource AppInputBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="3">
                            <Path x:Name="CheckMark"
                                  Width="9"
                                  Height="7"
                                  Data="M 0 3.5 L 3 6.5 L 9 0"
                                  Stroke="White"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  IsVisible="False"/>
                        </Border>
                        <ContentPresenter Grid.Column="1"
                                          Content="{TemplateBinding Content}"
                                          Margin="8,0,0,0"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#CheckBorder">
                <Setter Property="BorderBrush" Value="#6C63FF"/>
            </Style>
            <Style Selector="^:checked /template/ Border#CheckBorder">
                <Setter Property="Background" Value="#6C63FF"/>
                <Setter Property="BorderBrush" Value="#6C63FF"/>
            </Style>
            <Style Selector="^:checked /template/ Path#CheckMark">
                <Setter Property="IsVisible" Value="True"/>
            </Style>
            <Style Selector="^:disabled">
                <Setter Property="Opacity" Value="0.55"/>
                <Setter Property="Cursor" Value="Arrow"/>
            </Style>
        </ControlTheme>

        <!-- Pill toggle switch reused for genuine on/off options; still a CheckBox
             so existing code that reads IsChecked keeps working unchanged. -->
        <ControlTheme x:Key="SettingsToggleTheme" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
            <Setter Property="FontSize" Value="{DynamicResource FontSizeBody}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          VerticalAlignment="Center"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        <Border x:Name="Track"
                                Grid.Column="1"
                                Width="40"
                                Height="22"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center"
                                Background="{DynamicResource AppInputBrush}"
                                BorderBrush="{DynamicResource AppInputBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="11">
                            <Ellipse x:Name="Knob"
                                     Width="16"
                                     Height="16"
                                     Margin="2,0,0,0"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Fill="{DynamicResource AppSecondaryTextBrush}"/>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Track">
                <Setter Property="BorderBrush" Value="#6C63FF"/>
            </Style>
            <Style Selector="^:checked /template/ Border#Track">
                <Setter Property="Background" Value="#6C63FF"/>
                <Setter Property="BorderBrush" Value="#6C63FF"/>
            </Style>
            <Style Selector="^:checked /template/ Ellipse#Knob">
                <Setter Property="HorizontalAlignment" Value="Right"/>
                <Setter Property="Margin" Value="0,0,2,0"/>
                <Setter Property="Fill" Value="White"/>
            </Style>
            <Style Selector="^:disabled">
                <Setter Property="Opacity" Value="0.55"/>
                <Setter Property="Cursor" Value="Arrow"/>
            </Style>
        </ControlTheme>
    </UserControl.Resources>

    <UserControl.Styles>
        <Style Selector="ListBox#NavListBox ListBoxItem TextBlock">
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"/>
        </Style>
        <Style Selector="ListBox#NavListBox ListBoxItem Path">
            <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="TextBox">
            <Setter Property="MinHeight" Value="30"/>
        </Style>
        <Style Selector="NumericUpDown">
            <Setter Property="MinHeight" Value="30"/>
        </Style>
    </UserControl.Styles>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="1"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="NavListBox"
                 Grid.Column="0"
                 Grid.Row="0"
                 Background="{DynamicResource AppSidebarBrush}"
                 BorderThickness="0"
                 Padding="0,8,0,0"
                 SelectionChanged="NavListBox_OnSelectionChanged">
            <ListBoxItem IsHitTestVisible="False"
                         Focusable="False"
                         Padding="12,10,0,4"
                         FontSize="{DynamicResource FontSizeMeta}"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AppMutedTextBrush}">
                <TextBlock Text="{DynamicResource L_Playback}"/>
            </ListBoxItem>
            <ListBoxItem Tag="AudioDevice"
                         FontSize="{DynamicResource FontSizeBody}"
                         Theme="{StaticResource SettingsNavItemTheme}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"
                          Data="M3,9 L7,9 L12,4 L12,20 L7,15 L3,15 Z"/>
                    <TextBlock Text="{DynamicResource L_OutputDevice}" VerticalAlignment="Center"/>
                </StackPanel>
            </ListBoxItem>

            <ListBoxItem IsHitTestVisible="False"
                         Focusable="False"
                         Padding="12,14,0,4"
                         FontSize="{DynamicResource FontSizeMeta}"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AppMutedTextBrush}">
                <TextBlock Text="{DynamicResource L_Library}"/>
            </ListBoxItem>
            <ListBoxItem Tag="Library"
                         FontSize="{DynamicResource FontSizeBody}"
                         Theme="{StaticResource SettingsNavItemTheme}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"
                          Data="M2,6 L9,6 L11,8 L22,8 L22,19 L2,19 Z"/>
                    <TextBlock Text="{DynamicResource L_Directories}" VerticalAlignment="Center"/>
                </StackPanel>
            </ListBoxItem>
            <ListBoxItem Tag="OrynivoServers"
                         FontSize="{DynamicResource FontSizeBody}"
                         Theme="{StaticResource SettingsNavItemTheme}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"
                          Data="M3,5 L21,5 L21,10 L3,10 Z M3,13 L21,13 L21,18 L3,18 Z"/>
                    <TextBlock Text="{DynamicResource L_OrynivoServersSettings}" VerticalAlignment="Center"/>
                </StackPanel>
            </ListBoxItem>

            <ListBoxItem IsHitTestVisible="False"
                         Focusable="False"
                         Padding="12,14,0,4"
                         FontSize="{DynamicResource FontSizeMeta}"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AppMutedTextBrush}">
                <TextBlock Text="{DynamicResource L_Streaming}"/>
            </ListBoxItem>
            <ListBoxItem Tag="Streaming"
                         FontSize="{DynamicResource FontSizeBody}"
                         Theme="{StaticResource SettingsNavItemTheme}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"
                          Data="M4,18 L7,18 L7,14 L4,14 Z M9.5,18 L12.5,18 L12.5,9 L9.5,9 Z M15,18 L18,18 L18,4 L15,4 Z"/>
                    <TextBlock Text="{DynamicResource L_StreamingServices}" VerticalAlignment="Center"/>
                </StackPanel>
            </ListBoxItem>

            <ListBoxItem IsHitTestVisible="False"
                         Focusable="False"
                         Padding="12,14,0,4"
                         FontSize="{DynamicResource FontSizeMeta}"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AppMutedTextBrush}">
                <TextBlock Text="{DynamicResource L_Appearance}"/>
            </ListBoxItem>
            <ListBoxItem Tag="Appearance"
                         FontSize="{DynamicResource FontSizeBody}"
                         Theme="{StaticResource SettingsNavItemTheme}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"
                          Data="M4,20 L4,16 L14,6 L18,10 L8,20 Z M15,5 L17,3 L21,7 L19,9 Z"/>
                    <TextBlock Text="{DynamicResource L_AppearanceNavItem}" VerticalAlignment="Center"/>
                </StackPanel>
            </ListBoxItem>

            <ListBoxItem IsHitTestVisible="False"
                         Focusable="False"
                         Padding="12,14,0,4"
                         FontSize="{DynamicResource FontSizeMeta}"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AppMutedTextBrush}">
                <TextBlock Text="{DynamicResource L_ArtistInfo}"/>
            </ListBoxItem>
            <ListBoxItem Tag="ArtistInfo"
                         FontSize="{DynamicResource FontSizeBody}"
                         Theme="{StaticResource SettingsNavItemTheme}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"
                          Data="M12,3 L15.5,7 L12,11 L8.5,7 Z M5,21 L7,14 L17,14 L19,21 Z"/>
                    <TextBlock Text="{DynamicResource L_ArtistInfoNavItem}" VerticalAlignment="Center"/>
                </StackPanel>
            </ListBoxItem>

            <ListBoxItem IsHitTestVisible="False"
                         Focusable="False"
                         Padding="12,14,0,4"
                         FontSize="{DynamicResource FontSizeMeta}"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AppMutedTextBrush}">
                <TextBlock Text="{DynamicResource L_Integration}"/>
            </ListBoxItem>
            <ListBoxItem Tag="Mcp"
                         FontSize="{DynamicResource FontSizeBody}"
                         Theme="{StaticResource SettingsNavItemTheme}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"
                          Data="M9,3 L11,3 L11,7 L9,7 Z M13,3 L15,3 L15,7 L13,7 Z M7,7 L17,7 L17,13 L7,13 Z M11,13 L13,13 L13,21 L11,21 Z"/>
                    <TextBlock Text="{DynamicResource L_McpServer}" VerticalAlignment="Center"/>
                </StackPanel>
            </ListBoxItem>
            <ListBoxItem Tag="AiChat"
                         FontSize="{DynamicResource FontSizeBody}"
                         Theme="{StaticResource SettingsNavItemTheme}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Path Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"
                          Data="M4,5 L20,5 L20,15 L11,15 L7,19 L7,15 L4,15 Z"/>
                    <TextBlock Text="{DynamicResource L_AiChat}" VerticalAlignment="Center"/>
                </StackPanel>
            </ListBoxItem>
        </ListBox>

        <Rectangle Grid.Column="1"
                   Grid.Row="0"
                   Fill="{DynamicResource AppHeaderBorderBrush}"/>

        <ScrollViewer Grid.Column="2"
                      Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="28,24,28,16">

                <StackPanel x:Name="AudioDevicePanel"
                            IsVisible="False">
                    <TextBlock Text="{DynamicResource L_OutputDevice}"
                               FontSize="{DynamicResource FontSizeBodyStrong}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,14"/>

                    <WrapPanel Margin="0,0,0,20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,8" VerticalAlignment="Center">
                            <TextBlock Text="FFmpeg" VerticalAlignment="Center" Margin="0,0,8,0"
                                       FontSize="{DynamicResource FontSizeMeta}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppMutedTextBrush}"/>
                            <controls:StatusBadge x:Name="FfmpegStatusBadge"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,8" VerticalAlignment="Center">
                            <TextBlock Text="Steinberg ASIO" VerticalAlignment="Center" Margin="0,0,8,0"
                                       FontSize="{DynamicResource FontSizeMeta}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppMutedTextBrush}"/>
                            <controls:StatusBadge x:Name="AsioStatusBadge"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
                            <TextBlock Text="cwASIO" VerticalAlignment="Center" Margin="0,0,8,0"
                                       FontSize="{DynamicResource FontSizeMeta}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppMutedTextBrush}"/>
                            <controls:StatusBadge x:Name="CwAsioStatusBadge"/>
                        </StackPanel>
                    </WrapPanel>

                    <TextBlock Text="{DynamicResource L_OutputProfile}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="OutputProfileComboBox"
                                  Height="30"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OutputProfileComboBox_OnSelectionChanged"/>
                        <Button x:Name="ConfigureOutputProfileButton"
                                Grid.Column="1"
                                Height="30"
                                MinWidth="160"
                                Margin="8,0,0,0"
                                Padding="12,0"
                                IsEnabled="False"
                                Theme="{StaticResource SettingsButtonTheme}"
                                Content="{DynamicResource L_OutputProfileConfigure}"
                                Click="ConfigureOutputProfileButton_OnClick"/>
                        <Button Grid.Column="2"
                                Height="30"
                                MinWidth="140"
                                Margin="8,0,0,0"
                                Padding="12,0"
                                Theme="{StaticResource SettingsButtonTheme}"
                                Content="{DynamicResource L_OutputProfileCreate}"
                                Click="CreateOutputProfileButton_OnClick"/>
                        <Button x:Name="DeleteOutputProfileButton"
                                Grid.Column="3"
                                Height="30"
                                MinWidth="130"
                                Margin="8,0,0,0"
                                Padding="12,0"
                                IsEnabled="False"
                                Theme="{StaticResource SettingsButtonTheme}"
                                Content="{DynamicResource L_OutputProfileDelete}"
                                Click="DeleteOutputProfileButton_OnClick"/>
                    </Grid>
                    <TextBlock x:Name="OutputProfileSummaryTextBlock"
                               Margin="0,6,0,0"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"/>

                    <Separator Margin="0,18,0,14"/>

                    <TextBlock Text="{DynamicResource L_DsdPlayback}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <CheckBox x:Name="AlwaysConvertDsdToPcmCheckBox"
                              Theme="{StaticResource SettingsToggleTheme}"
                              Content="{DynamicResource L_AlwaysConvertDsdToPcm}"
                              Margin="0,0,0,6"/>
                    <TextBlock Text="{DynamicResource L_AlwaysConvertDsdToPcmHint}"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"/>
                    <CheckBox x:Name="PcmOutputBoostCheckBox"
                              Theme="{StaticResource SettingsToggleTheme}"
                              Content="{DynamicResource L_PcmOutputBoost}"
                              Margin="0,14,0,6"/>
                    <TextBlock Text="{DynamicResource L_PcmOutputBoostHint}"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"/>

                    <Separator Margin="0,18,0,14"/>

                    <TextBlock Text="{DynamicResource L_ReplayGain}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="ReplayGainModeComboBox"
                              Height="30"
                              MinWidth="360"
                              HorizontalAlignment="Stretch"
                              Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource L_ReplayGainHint}"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"/>

                    <Separator Margin="0,18,0,14"/>

                    <TextBlock Text="{DynamicResource L_Equalizer}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="EqualizerProfileComboBox"
                                  Height="30"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="EqualizerProfileComboBox_OnSelectionChanged"/>
                        <Button Grid.Column="1"
                                Height="30"
                                MinWidth="150"
                                Margin="8,0,0,0"
                                Padding="12,0"
                                Theme="{StaticResource SettingsButtonTheme}"
                                Content="{DynamicResource L_EqualizerCreate}"
                                Click="CreateEqualizerProfileButton_OnClick"/>
                        <Button x:Name="DeleteEqualizerProfileButton"
                                Grid.Column="2"
                                Height="30"
                                MinWidth="130"
                                Margin="8,0,0,0"
                                Padding="12,0"
                                IsVisible="False"
                                Theme="{StaticResource SettingsButtonTheme}"
                                Content="{DynamicResource L_EqualizerDelete}"
                                Click="DeleteEqualizerProfileButton_OnClick"/>
                    </Grid>
                    <StackPanel x:Name="EqualizerEditorPanel"
                                IsVisible="False">
                        <CheckBox x:Name="EqualizerEnabledCheckBox"
                                  Theme="{StaticResource SettingsToggleTheme}"
                                  Content="{DynamicResource L_EqualizerEnabled}"
                                  IsCheckedChanged="EqualizerEnabledCheckBox_OnIsCheckedChanged"
                                  Margin="0,0,0,10"/>
                        <Button x:Name="ImportEqualizerProfileButton"
                                Width="220"
                                Height="30"
                                HorizontalAlignment="Left"
                                Theme="{StaticResource SettingsButtonTheme}"
                                Content="{DynamicResource L_EqualizerImport}"
                                Click="ImportEqualizerProfileButton_OnClick"/>
                        <TextBlock x:Name="EqualizerProfileTextBlock"
                                   Margin="0,8,0,0"
                                   FontSize="{DynamicResource FontSizeMeta}"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   TextWrapping="Wrap"/>
                        <controls:EqualizerResponseControl x:Name="EqualizerResponseGraph"
                                                           Height="180"
                                                           Margin="0,12,0,4"/>
                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{DynamicResource L_EqualizerPreamp}"
                                       VerticalAlignment="Center"
                                       FontSize="{DynamicResource FontSizeMeta}"
                                       Margin="0,0,10,0"/>
                            <NumericUpDown x:Name="EqualizerPreampNumericUpDown"
                                           Grid.Column="1"
                                           Height="30"
                                           Minimum="-100"
                                           Maximum="100"
                                           Increment="0.5"
                                           FormatString="0.0"
                                           ClipValueToMinMax="True"
                                           ValueChanged="EqualizerPreampNumericUpDown_OnValueChanged"/>
                        </Grid>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="#"
                                       FontSize="{DynamicResource FontSizeMeta}"
                                       Foreground="{DynamicResource AppMutedTextBrush}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{DynamicResource L_EqualizerFilterType}"
                                       FontSize="{DynamicResource FontSizeMeta}"
                                       Foreground="{DynamicResource AppMutedTextBrush}"/>
                            <TextBlock Grid.Column="2"
                                       Text="{DynamicResource L_EqualizerFrequency}"
                                       FontSize="{DynamicResource FontSizeMeta}"
                                       Foreground="{DynamicResource AppMutedTextBrush}"/>
                            <TextBlock Grid.Column="3"
                                       Text="{DynamicResource L_EqualizerGain}"
                                       FontSize="{DynamicResource FontSizeMeta}"
                                       Foreground="{DynamicResource AppMutedTextBrush}"/>
                            <TextBlock Grid.Column="4"
                                       Text="{DynamicResource L_EqualizerQ}"
                                       FontSize="{DynamicResource FontSizeMeta}"
                                       Foreground="{DynamicResource AppMutedTextBrush}"/>
                        </Grid>
                        <Border MaxHeight="260"
                                BorderBrush="{DynamicResource AppInputBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="6">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="EqualizerFiltersPanel"/>
                            </ScrollViewer>
                        </Border>
                        <Button x:Name="AddEqualizerFilterButton"
                                Width="150"
                                Height="30"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"
                                Theme="{StaticResource SettingsButtonTheme}"
                                Content="{DynamicResource L_EqualizerAddFilter}"
                                Click="AddEqualizerFilterButton_OnClick"/>
                        <TextBlock Text="{DynamicResource L_EqualizerHint}"
                                   Margin="0,6,0,0"
                                   FontSize="{DynamicResource FontSizeMeta}"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="LibraryPanel"
                            IsVisible="False">
                    <TextBlock Text="{DynamicResource L_Directories}"
                               FontSize="{DynamicResource FontSizeBodyStrong}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20"/>

                    <ScrollViewer MaxHeight="320"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="DirectoriesPanel"/>
                    </ScrollViewer>

                    <Button x:Name="AddDirectoryButton"
                            Width="180"
                            Height="30"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0"
                            Theme="{StaticResource SettingsButtonTheme}"
                            Content="{DynamicResource L_AddDirectory}"
                            Click="AddDirectoryButton_OnClick"/>

                    <Separator Margin="0,18,0,14"/>

                    <TextBlock Text="{DynamicResource L_LibraryBackup}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="{DynamicResource L_LibraryBackupHint}"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ExportLibraryButton"
                                Width="180"
                                Height="30"
                                Theme="{StaticResource SettingsButtonTheme}"
                                Content="{DynamicResource L_ExportLibrary}"
                                Click="ExportLibraryButton_OnClick"/>
                        <Button x:Name="ImportLibraryButton"
                                Width="180"
                                Height="30"
                                Margin="8,0,0,0"
                                Theme="{StaticResource SettingsButtonTheme}"
                                Content="{DynamicResource L_ImportLibrary}"
                                Click="ImportLibraryButton_OnClick"/>
                    </StackPanel>
                    <TextBlock x:Name="LibraryBackupStatusTextBlock"
                               Margin="0,8,0,0"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                    <ProgressBar x:Name="LibraryExportProgressBar"
                                 Height="8"
                                 Margin="0,8,0,0"
                                 Minimum="0"
                                 Maximum="100"
                                 IsVisible="False"
                                 Foreground="#6C63FF"
                                 Background="{DynamicResource AppGridLineBrush}"/>

                    <Separator Margin="0,18,0,14"/>

                    <TextBlock Text="{DynamicResource L_DatabaseMaintenance}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="{DynamicResource L_DatabaseOptimizeHint}"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                    <Button x:Name="OptimizeDatabaseButton"
                            Width="180"
                            Height="30"
                            HorizontalAlignment="Left"
                            Theme="{StaticResource SettingsButtonTheme}"
                            Content="{DynamicResource L_OptimizeDatabase}"
                            Click="OptimizeDatabaseButton_OnClick"/>
                    <Button x:Name="RepairAlbumArtworkButton"
                            Width="180"
                            Height="30"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Theme="{StaticResource SettingsButtonTheme}"
                            Content="{DynamicResource L_RepairAlbumArtwork}"
                            Click="RepairAlbumArtworkButton_OnClick"/>
                    <Button x:Name="NormalizeArtistsButton"
                            Width="220"
                            Height="30"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Theme="{StaticResource SettingsButtonTheme}"
                            Content="{DynamicResource L_NormalizeArtists}"
                            Click="NormalizeArtistsButton_OnClick"/>
                    <TextBlock Text="{DynamicResource L_NormalizeArtistsHint}"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0"/>
                    <Button x:Name="DownloadMissingArtworkButton"
                            Width="260"
                            Height="30"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Theme="{StaticResource SettingsButtonTheme}"
                            Content="{DynamicResource L_DownloadMissingArtwork}"
                            Click="DownloadMissingArtworkButton_OnClick"/>
                    <TextBlock Text="{DynamicResource L_DownloadMissingArtworkHint}"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0"/>
                    <TextBlock x:Name="DatabaseMaintenanceStatusTextBlock"
                               Margin="0,8,0,0"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel x:Name="OrynivoServersSettingsPanel"
                            IsVisible="False">
                    <TextBlock Text="{DynamicResource L_OrynivoServersSettings}"
                               FontSize="{DynamicResource FontSizeBodyStrong}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource L_OrynivoServersHint}"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>
                    <StackPanel x:Name="OrynivoServersPanel"/>
                    <Button Width="140"
                            Height="30"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Theme="{StaticResource SettingsButtonTheme}"
                            Content="{DynamicResource L_AddOrynivoServer}"
                            Click="AddOrynivoServerButton_OnClick"/>
                </StackPanel>

                <StackPanel x:Name="StreamingPanel"
                            IsVisible="False">
                    <TextBlock Text="{DynamicResource L_StreamingServices}"
                               FontSize="{DynamicResource FontSizeBodyStrong}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="{DynamicResource L_Qobuz}"
                               FontSize="{DynamicResource FontSizeBody}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource L_QobuzIntegrationHint}"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"/>

                    <TextBlock Text="{DynamicResource L_QobuzApplicationId}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="QobuzApplicationIdTextBox"
                             Height="30"
                             HorizontalAlignment="Stretch"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource L_QobuzCredentialsHint}"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,24"/>

                    <TextBlock Text="{DynamicResource L_PlexServersSettings}"
                               FontSize="{DynamicResource FontSizeBody}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="{DynamicResource L_PlexServersHint}"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>
                    <StackPanel x:Name="PlexServersPanel"/>
                    <Button Width="140"
                            Height="30"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Theme="{StaticResource SettingsButtonTheme}"
                            Content="{DynamicResource L_AddPlexServer}"
                            Click="AddPlexServerButton_OnClick"/>
                </StackPanel>

                <StackPanel x:Name="ArtistInfoPanel"
                            IsVisible="False">
                    <TextBlock Text="{DynamicResource L_ArtistInfo}"
                               FontSize="{DynamicResource FontSizeBodyStrong}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20"/>

                    <TextBlock Text="{DynamicResource L_ArtistInfoSourceSetting}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="ArtistInfoSourceComboBox"
                              Height="30"
                              HorizontalAlignment="Stretch"
                              Margin="0,0,0,18"
                              SelectionChanged="ArtistInfoSourceComboBox_OnSelectionChanged"/>

                    <StackPanel x:Name="LastFmPanel"
                                IsVisible="False">
                        <TextBlock Text="{DynamicResource L_LastFmApiKey}"
                                   FontSize="{DynamicResource FontSizeCaption}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6"/>
                        <TextBox x:Name="LastFmApiKeyTextBox"
                                 Height="30"
                                 HorizontalAlignment="Stretch"
                                 Padding="8,0"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,8"/>
                        <TextBlock Text="{DynamicResource L_LastFmApiKeyHint}"
                                   FontSize="{DynamicResource FontSizeMeta}"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel x:Name="AppearancePanel"
                            IsVisible="False">
                    <TextBlock Text="{DynamicResource L_Appearance}"
                               FontSize="{DynamicResource FontSizeBodyStrong}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20"/>
                    <TextBlock Text="{DynamicResource L_ColorScheme}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="ThemeComboBox"
                              Height="30"
                              HorizontalAlignment="Stretch"
                              Margin="0,0,0,12"/>

                    <TextBlock Text="{DynamicResource L_Language}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="LanguageComboBox"
                              Height="30"
                              HorizontalAlignment="Stretch"
                              Margin="0,0,0,20"/>

                    <TextBlock Text="{DynamicResource L_SidebarSections}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="{DynamicResource L_SidebarSectionsHint}"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                    <CheckBox x:Name="ShowInternetRadioItemCheckBox"
                              Content="{DynamicResource L_InternetRadio}"
                              Theme="{StaticResource SettingsToggleTheme}"
                              Margin="0,4"/>
                    <CheckBox x:Name="ShowPodcastsItemCheckBox"
                              Content="{DynamicResource L_Podcasts}"
                              Theme="{StaticResource SettingsToggleTheme}"
                              Margin="0,4"/>
                    <CheckBox x:Name="ShowQueueItemCheckBox"
                              Content="{DynamicResource L_UpNext}"
                              Theme="{StaticResource SettingsToggleTheme}"
                              Margin="0,4"/>
                    <CheckBox x:Name="ShowLocalLibrarySectionCheckBox"
                              Content="{DynamicResource L_LocalLibrary}"
                              Theme="{StaticResource SettingsToggleTheme}"
                              Margin="0,4"/>
                    <CheckBox x:Name="ShowOwnRadiosSectionCheckBox"
                              Content="{DynamicResource L_OwnRadios}"
                              Theme="{StaticResource SettingsToggleTheme}"
                              Margin="0,4"/>
                    <CheckBox x:Name="ShowMyPodcastsSectionCheckBox"
                              Content="{DynamicResource L_MyPodcasts}"
                              Theme="{StaticResource SettingsToggleTheme}"
                              Margin="0,4"/>
                    <CheckBox x:Name="ShowPlexSectionCheckBox"
                              Content="{DynamicResource L_PlexServers}"
                              Theme="{StaticResource SettingsToggleTheme}"
                              Margin="0,4"/>
                </StackPanel>

                <StackPanel x:Name="McpPanel"
                            IsVisible="False">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource L_McpServer}"
                                   FontSize="{DynamicResource FontSizeBodyStrong}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <controls:StatusBadge x:Name="McpStatusBadge"
                                              Margin="12,0,0,0"
                                              VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource L_McpServerHint}"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>
                    <CheckBox x:Name="McpServerEnabledCheckBox"
                              Content="{DynamicResource L_McpServerEnabled}"
                              Theme="{StaticResource SettingsToggleTheme}"
                              Margin="0,0,0,16"/>
                    <TextBlock Text="{DynamicResource L_McpServerPort}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <NumericUpDown x:Name="McpServerPortNumericUpDown"
                                   Height="30"
                                   Minimum="1024"
                                   Maximum="65535"
                                   Increment="1"
                                   FormatString="0"
                                   ClipValueToMinMax="True"
                                   HorizontalAlignment="Stretch"
                                   Margin="0,0,0,12"/>
                    <TextBlock x:Name="McpServerStatusTextBlock"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,20"/>

                    <Border Height="1"
                            Background="{DynamicResource AppGridLineBrush}"
                            Margin="0,0,0,16"/>

                    <TextBlock Text="{DynamicResource L_McpToolsHeader}"
                               FontSize="{DynamicResource FontSizeBody}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="{DynamicResource L_McpToolsHint}"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <UniformGrid Columns="2" Rows="12">
                        <CheckBox x:Name="McpToolGetNowPlaying"
                                  Content="get_now_playing"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,8,6"/>
                        <CheckBox x:Name="McpToolGetQueue"
                                  Content="get_queue"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,0,6"/>
                        <CheckBox x:Name="McpToolPlay"
                                  Content="play"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,8,6"/>
                        <CheckBox x:Name="McpToolPauseResume"
                                  Content="pause_resume"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,0,6"/>
                        <CheckBox x:Name="McpToolNextTrack"
                                  Content="next_track"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,8,6"/>
                        <CheckBox x:Name="McpToolPreviousTrack"
                                  Content="previous_track"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,0,6"/>
                        <CheckBox x:Name="McpToolStop"
                                  Content="stop"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,8,6"/>
                        <CheckBox x:Name="McpToolSeek"
                                  Content="seek"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,0,6"/>
                        <CheckBox x:Name="McpToolSetVolume"
                                  Content="set_volume"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,8,6"/>
                        <CheckBox x:Name="McpToolQueueAppend"
                                  Content="queue_append"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,0,6"/>
                        <CheckBox x:Name="McpToolQueuePlayNext"
                                  Content="queue_play_next"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,8,6"/>
                        <CheckBox x:Name="McpToolSearchLibrary"
                                  Content="search_library"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,0,6"/>
                        <CheckBox x:Name="McpToolListPlaylists"
                                  Content="list_playlists"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,8,6"/>
                        <CheckBox x:Name="McpToolGetPlaylistTracks"
                                  Content="get_playlist_tracks"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,0,6"/>
                        <CheckBox x:Name="McpToolCreatePlaylist"
                                  Content="create_playlist"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,8,6"/>
                        <CheckBox x:Name="McpToolCreateSmartPlaylist"
                                  Content="create_smart_playlist"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,0,6"/>
                        <CheckBox x:Name="McpToolGetPlayHistory"
                                  Content="get_play_history"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,8,6"/>
                        <CheckBox x:Name="McpToolClearQueue"
                                  Content="clear_queue"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,0,6"/>
                        <CheckBox x:Name="McpToolReplaceQueue"
                                  Content="replace_queue"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,8,6"/>
                        <CheckBox x:Name="McpToolGetCurrentTime"
                                  Content="get_current_time"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,0,6"/>
                        <CheckBox x:Name="McpToolSearchWeb"
                                  Content="search_web"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,8,6"/>
                        <CheckBox x:Name="McpToolFetchPage"
                                  Content="fetch_page"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,0,6"/>
                        <CheckBox x:Name="McpToolFetchPageMarkdown"
                                  Content="fetch_page_as_markdown"
                                  Theme="{StaticResource SettingsCheckBoxTheme}"
                                  Margin="0,0,8,6"/>
                    </UniformGrid>

                    <Border Height="1"
                            Background="{DynamicResource AppGridLineBrush}"
                            Margin="0,16,0,16"/>

                    <TextBlock Text="{DynamicResource L_WebBrowsing}"
                               FontSize="{DynamicResource FontSizeBody}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBlock Text="{DynamicResource L_WebBrowsingHint}"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>
                    <CheckBox x:Name="WebBrowsingEnabledCheckBox"
                              Content="{DynamicResource L_WebBrowsingEnabled}"
                              Theme="{StaticResource SettingsToggleTheme}"
                              Margin="0,0,0,14"/>

                    <TextBlock Text="{DynamicResource L_SearxngUrl}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="SearxngUrlTextBox"
                             Height="30"
                             HorizontalAlignment="Stretch"
                             Padding="8,0"
                             VerticalContentAlignment="Center"
                             Margin="0,0,0,14"/>

                    <CheckBox x:Name="WebBlockPrivateCheckBox"
                              Content="{DynamicResource L_WebBlockPrivate}"
                              Theme="{StaticResource SettingsToggleTheme}"
                              Margin="0,0,0,14"/>

                    <TextBlock Text="{DynamicResource L_WebMaxResults}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <NumericUpDown x:Name="WebMaxResultsNumericUpDown"
                                   Height="30"
                                   Minimum="1"
                                   Maximum="25"
                                   Increment="1"
                                   FormatString="0"
                                   ClipValueToMinMax="True"
                                   HorizontalAlignment="Stretch"
                                   Margin="0,0,0,14"/>

                    <TextBlock Text="{DynamicResource L_WebTimeoutSeconds}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <NumericUpDown x:Name="WebTimeoutNumericUpDown"
                                   Height="30"
                                   Minimum="1"
                                   Maximum="120"
                                   Increment="1"
                                   FormatString="0"
                                   ClipValueToMinMax="True"
                                   HorizontalAlignment="Stretch"
                                   Margin="0,0,0,14"/>

                    <TextBlock Text="{DynamicResource L_WebMaxResponseKb}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <NumericUpDown x:Name="WebMaxResponseKbNumericUpDown"
                                   Height="30"
                                   Minimum="16"
                                   Maximum="20480"
                                   Increment="256"
                                   FormatString="0"
                                   ClipValueToMinMax="True"
                                   HorizontalAlignment="Stretch"/>
                </StackPanel>

                <StackPanel x:Name="AiChatPanel"
                            IsVisible="False">
                    <TextBlock Text="{DynamicResource L_AiChatSettings}"
                               FontSize="{DynamicResource FontSizeBodyStrong}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20"/>
                    <TextBlock Text="{DynamicResource L_AiChatHint}"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,14"/>
                    <CheckBox x:Name="AiChatEnabledCheckBox"
                              Content="{DynamicResource L_AiChatEnabled}"
                              Theme="{StaticResource SettingsToggleTheme}"
                              Margin="0,0,0,18"/>

                    <TextBlock Text="{DynamicResource L_AiChatEndpointUrl}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="AiChatEndpointUrlTextBox"
                             Height="30"
                             HorizontalAlignment="Stretch"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="{DynamicResource L_AiChatApiKey}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="AiChatApiKeyTextBox"
                             Height="30"
                             PasswordChar="●"
                             HorizontalAlignment="Stretch"
                             Margin="0,0,0,4"/>
                    <TextBlock Text="{DynamicResource L_AiChatLocalNote}"
                               FontSize="{DynamicResource FontSizeMeta}"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Margin="0,0,0,14"/>

                    <TextBlock Text="{DynamicResource L_AiChatModel}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="AiChatModelTextBox"
                             Height="30"
                             HorizontalAlignment="Stretch"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="{DynamicResource L_AiChatMaxTokens}"
                               FontSize="{DynamicResource FontSizeCaption}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <NumericUpDown x:Name="AiChatMaxTokensNumericUpDown"
                                   Height="30"
                                   Minimum="256"
                                   Maximum="32768"
                                   Increment="256"
                                   FormatString="0"
                                   ClipValueToMinMax="True"
                                   HorizontalAlignment="Stretch"/>
                </StackPanel>

            </Grid>
        </ScrollViewer>

        <Border Grid.Column="0"
                Grid.ColumnSpan="3"
                Grid.Row="1"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource AppHeaderBorderBrush}"
                Padding="16,10">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="90"
                        Height="30"
                        Margin="0,0,10,0"
                        Theme="{StaticResource SettingsButtonTheme}"
                        Click="CancelButton_OnClick"
                        Content="{DynamicResource L_Cancel}"/>
                <Button Width="90"
                        Height="30"
                        Theme="{StaticResource SettingsButtonTheme}"
                        Click="SaveButton_OnClick"
                        Content="{DynamicResource L_Save}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
