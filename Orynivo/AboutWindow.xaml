<Window x:Class="Orynivo.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L_About}"
        Icon="Assets/Orynivo.ico"
        Width="560"
        Height="460"
        MinWidth="480"
        MinHeight="360"
        Background="{DynamicResource AppContentBrush}"
        Foreground="{DynamicResource AppPrimaryTextBrush}"
        SourceInitialized="AboutWindow_OnSourceInitialized">
    <Grid>
        <StackPanel Margin="22">
            <TextBlock Text="Orynivo"
                       FontSize="22"
                       FontWeight="Bold"/>
            <TextBlock Margin="0,18,0,4"
                       FontWeight="SemiBold"
                       Text="{DynamicResource L_Author}"/>
            <TextBlock Text="Björn Schlaack"/>

            <TextBlock Margin="0,22,0,10"
                       FontWeight="SemiBold"
                       Text="{DynamicResource L_Licenses}"/>

            <StackPanel>
                <TextBlock Text="ASIO is a trademark and software of Steinberg Media Technologies GmbH."/>
                <TextBlock Text="cwASIO — MIT License" Margin="0,6,0,0"/>
                <TextBlock Text="Lucene.NET 4.8.0-beta00017 — Apache License 2.0"/>
                <TextBlock Text="Microsoft.Data.Sqlite 9.0.5 — MIT License" Margin="0,6,0,0"/>
                <TextBlock Text="NAudio 2.3.0 — MIT License" Margin="0,6,0,0"/>
                <TextBlock Text="TagLibSharp 2.3.0 — LGPL-2.1 License" Margin="0,6,0,0"/>
                <TextBlock Text="SQLitePCLRaw / e_sqlite3 — Apache License 2.0" Margin="0,6,0,0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
