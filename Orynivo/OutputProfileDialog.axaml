<Window x:Class="Orynivo.OutputProfileDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L_OutputProfileCreateTitle}"
        Icon="avares://Orynivo/Assets/Orynivo.ico"
        Width="480"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppSurfaceBrush}"
        Foreground="{DynamicResource AppPrimaryTextBrush}">
    <Window.Resources>
        <ControlTheme x:Key="DialogButtonTheme" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppButtonBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppButtonTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#ButtonBorder">
                <Setter Property="Background" Value="{DynamicResource AppButtonHoverBrush}"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#ButtonBorder">
                <Setter Property="Background" Value="{DynamicResource AppButtonPressedBrush}"/>
            </Style>
            <Style Selector="^:disabled">
                <Setter Property="Opacity" Value="0.55"/>
            </Style>
        </ControlTheme>
        <ControlTheme x:Key="DialogPrimaryButtonTheme"
                      TargetType="Button"
                      BasedOn="{StaticResource DialogButtonTheme}">
            <Setter Property="Background" Value="{DynamicResource AppTransportPlayBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style Selector="^:pointerover /template/ Border#ButtonBorder">
                <Setter Property="Background" Value="{DynamicResource AppTransportPlayHoverBrush}"/>
            </Style>
        </ControlTheme>
    </Window.Resources>

    <Grid Margin="24,20,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{DynamicResource L_OutputProfileName}"
                   FontSize="{DynamicResource FontSizeCaption}"
                   Foreground="{DynamicResource AppMutedTextBrush}"
                   Margin="0,0,0,6"/>
        <TextBox x:Name="NameTextBox"
                 Grid.Row="1"
                 Height="34"
                 Padding="10,0"
                 VerticalContentAlignment="Center"
                 Background="{DynamicResource AppInputBrush}"
                 Foreground="{DynamicResource AppPrimaryTextBrush}"
                 BorderBrush="{DynamicResource AppInputBorderBrush}"
                 TextChanged="NameTextBox_OnTextChanged"
                 KeyDown="NameTextBox_OnKeyDown"/>
        <TextBlock x:Name="ValidationTextBlock"
                   Grid.Row="2"
                   MinHeight="18"
                   Margin="0,5,0,14"
                   FontSize="{DynamicResource FontSizeMeta}"
                   Foreground="{DynamicResource AppMutedTextBrush}"
                   TextWrapping="Wrap"/>

        <TextBlock Grid.Row="3"
                   Text="{DynamicResource L_OutputType}"
                   FontSize="{DynamicResource FontSizeCaption}"
                   Foreground="{DynamicResource AppMutedTextBrush}"
                   Margin="0,0,0,6"/>
        <ComboBox x:Name="BackendComboBox"
                  Grid.Row="4"
                  Height="34"
                  HorizontalAlignment="Stretch"
                  Margin="0,0,0,14"
                  SelectionChanged="BackendComboBox_OnSelectionChanged"/>

        <TextBlock x:Name="DeviceLabelTextBlock"
                   Grid.Row="5"
                   Text="{DynamicResource L_AsioOutputDevice}"
                   FontSize="{DynamicResource FontSizeCaption}"
                   Foreground="{DynamicResource AppMutedTextBrush}"
                   Margin="0,0,0,6"/>
        <ComboBox x:Name="DeviceComboBox"
                  Grid.Row="6"
                  Height="34"
                  HorizontalAlignment="Stretch"
                  Margin="0,0,0,8"
                  SelectionChanged="DeviceComboBox_OnSelectionChanged"/>
        <Grid Grid.Row="7" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="DeviceInfoButton"
                    Width="130"
                    Height="28"
                    IsEnabled="False"
                    IsVisible="False"
                    Theme="{StaticResource DialogButtonTheme}"
                    Content="{DynamicResource L_DeviceInfo}"
                    Click="DeviceInfoButton_OnClick"/>
            <TextBlock x:Name="StatusTextBlock"
                       Grid.Column="1"
                       Margin="12,0,0,0"
                       VerticalAlignment="Center"
                       FontSize="{DynamicResource FontSizeMeta}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource AppMutedTextBrush}"/>
        </Grid>

        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="96"
                    Height="34"
                    Margin="0,0,8,0"
                    Theme="{StaticResource DialogButtonTheme}"
                    Content="{DynamicResource L_Cancel}"
                    Click="CancelButton_OnClick"/>
            <Button x:Name="SaveButton"
                    Width="110"
                    Height="34"
                    IsEnabled="False"
                    Theme="{StaticResource DialogPrimaryButtonTheme}"
                    Content="{DynamicResource L_Save}"
                    Click="SaveButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
