<Window x:Class="Orynivo.ArtistImageSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L_ArtistImageSearchTitle}"
        Icon="Assets/Orynivo.ico"
        Height="620"
        Width="560"
        MinHeight="440"
        MinWidth="480"
        Background="{DynamicResource AppContentBrush}"
        Foreground="{DynamicResource AppPrimaryTextBrush}"
        SourceInitialized="ArtistImageSearchWindow_OnSourceInitialized">
    <Window.Resources>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6C63FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock x:Name="BusyIndicatorTextBlock"
                       Text="⠋"
                       FontSize="16"
                       Margin="0,0,8,0"/>
            <TextBlock x:Name="StatusTextBlock"
                       Text="{DynamicResource L_ArtistImageSearchRunning}"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{DynamicResource L_ArtistImageSearchQuery}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="QueryTextBox"
                         Height="28"
                         VerticalContentAlignment="Center"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Width="110"
                    Height="28"
                    Margin="10,20,0,0"
                    Style="{StaticResource DialogButtonStyle}"
                    Content="{DynamicResource L_SearchAgain}"
                    Click="SearchAgainButton_OnClick"/>
        </Grid>
        <ListBox x:Name="ResultsListBox"
                 Grid.Row="2"
                 Background="Transparent"
                 BorderThickness="0"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,8"
                            Padding="10"
                            Background="{DynamicResource AppSurfaceBrush}"
                            CornerRadius="0,14,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="112"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="96"
                                    Height="96"
                                    Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                    ClipToBounds="True">
                                <Image Source="{Binding Image}"
                                       Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Attribution}"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding License}"
                                           Margin="0,4,0,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource AppMutedTextBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button Grid.Row="3"
                Width="220"
                Height="30"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Style="{StaticResource DialogButtonStyle}"
                Content="{DynamicResource L_UseSelectedArtistImage}"
                Click="UseSelectedImageButton_OnClick"/>
    </Grid>
</Window>
