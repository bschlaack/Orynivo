<Window x:Class="Orynivo.NewPlaylistDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L_NewPlaylistDialogTitle}"
        Icon="avares://Orynivo/Assets/Orynivo.ico"
        Width="380"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppSurfaceBrush}">
    <Grid Margin="24,20,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{DynamicResource L_NewPlaylistNameLabel}"
                   FontSize="12"
                   Foreground="{DynamicResource AppMutedTextBrush}"
                   Margin="0,0,0,6"/>

        <TextBox x:Name="NameTextBox"
                 Grid.Row="1"
                 Height="34"
                 Padding="10,0"
                 VerticalContentAlignment="Center"
                 FontSize="13"
                 Background="{DynamicResource AppInputBrush}"
                 Foreground="{DynamicResource AppPrimaryTextBrush}"
                 BorderBrush="{DynamicResource AppInputBorderBrush}"
                 Margin="0,0,0,20"
                 TextChanged="NameTextBox_OnTextChanged"
                 KeyDown="NameTextBox_OnKeyDown"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource L_Cancel}"
                    Width="96" Height="34"
                    Margin="0,0,8,0"
                    Background="{DynamicResource AppButtonBrush}"
                    Foreground="{DynamicResource AppButtonTextBrush}"
                    BorderBrush="{DynamicResource AppButtonBorderBrush}"
                    BorderThickness="1"
                    Cursor="Hand"
                    Click="CancelButton_OnClick"/>
            <Button x:Name="CreateButton"
                    Content="{DynamicResource L_CreatePlaylist}"
                    Width="96" Height="34"
                    IsEnabled="False"
                    Background="#6C63FF"
                    Foreground="White"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="CreateButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
