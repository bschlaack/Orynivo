<Window x:Class="Orynivo.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orynivo"
        Icon="Assets/Orynivo.ico"
        Width="420"
        Height="220"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="#13142A">
    <Border Padding="28" CornerRadius="12" Background="#13142A">
        <StackPanel VerticalAlignment="Center">
            <Border Padding="14,10"
                    CornerRadius="10,10,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#7268A7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Image Height="66"
                       Source="Assets/Orynivo_Logo.png"
                       Stretch="Uniform"/>
            </Border>
            <TextBlock x:Name="StatusTextBlock"
                       Margin="0,16,0,12"
                       Foreground="#CCCCEE"
                       FontSize="13"
                       Text="{DynamicResource L_StartupPreparingLibrary}"/>
            <ProgressBar IsIndeterminate="True"
                         Height="6"
                         Background="#252640"
                         Foreground="#6C63FF"/>
        </StackPanel>
    </Border>
</Window>
