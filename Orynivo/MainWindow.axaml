<Window x:Class="Orynivo.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Orynivo.Controls"
        xmlns:conv="using:Avalonia.Data.Converters"
        xmlns:ai="using:Orynivo.AI"
        Title="Orynivo" Icon="avares://Orynivo/Assets/Orynivo.ico"
        Height="760" Width="1100"
        WindowState="Maximized"
        MinHeight="600" MinWidth="800">
    <Window.Resources>

        <!-- Sidebar nav item -->
        <ControlTheme x:Key="NavItemTheme" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource AppNavTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="MaxWidth" Value="220"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bd"
                            Background="Transparent"
                            BorderThickness="3,0,0,0"
                            BorderBrush="Transparent"
                            Padding="21,8,12,8"
                            ClipToBounds="True">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Stretch"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:selected /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource AppNavSelectedBrush}"/>
                <Setter Property="BorderBrush" Value="#6C63FF"/>
            </Style>
            <Style Selector="^:selected">
                <Setter Property="Foreground" Value="{DynamicResource AppNavSelectedTextBrush}"/>
            </Style>
            <Style Selector="^:pointerover:not(:selected) /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource AppNavHoverBrush}"/>
            </Style>
            <Style Selector="^:pointerover:not(:selected)">
                <Setter Property="Foreground" Value="{DynamicResource AppNavHoverTextBrush}"/>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="NavSectionHeaderTheme" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="MaxWidth" Value="220"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            Padding="24,12,14,5"
                            ClipToBounds="True">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Stretch"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource AppNavHoverBrush}"/>
            </Style>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{DynamicResource AppNavHoverTextBrush}"/>
            </Style>
        </ControlTheme>

        <!-- Transport secondary button -->
        <ControlTheme x:Key="TransportBtnTheme" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppTransportButtonBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTransportButtonTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="17">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource AppTransportButtonHoverBrush}"/>
            </Style>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{DynamicResource AppTransportButtonHoverTextBrush}"/>
            </Style>
            <Style Selector="^:disabled /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource AppTransportButtonDisabledBrush}"/>
            </Style>
            <Style Selector="^:disabled">
                <Setter Property="Foreground" Value="{DynamicResource AppTransportButtonDisabledTextBrush}"/>
            </Style>
        </ControlTheme>

        <!-- Transport primary button (play/pause) -->
        <ControlTheme x:Key="PlayBtnTheme" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{DynamicResource AppTransportPlayBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="22">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource AppTransportPlayHoverBrush}"/>
            </Style>
            <Style Selector="^:disabled /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource AppTransportPlayDisabledBrush}"/>
            </Style>
            <Style Selector="^:disabled">
                <Setter Property="Foreground" Value="{DynamicResource AppTransportPlayDisabledTextBrush}"/>
            </Style>
        </ControlTheme>

        <!-- Popup checkbox - theme-aware colors matching AppInputBrush/AppPrimaryTextBrush -->
        <ControlTheme x:Key="PopupCheckBoxTheme" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="CheckBorder"
                                Width="16" Height="16"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                Background="{DynamicResource AppInputBrush}"
                                BorderBrush="{DynamicResource AppInputBorderBrush}"
                                BorderThickness="1" CornerRadius="3">
                            <Path x:Name="CheckMark"
                                  Width="9" Height="7"
                                  Data="M 0 3.5 L 3 6.5 L 9 0"
                                  Stroke="White" StrokeThickness="2"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  IsVisible="False"/>
                        </Border>
                        <ContentPresenter Grid.Column="1"
                                          Content="{TemplateBinding Content}"
                                          Margin="8,0,0,0"
                                          TextBlock.FontSize="{TemplateBinding FontSize}"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"
                                          VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#CheckBorder">
                <Setter Property="BorderBrush" Value="#6C63FF"/>
            </Style>
            <Style Selector="^:checked /template/ Border#CheckBorder">
                <Setter Property="Background" Value="#6C63FF"/>
                <Setter Property="BorderBrush" Value="#6C63FF"/>
            </Style>
            <Style Selector="^:checked /template/ Path#CheckMark">
                <Setter Property="IsVisible" Value="True"/>
            </Style>
        </ControlTheme>

        <!-- Settings button -->
        <ControlTheme x:Key="SidebarBtnTheme" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppNavTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            Padding="24,14">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource AppNavHoverBrush}"/>
            </Style>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{DynamicResource AppNavHoverTextBrush}"/>
            </Style>
        </ControlTheme>

        <!-- Back navigation button -->
        <ControlTheme x:Key="HeaderIconButtonTheme" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8FA7FF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Bd">
                <Setter Property="Background" Value="#252640"/>
            </Style>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="#B5C4FF"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#Bd">
                <Setter Property="Background" Value="#303251"/>
            </Style>
        </ControlTheme>

        <!-- Header filter button -->
        <ControlTheme x:Key="HeaderFilterButtonTheme" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppButtonBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppButtonTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource AppButtonHoverBrush}"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource AppButtonPressedBrush}"/>
            </Style>
            <Style Selector="^:disabled /template/ Border#Bd">
                <Setter Property="Opacity" Value="0.38"/>
            </Style>
            <Style Selector="^:disabled">
                <Setter Property="Cursor" Value="Arrow"/>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="HeaderCheckBoxTheme" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <StackPanel Orientation="Horizontal"
                                Spacing="7"
                                VerticalAlignment="Center">
                        <Border x:Name="Box"
                                Width="16"
                                Height="16"
                                Background="{DynamicResource AppInputBrush}"
                                BorderBrush="#8FA7FF"
                                BorderThickness="1.2"
                                CornerRadius="4">
                            <Path x:Name="CheckMark"
                                  Data="M 3 8 L 6.3 11.2 L 13 4.5"
                                  Stroke="White"
                                  StrokeThickness="1.9"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  IsVisible="False"/>
                        </Border>
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          VerticalAlignment="Center"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
            </Style>
            <Style Selector="^:pointerover /template/ Border#Box">
                <Setter Property="BorderBrush" Value="#B5C4FF"/>
                <Setter Property="Background" Value="#252640"/>
            </Style>
            <Style Selector="^:checked /template/ Border#Box">
                <Setter Property="Background" Value="#6C63FF"/>
                <Setter Property="BorderBrush" Value="#8FA7FF"/>
            </Style>
            <Style Selector="^:checked /template/ Path#CheckMark">
                <Setter Property="IsVisible" Value="True"/>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="TrackFilterExpanderTheme" TargetType="Expander">
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <StackPanel>
                        <ToggleButton x:Name="PART_ToggleButton"
                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      Background="{DynamicResource AppButtonBrush}"
                                      Foreground="{DynamicResource AppButtonTextBrush}"
                                      BorderBrush="{DynamicResource AppButtonBorderBrush}"
                                      BorderThickness="1"
                                      Content="{TemplateBinding Header}"
                                      Cursor="Hand">
                            <ToggleButton.Theme>
                                <ControlTheme TargetType="ToggleButton">
                                    <Setter Property="Template">
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bd"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="8"
                                                    Padding="10,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Path x:Name="Arrow"
                                                          Width="10"
                                                          Height="10"
                                                          Margin="0,0,10,0"
                                                          VerticalAlignment="Center"
                                                          Data="M 1 3 L 5 7 L 9 3"
                                                          Stroke="{TemplateBinding Foreground}"
                                                          StrokeThickness="1.8"
                                                          StrokeLineCap="Round"
                                                          StrokeJoin="Round"/>
                                                    <ContentPresenter Grid.Column="1"
                                                                      Content="{TemplateBinding Content}"
                                                                      VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter>
                                    <Style Selector="^:pointerover /template/ Border#Bd">
                                        <Setter Property="Background" Value="{DynamicResource AppButtonHoverBrush}"/>
                                    </Style>
                                    <Style Selector="^:pressed /template/ Border#Bd">
                                        <Setter Property="Background" Value="{DynamicResource AppButtonPressedBrush}"/>
                                    </Style>
                                    <Style Selector="^:checked /template/ Path#Arrow">
                                        <Setter Property="Data" Value="M 1 7 L 5 3 L 9 7"/>
                                    </Style>
                                </ControlTheme>
                            </ToggleButton.Theme>
                        </ToggleButton>
                        <ContentPresenter x:Name="ExpandSite"
                                          Margin="10,6,0,0"
                                          IsVisible="False"
                                          Content="{TemplateBinding Content}"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:expanded /template/ ContentPresenter#ExpandSite">
                <Setter Property="IsVisible" Value="True"/>
            </Style>
        </ControlTheme>

        <!-- Dark slider (transport bar) -->
        <ControlTheme x:Key="DarkSliderTheme" TargetType="Slider">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid Height="30"
                          VerticalAlignment="Center"
                          Background="Transparent">
                        <Border Height="3"
                                VerticalAlignment="Center"
                                Background="#2E2F4A"
                                CornerRadius="1.5"/>
                        <Track Name="PART_Track"
                               Minimum="{TemplateBinding Minimum}"
                               Maximum="{TemplateBinding Maximum}"
                               Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                               Orientation="{TemplateBinding Orientation}"
                               VerticalAlignment="Center">
                            <Track.DecreaseButton>
                                <RepeatButton>
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="3" VerticalAlignment="Center"
                                                    Background="#6C63FF" CornerRadius="1.5"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseButton>
                            <Track.Thumb>
                                <Thumb Width="14"
                                       Height="14"
                                       VerticalAlignment="Center">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse x:Name="El"
                                                     Width="14"
                                                     Height="14"
                                                     Fill="White"
                                                     Stroke="#6C63FF"
                                                     StrokeThickness="1"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseButton>
                                <RepeatButton>
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="3" VerticalAlignment="Center"
                                                    Background="#2E2F4A" CornerRadius="1.5"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter>
        </ControlTheme>

        <ControlTheme x:Key="AlphabetIndexButtonTheme" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="9.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bd"
                            Margin="2,1"
                            Background="{TemplateBinding Background}"
                            CornerRadius="3">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Bd">
                <Setter Property="Background" Value="{DynamicResource AppNavHoverBrush}"/>
            </Style>
            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="#6C63FF"/>
            </Style>
            <Style Selector="^.active /template/ Border#Bd">
                <Setter Property="Background" Value="#6C63FF"/>
            </Style>
            <Style Selector="^.active">
                <Setter Property="Foreground" Value="White"/>
            </Style>
            <Style Selector="^:disabled">
                <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}"/>
                <Setter Property="Opacity" Value="0.3"/>
                <Setter Property="Cursor" Value="Arrow"/>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="EntityLinkButtonTheme" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <TextBlock x:Name="Text"
                               Text="{TemplateBinding Content}"
                               Foreground="{TemplateBinding Foreground}"
                               FontSize="{TemplateBinding FontSize}"
                               FontWeight="{TemplateBinding FontWeight}"
                               HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                               TextTrimming="CharacterEllipsis"/>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ TextBlock#Text">
                <Setter Property="Foreground" Value="#6C63FF"/>
                <Setter Property="TextDecorations" Value="Underline"/>
            </Style>
        </ControlTheme>

        <!-- Segmented view mode switcher -->
        <ControlTheme x:Key="ViewModeRadioTheme" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#666688"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="22,9"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:checked /template/ Border#Bd">
                <Setter Property="Background" Value="#6C63FF"/>
            </Style>
            <Style Selector="^:checked">
                <Setter Property="Foreground" Value="White"/>
            </Style>
            <Style Selector="^:pointerover:not(:checked) /template/ Border#Bd">
                <Setter Property="Background" Value="#DDDDF5"/>
            </Style>
        </ControlTheme>

    </Window.Resources>

    <Window.Styles>
        <!-- Implicit DataGrid styles -->
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="{DynamicResource AppContentBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppGridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="ComboBoxItem">
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource AppColumnHeaderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,11"/>
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppGridLineBrush}"/>
        </Style>
        <Style Selector="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
        </Style>
        <Style Selector="DataGridRow:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}"/>
        </Style>
        <Style Selector="DataGridRow:selected">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceSelectedBrush}"/>
        </Style>
        <Style Selector="DataGridRow.nowPlaying:not(:selected)">
            <Setter Property="Background" Value="{DynamicResource AppNowPlayingRowBrush}"/>
        </Style>
        <Style Selector="DataGridRow.nowPlaying:pointerover:not(:selected)">
            <Setter Property="Background" Value="{DynamicResource AppNowPlayingRowBrush}"/>
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Padding="{TemplateBinding Padding}"
                            Background="Transparent">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="DataGridCell TextBlock">
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridCell}}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style Selector="DataGridCell Button">
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="ListBox#NavListBox ListBoxItem TextBlock">
            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"/>
        </Style>
        <Style Selector="TreeViewItem">
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
            <Setter Property="Padding" Value="4,5"/>
        </Style>
        <Style Selector="TreeViewItem /template/ ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}"/>
        </Style>
        <Style Selector="TreeViewItem /template/ ToggleButton:pointerover">
            <Setter Property="Foreground" Value="#6C63FF"/>
        </Style>
        <Style Selector="TreeViewItem ToggleButton">
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}"/>
        </Style>
        <Style Selector="TreeViewItem ToggleButton:pointerover">
            <Setter Property="Foreground" Value="#6C63FF"/>
        </Style>
        <Style Selector="TreeViewItem /template/ PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}"/>
        </Style>
        <Style Selector="TreeViewItem /template/ ToggleButton Path">
            <Setter Property="Fill" Value="{DynamicResource AppSecondaryTextBrush}"/>
            <Setter Property="Stroke" Value="{DynamicResource AppSecondaryTextBrush}"/>
        </Style>
        <Style Selector="TreeViewItem /template/ ToggleButton:pointerover Path">
            <Setter Property="Fill" Value="#6C63FF"/>
            <Setter Property="Stroke" Value="#6C63FF"/>
        </Style>
        <Style Selector="TreeViewItem ToggleButton Path">
            <Setter Property="Fill" Value="{DynamicResource AppSecondaryTextBrush}"/>
            <Setter Property="Stroke" Value="{DynamicResource AppSecondaryTextBrush}"/>
        </Style>
        <Style Selector="TreeViewItem ToggleButton:pointerover Path">
            <Setter Property="Fill" Value="#6C63FF"/>
            <Setter Property="Stroke" Value="#6C63FF"/>
        </Style>
        <Style Selector="TreeViewItem:selected">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceSelectedBrush}"/>
        </Style>
        <Style Selector="TreeViewItem:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}"/>
        </Style>
        <Style Selector="TreeViewItem.nowPlaying">
            <Setter Property="Background" Value="{DynamicResource AppNowPlayingRowBrush}"/>
        </Style>
        <Style Selector="TreeViewItem.nowPlaying:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppNowPlayingRowBrush}"/>
        </Style>
        <!-- NavItemText helper -->
        <Style Selector="TextBlock.navItemText">
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="MaxWidth" Value="170"/>
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ SIDEBAR ═══ -->
        <Grid Grid.Column="0" Grid.Row="0" Background="{DynamicResource AppSidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- App title -->
            <Border Padding="18,16,18,14" BorderThickness="0,0,0,1" BorderBrush="#1E1F38">
                <StackPanel>
                    <Border Padding="9,7"
                            CornerRadius="0,18,0,18">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#7268A7" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Image Height="38"
                               Source="avares://Orynivo/Assets/Orynivo_Logo.png"
                               Stretch="Uniform"/>
                    </Border>
                    <TextBlock x:Name="SelectedDriverTextBlock"
                               Foreground="#7777AA" FontSize="10" Margin="4,8,4,0"
                               Text="{DynamicResource L_NoDeviceSelected}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <!-- Nav -->
            <ListBox x:Name="NavListBox"
                     Grid.Row="1"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0,8,0,8"
                     FontSize="13"
                     ClipToBounds="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionChanged="NavListBox_OnSelectionChanged"
                     PointerReleased="NavListBox_OnPreviewMouseLeftButtonUp">

                <ListBoxItem Tag="Dashboard" Theme="{StaticResource NavItemTheme}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⊞" Width="18" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource L_Dashboard}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>

                <ListBoxItem x:Name="InternetRadioNavItem" Tag="InternetRadio" Theme="{StaticResource NavItemTheme}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="◉" Width="18" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource L_InternetRadio}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>

                <ListBoxItem x:Name="PodcastsNavItem" Tag="Podcasts" Theme="{StaticResource NavItemTheme}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="◍" Width="18" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource L_Podcasts}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>

                <ListBoxItem x:Name="QueueNavItem" Tag="Queue" Theme="{StaticResource NavItemTheme}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="≡" Width="18" FontSize="15" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource L_UpNext}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>

                <ListBoxItem x:Name="AiChatNavItem" Tag="AiChat" Theme="{StaticResource NavItemTheme}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="✦" Width="18" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource L_AiChat}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>

                <ListBoxItem x:Name="LocalLibraryHeaderItem"
                             Tag="Section:LocalLibrary"
                             FontSize="10"
                             FontWeight="Bold"
                             Theme="{StaticResource NavSectionHeaderTheme}">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource L_LocalLibrary}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Path x:Name="LocalLibraryHeaderArrow"
                              Grid.Column="1"
                              Width="8"
                              Height="5"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 0 0 L 4 5 L 8 0"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                              StrokeThickness="1.4"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"/>
                    </Grid>
                </ListBoxItem>
                <ListBoxItem x:Name="ArtistsNavItem" Tag="Artists" Theme="{StaticResource NavItemTheme}"><TextBlock Text="{DynamicResource L_Artists}" Classes="navItemText"/></ListBoxItem>
                <ListBoxItem x:Name="AlbumsNavItem" Tag="Albums" Theme="{StaticResource NavItemTheme}"><TextBlock Text="{DynamicResource L_Albums}" Classes="navItemText"/></ListBoxItem>
                <ListBoxItem x:Name="TracksNavItem" Tag="Tracks" Theme="{StaticResource NavItemTheme}"><TextBlock Text="{DynamicResource L_Tracks}" Classes="navItemText"/></ListBoxItem>
                <ListBoxItem x:Name="FoldersNavItem" Tag="Folders" Theme="{StaticResource NavItemTheme}"><TextBlock Text="{DynamicResource L_FolderStructure}" Classes="navItemText"/></ListBoxItem>

                <ListBoxItem x:Name="OrynivoServerHeaderItem"
                             Tag="Section:OrynivoServer"
                             FontSize="10"
                             FontWeight="Bold"
                             Theme="{StaticResource NavSectionHeaderTheme}">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource L_OrynivoServers}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Path x:Name="OrynivoServerHeaderArrow"
                              Grid.Column="1"
                              Width="8"
                              Height="5"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 0 0 L 4 5 L 8 0"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                              StrokeThickness="1.4"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"/>
                    </Grid>
                </ListBoxItem>

                <ListBoxItem x:Name="OwnRadiosHeaderItem"
                             Tag="Section:OwnRadios"
                             FontSize="10"
                             FontWeight="Bold"
                             Theme="{StaticResource NavSectionHeaderTheme}">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource L_OwnRadios}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Path x:Name="OwnRadiosHeaderArrow"
                              Grid.Column="1"
                              Width="8"
                              Height="5"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 0 0 L 4 5 L 8 0"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                              StrokeThickness="1.4"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"/>
                    </Grid>
                </ListBoxItem>

                <ListBoxItem x:Name="MyPodcastsHeaderItem"
                             Tag="Section:MyPodcasts"
                             FontSize="10"
                             FontWeight="Bold"
                             Theme="{StaticResource NavSectionHeaderTheme}">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource L_MyPodcasts}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Path x:Name="MyPodcastsHeaderArrow"
                              Grid.Column="1"
                              Width="8"
                              Height="5"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 0 0 L 4 5 L 8 0"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                              StrokeThickness="1.4"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"/>
                    </Grid>
                </ListBoxItem>

                <ListBoxItem x:Name="PlexHeaderItem"
                             Tag="Section:Plex"
                             FontSize="10"
                             FontWeight="Bold"
                             Theme="{StaticResource NavSectionHeaderTheme}">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource L_PlexServers}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Path x:Name="PlexHeaderArrow"
                              Grid.Column="1"
                              Width="8"
                              Height="5"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 0 0 L 4 5 L 8 0"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                              StrokeThickness="1.4"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"/>
                    </Grid>
                </ListBoxItem>

                <ListBoxItem x:Name="PlaylistsHeaderItem"
                             Tag="Section:Playlists"
                             FontSize="10"
                             FontWeight="Bold"
                             Theme="{StaticResource NavSectionHeaderTheme}">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource L_Playlists}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Path x:Name="PlaylistsHeaderArrow"
                              Grid.Column="1"
                              Width="8"
                              Height="5"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 0 0 L 4 5 L 8 0"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                              StrokeThickness="1.4"
                              StrokeLineCap="Round"
                              StrokeJoin="Round"/>
                    </Grid>
                </ListBoxItem>
                <!-- Own radios, podcasts and playlist entries are added in code -->
            </ListBox>

            <!-- Status -->
            <TextBlock x:Name="StatusTextBlock"
                       Grid.Row="2"
                       Padding="24,8"
                       Foreground="#44445A" FontSize="10"
                       TextWrapping="Wrap"/>

            <!-- About -->
            <Button Grid.Row="3"
                    HorizontalAlignment="Stretch"
                    FontSize="13"
                    Theme="{StaticResource SidebarBtnTheme}"
                    Click="AboutButton_OnClick">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="ⓘ"
                               Width="16"
                               FontSize="17"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource L_About}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Grid.Row="4"
                    HorizontalAlignment="Stretch"
                    FontSize="13"
                    Theme="{StaticResource SidebarBtnTheme}"
                    Click="SettingsButton_OnClick">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="⚙"
                               Width="16"
                               FontSize="14"
                               Margin="0,0,8,0"
                               TextAlignment="Center"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource L_Settings}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ═══ CONTENT ═══ -->
        <Grid Grid.Column="1" Grid.Row="0" Background="{DynamicResource AppContentBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Background="{DynamicResource AppHeaderBrush}"
                    BorderThickness="0,0,0,1" BorderBrush="{DynamicResource AppHeaderBorderBrush}"
                    Padding="24,16">
                <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BackButton"
                                Width="24"
                                Height="24"
                                Margin="0,-1,10,0"
                                VerticalAlignment="Top"
                                IsVisible="False"
                                Theme="{StaticResource HeaderIconButtonTheme}"
                                Click="BackButton_OnClick"
                                ToolTip.Tip="{DynamicResource L_Back}">
                            <Path Data="M 14 5 L 7 12 L 14 19"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round"
                                  StrokeJoin="Round"
                                  Width="16"
                                  Height="16"
                                  Stretch="Uniform"/>
                        </Button>
                        <TextBlock x:Name="ContentTitleTextBlock"
                                   Grid.Column="1"
                                   FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AppPrimaryTextBrush}"
                                   VerticalAlignment="Top"/>
                        <TextBlock x:Name="ContentCountTextBlock"
                                Grid.Column="2"
                                Margin="14,0,0,0"
                                   FontSize="12" Foreground="{DynamicResource AppMutedTextBrush}"
                                   VerticalAlignment="Center"/>
                        <CheckBox x:Name="EntityFavoritesOnlyCheckBox"
                                Grid.Column="3"
                                Margin="14,0,0,0"
                                VerticalAlignment="Center"
                                IsVisible="False"
                                Theme="{StaticResource HeaderCheckBoxTheme}"
                                Content="{DynamicResource L_Favorites}"
                                IsCheckedChanged="EntityFavoritesOnlyCheckBox_OnChanged"/>
                        <Button x:Name="TrackFilterButton"
                                Grid.Column="4"
                                Margin="14,0,0,0"
                                Padding="12,5"
                                VerticalAlignment="Center"
                                IsVisible="False"
                                Theme="{StaticResource HeaderFilterButtonTheme}"
                                Content="{DynamicResource L_Filter}"
                                Click="TrackFilterButton_OnClick"/>
                        <Button x:Name="SaveSmartPlaylistButton"
                                Grid.Column="5"
                                Margin="8,0,0,0"
                                Padding="12,5"
                                VerticalAlignment="Center"
                                IsVisible="False"
                                IsEnabled="False"
                                Theme="{StaticResource HeaderFilterButtonTheme}"
                                ToolTip.Tip="{DynamicResource L_SaveSmartPlaylistDisabledTooltip}"
                                Click="SaveSmartPlaylistButton_OnClick">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚡" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{DynamicResource L_SaveSmartPlaylist}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="SaveQueueAsPlaylistButton"
                                Grid.Column="5"
                                Margin="8,0,0,0"
                                Padding="12,5"
                                VerticalAlignment="Center"
                                IsVisible="False"
                                Theme="{StaticResource HeaderFilterButtonTheme}"
                                Content="{DynamicResource L_SaveQueueAsPlaylist}"
                                Click="SaveQueueAsPlaylistButton_OnClick"/>
                        <TextBox x:Name="SearchTextBox"
                                Grid.Column="6"
                                 Width="240"
                                 Height="30"
                                 Margin="20,0,0,0"
                                 VerticalContentAlignment="Center"
                                 Background="{DynamicResource AppInputBrush}"
                                 Foreground="{DynamicResource AppPrimaryTextBrush}"
                                 BorderBrush="{DynamicResource AppInputBorderBrush}"
                                 Watermark="{DynamicResource L_Search}"
                                 ToolTip.Tip="{DynamicResource L_Search}"
                                 TextChanged="SearchTextBox_OnTextChanged"/>
                        <Border x:Name="AlbumViewModeBorder"
                                Grid.Column="7"
                                Margin="20,0,0,0"
                                Padding="4"
                                Background="{DynamicResource AppButtonBrush}"
                                CornerRadius="10"
                                IsVisible="False">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="AlbumTableViewRadioButton"
                                             GroupName="AlbumViewMode"
                                             Theme="{StaticResource ViewModeRadioTheme}"
                                             MinWidth="104"
                                             Content="{DynamicResource L_Table}"
                                             IsChecked="True"
                                             IsCheckedChanged="AlbumViewModeRadioButton_OnChecked"/>
                                <RadioButton x:Name="AlbumArtworkViewRadioButton"
                                             GroupName="AlbumViewMode"
                                             Theme="{StaticResource ViewModeRadioTheme}"
                                             MinWidth="104"
                                             Content="{DynamicResource L_Artwork}"
                                             IsCheckedChanged="AlbumViewModeRadioButton_OnChecked"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="PlexViewModeBorder"
                                Grid.Column="7"
                                Margin="20,0,0,0"
                                Padding="3"
                                Background="{DynamicResource AppButtonBrush}"
                                CornerRadius="9"
                                IsVisible="False">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="PlexArtistsViewRadioButton"
                                             GroupName="PlexViewMode"
                                             Theme="{StaticResource ViewModeRadioTheme}"
                                             MinWidth="76"
                                             Content="{DynamicResource L_Artists}"
                                             IsChecked="True"
                                             Tag="Artists"
                                             IsCheckedChanged="PlexViewModeRadioButton_OnChecked"/>
                                <RadioButton GroupName="PlexViewMode"
                                             Theme="{StaticResource ViewModeRadioTheme}"
                                             MinWidth="76"
                                             Content="{DynamicResource L_Albums}"
                                             Tag="Albums"
                                             IsCheckedChanged="PlexViewModeRadioButton_OnChecked"/>
                                <RadioButton GroupName="PlexViewMode"
                                             Theme="{StaticResource ViewModeRadioTheme}"
                                             MinWidth="76"
                                             Content="{DynamicResource L_Tracks}"
                                             Tag="Tracks"
                                             IsCheckedChanged="PlexViewModeRadioButton_OnChecked"/>
                                <RadioButton GroupName="PlexViewMode"
                                             Theme="{StaticResource ViewModeRadioTheme}"
                                             MinWidth="92"
                                             Content="{DynamicResource L_FolderStructure}"
                                             Tag="Folders"
                                             IsCheckedChanged="PlexViewModeRadioButton_OnChecked"/>
                                <Button x:Name="PlexLoadMoreButton"
                                        Margin="5,0,0,0"
                                        Padding="10,3"
                                        IsVisible="False"
                                        Theme="{StaticResource HeaderFilterButtonTheme}"
                                        Content="{DynamicResource L_LoadMore}"
                                        Click="PlexLoadMoreButton_OnClick"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="OrynivoServerViewModeBorder"
                                Grid.Column="7"
                                Margin="20,0,0,0"
                                Padding="3"
                                Background="{DynamicResource AppButtonBrush}"
                                CornerRadius="9"
                                IsVisible="False">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="OrynivoArtistsViewRadioButton"
                                             GroupName="OrynivoServerViewMode"
                                             Theme="{StaticResource ViewModeRadioTheme}"
                                             MinWidth="76"
                                             Content="{DynamicResource L_Artists}"
                                             IsChecked="True"
                                             Tag="Artists"
                                             IsCheckedChanged="OrynivoServerViewModeRadioButton_OnChecked"/>
                                <RadioButton GroupName="OrynivoServerViewMode"
                                             Theme="{StaticResource ViewModeRadioTheme}"
                                             MinWidth="76"
                                             Content="{DynamicResource L_Albums}"
                                             Tag="Albums"
                                             IsCheckedChanged="OrynivoServerViewModeRadioButton_OnChecked"/>
                                <RadioButton GroupName="OrynivoServerViewMode"
                                             Theme="{StaticResource ViewModeRadioTheme}"
                                             MinWidth="76"
                                             Content="{DynamicResource L_Tracks}"
                                             Tag="Tracks"
                                             IsCheckedChanged="OrynivoServerViewModeRadioButton_OnChecked"/>
                            </StackPanel>
                        </Border>
                </Grid>
            </Border>

            <Popup x:Name="TrackFilterPopup"
                   Grid.Row="0"
                   PlacementTarget="{Binding ElementName=TrackFilterButton}"
                   Placement="Bottom"
                   IsLightDismissEnabled="True">
                <Border Margin="0,8,0,0"
                        Width="640"
                        MaxHeight="430"
                        Padding="14"
                        CornerRadius="10"
                        Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="{DynamicResource AppInputBorderBrush}"
                        BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="TrackFilterPanel"/>
                    </ScrollViewer>
                </Border>
            </Popup>

            <Border x:Name="LibraryIntroCard"
                    Grid.Row="1"
                    Height="96"
                    Margin="28,16,28,10"
                    Padding="24,16"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="#6C63FF"
                    BorderThickness="1"
                    CornerRadius="0,24,0,24"
                    IsVisible="False">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="LibraryIntroTitleTextBlock"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                        <TextBlock x:Name="LibraryIntroHintTextBlock"
                                   Margin="0,6,20,0"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock x:Name="LibraryIntroIconTextBlock"
                               Grid.Column="1"
                               FontSize="30"
                               Foreground="#6C63FF"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Dashboard -->
            <ScrollViewer x:Name="DashboardScrollViewer"
                          Grid.Row="2"
                          IsVisible="False"
                          Background="{DynamicResource AppContentBrush}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="DashboardPanel" Margin="28,24,28,28"/>
            </ScrollViewer>

            <!-- AI Chat -->
            <ai:AiChatView x:Name="AiChatViewControl"
                           Grid.Row="1"
                           Grid.RowSpan="2"
                           IsVisible="False"
                           ZIndex="15"/>

            <Grid x:Name="InternetRadioView"
                  Grid.Row="1"
                  Grid.RowSpan="2"
                  IsVisible="False"
                  Background="{DynamicResource AppContentBrush}"
                  ZIndex="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border x:Name="RadioNowPlayingPanel"
                        Margin="28,24,28,14"
                        Padding="24"
                        IsVisible="False"
                        Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="#6C63FF"
                        BorderThickness="1"
                        CornerRadius="0,24,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="160"
                                Height="160"
                                Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                CornerRadius="0,22,0,22"
                                ClipToBounds="True">
                            <Grid>
                                <TextBlock Text="◉"
                                           FontSize="52"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Image x:Name="RadioNowPlayingLogo"
                                       Stretch="Uniform"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource L_RadioNowPlaying}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="#6C63FF"/>
                            <TextBlock x:Name="RadioNowPlayingStation"
                                       Margin="0,7,0,0"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="RadioNowPlayingTitle"
                                       Margin="0,12,0,0"
                                       FontSize="21"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="RadioNowPlayingArtist"
                                       Margin="0,5,0,0"
                                       FontSize="16"
                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="RadioNowPlayingDescription"
                                       Margin="0,10,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="28,24,28,14"
                        Padding="24"
                        Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="#6C63FF"
                        BorderThickness="1"
                        CornerRadius="0,24,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L_RadioDirectory}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                            <TextBlock Text="{DynamicResource L_RadioDirectoryHint}"
                                       Margin="0,7,20,0"
                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="◉"
                                   FontSize="38"
                                   Foreground="#6C63FF"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="28,0,28,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="RadioSearchTextBox"
                             Height="36"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             Background="{DynamicResource AppInputBrush}"
                             Foreground="{DynamicResource AppPrimaryTextBrush}"
                             BorderBrush="{DynamicResource AppInputBorderBrush}"
                             ToolTip.Tip="{DynamicResource L_RadioSearch}"
                             KeyDown="RadioSearchTextBox_OnKeyDown"/>
                    <Button x:Name="RadioGenreFilterButton"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            Padding="14,7"
                            Theme="{StaticResource HeaderFilterButtonTheme}"
                            Content="{DynamicResource L_RadioGenres}"
                            Click="RadioGenreFilterButton_OnClick"/>
                    <Button Grid.Column="2"
                            Margin="10,0,0,0"
                            Padding="18,7"
                            Theme="{StaticResource HeaderFilterButtonTheme}"
                            Content="{DynamicResource L_RadioSearch}"
                            Click="RadioSearchButton_OnClick"/>
                </Grid>

                <Popup x:Name="RadioGenreFilterPopup"
                       PlacementTarget="{Binding ElementName=RadioGenreFilterButton}"
                       Placement="Bottom"
                       IsLightDismissEnabled="True">
                    <Border Margin="0,8,0,0"
                            Width="320"
                            MaxHeight="420"
                            Padding="14"
                            CornerRadius="10"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppInputBorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource L_RadioGenres}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppPrimaryTextBrush}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Padding="9,4"
                                        Theme="{StaticResource HeaderFilterButtonTheme}"
                                        Content="{DynamicResource L_ClearFilter}"
                                        Click="ClearRadioGenreFilterButton_OnClick"/>
                            </Grid>
                            <ScrollViewer Grid.Row="1"
                                          Margin="0,10,0,0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="RadioGenreFilterPanel"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Popup>

                <Grid Grid.Row="3" Margin="28,0,28,24">
                    <DataGrid x:Name="RadioStationsDataGrid"
                              Background="{DynamicResource AppContentBrush}"
                              BorderThickness="0"
                              RowHeight="54"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource AppGridLineBrush}"
                              AutoGenerateColumns="False"
                              CanUserResizeColumns="True"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              LoadingRow="TrackDataGrid_OnLoadingRow"
                              DoubleTapped="RadioStationsDataGrid_OnMouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="38"
                                                Height="38"
                                                CornerRadius="8"
                                                Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                                ClipToBounds="True">
                                            <Grid>
                                                <TextBlock Text="♪"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource AppMutedTextBrush}"/>
                                                <Image Source="{Binding Favicon}" Stretch="UniformToFill"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource L_RadioStation}"
                                                Binding="{Binding Name}"
                                                Tag="name"
                                                Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource L_Country}"
                                                Binding="{Binding CountryCode}"
                                                Tag="country"
                                                Width="90"/>
                            <DataGridTextColumn Header="{DynamicResource L_Genre}"
                                                Binding="{Binding GenreSummary}"
                                                Tag="genre"
                                                Width="180"/>
                            <DataGridTextColumn Header="{DynamicResource L_Format}"
                                                Binding="{Binding FormatSummary}"
                                                Tag="format"
                                                Width="120"/>
                            <DataGridTextColumn Header="{DynamicResource L_Codec}"
                                                Binding="{Binding Codec}"
                                                Tag="codec"
                                                IsVisible="False"
                                                Width="100"/>
                            <DataGridTextColumn Header="{DynamicResource L_Bitrate}"
                                                Binding="{Binding BitrateSummary}"
                                                Tag="bitrate"
                                                IsVisible="False"
                                                Width="90"/>
                            <DataGridTextColumn Header="{DynamicResource L_Tags}"
                                                Binding="{Binding Tags}"
                                                Tag="tags"
                                                IsVisible="False"
                                                Width="220"/>
                            <DataGridTextColumn Header="{DynamicResource L_Homepage}"
                                                Binding="{Binding Homepage}"
                                                Tag="homepage"
                                                IsVisible="False"
                                                Width="220"/>
                            <DataGridTemplateColumn Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{DynamicResource L_PlayRadio}"
                                                Tag="{Binding}"
                                                Padding="10,5"
                                                Theme="{StaticResource HeaderFilterButtonTheme}"
                                                Click="PlayRadioButton_OnClick"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{DynamicResource L_AddToOwnRadios}"
                                                Tag="{Binding}"
                                                Padding="10,5"
                                                Theme="{StaticResource HeaderFilterButtonTheme}"
                                                Click="AddRadioButton_OnClick"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="RadioStatusTextBlock"
                               Margin="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </Grid>
            </Grid>

            <Grid x:Name="PodcastView"
                  Grid.Row="1"
                  Grid.RowSpan="2"
                  IsVisible="False"
                  Background="{DynamicResource AppContentBrush}"
                  ZIndex="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Margin="28,24,28,14"
                        Padding="24"
                        Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="#6C63FF"
                        BorderThickness="1"
                        CornerRadius="0,24,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L_PodcastDirectory}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                            <TextBlock Text="{DynamicResource L_PodcastDirectoryHint}"
                                       Margin="0,7,20,0"
                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="◍"
                                   FontSize="38"
                                   Foreground="#6C63FF"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="28,0,28,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PodcastSearchTextBox"
                             Height="36"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             Background="{DynamicResource AppInputBrush}"
                             Foreground="{DynamicResource AppPrimaryTextBrush}"
                             BorderBrush="{DynamicResource AppInputBorderBrush}"
                             ToolTip.Tip="{DynamicResource L_PodcastSearch}"
                             KeyDown="PodcastSearchTextBox_OnKeyDown"/>
                    <Button x:Name="PodcastCategoryFilterButton"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            Padding="14,7"
                            Theme="{StaticResource HeaderFilterButtonTheme}"
                            Content="{DynamicResource L_PodcastCategories}"
                            Click="PodcastCategoryFilterButton_OnClick"/>
                    <Button x:Name="PodcastLanguageFilterButton"
                            Grid.Column="2"
                            Margin="10,0,0,0"
                            Padding="14,7"
                            Theme="{StaticResource HeaderFilterButtonTheme}"
                            Content="{DynamicResource L_PodcastLanguages}"
                            Click="PodcastLanguageFilterButton_OnClick"/>
                    <Button Grid.Column="3"
                            Margin="10,0,0,0"
                            Padding="18,7"
                            Theme="{StaticResource HeaderFilterButtonTheme}"
                            Content="{DynamicResource L_PodcastSearch}"
                            Click="PodcastSearchButton_OnClick"/>
                </Grid>

                <Popup x:Name="PodcastCategoryFilterPopup"
                       PlacementTarget="{Binding ElementName=PodcastCategoryFilterButton}"
                       Placement="Bottom"
                       IsLightDismissEnabled="True">
                    <Border Margin="0,8,0,0"
                            Width="320"
                            MaxHeight="420"
                            Padding="14"
                            CornerRadius="10"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppInputBorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource L_PodcastCategories}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                                <Button Grid.Column="1"
                                        Padding="9,4"
                                        Theme="{StaticResource HeaderFilterButtonTheme}"
                                        Content="{DynamicResource L_ClearFilter}"
                                        Click="ClearPodcastCategoryFilterButton_OnClick"/>
                            </Grid>
                            <ScrollViewer Grid.Row="1"
                                          Margin="0,10,0,0"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="PodcastCategoryFilterPanel"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Popup>

                <Popup x:Name="PodcastLanguageFilterPopup"
                       PlacementTarget="{Binding ElementName=PodcastLanguageFilterButton}"
                       Placement="Bottom"
                       IsLightDismissEnabled="True">
                    <Border Margin="0,8,0,0"
                            Width="280"
                            MaxHeight="420"
                            Padding="14"
                            CornerRadius="10"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppInputBorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource L_PodcastLanguages}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                                <Button Grid.Column="1"
                                        Padding="9,4"
                                        Theme="{StaticResource HeaderFilterButtonTheme}"
                                        Content="{DynamicResource L_ClearFilter}"
                                        Click="ClearPodcastLanguageFilterButton_OnClick"/>
                            </Grid>
                            <ScrollViewer Grid.Row="1"
                                          Margin="0,10,0,0"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="PodcastLanguageFilterPanel"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Popup>

                <Grid Grid.Row="2" Margin="28,0,28,24">
                    <DataGrid x:Name="PodcastsDataGrid"
                              Background="{DynamicResource AppContentBrush}"
                              BorderThickness="0"
                              RowHeight="64"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource AppGridLineBrush}"
                              AutoGenerateColumns="False"
                              CanUserResizeColumns="True"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              DoubleTapped="PodcastsDataGrid_OnMouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="78">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="48"
                                                Height="48"
                                                CornerRadius="8"
                                                Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                                ClipToBounds="True">
                                            <Grid>
                                                <TextBlock Text="◍"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource AppMutedTextBrush}"/>
                                                <Image Source="{Binding ArtworkUrl}" Stretch="UniformToFill"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource L_Podcast}"
                                                Binding="{Binding Name}"
                                                Tag="podcast"
                                                Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource L_PodcastAuthor}"
                                                Binding="{Binding Author}"
                                                Tag="author"
                                                Width="220"/>
                            <DataGridTextColumn Header="{DynamicResource L_Genre}"
                                                Binding="{Binding Genre}"
                                                Tag="genre"
                                                Width="150"/>
                            <DataGridTextColumn Header="{DynamicResource L_PodcastLanguage}"
                                                Binding="{Binding LanguageDisplay}"
                                                Tag="language"
                                                Width="110"/>
                            <DataGridTextColumn Header="{DynamicResource L_FeedUrl}"
                                                Binding="{Binding FeedUrl}"
                                                Tag="feed"
                                                IsVisible="False"
                                                Width="280"/>
                            <DataGridTemplateColumn Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{DynamicResource L_ShowEpisodes}"
                                                Tag="{Binding}"
                                                Padding="10,5"
                                                Theme="{StaticResource HeaderFilterButtonTheme}"
                                                Click="ShowPodcastEpisodesButton_OnClick"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{DynamicResource L_AddToMyPodcasts}"
                                                Tag="{Binding}"
                                                Padding="10,5"
                                                Theme="{StaticResource HeaderFilterButtonTheme}"
                                                Click="AddPodcastButton_OnClick"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="PodcastStatusTextBlock"
                               Margin="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </Grid>

                <Grid x:Name="PodcastEpisodesView"
                      Grid.Row="0"
                      Grid.RowSpan="3"
                      IsVisible="False"
                      Background="{DynamicResource AppContentBrush}"
                      ZIndex="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Margin="28,24,28,14"
                            Padding="24"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="#6C63FF"
                            BorderThickness="1"
                            CornerRadius="0,24,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="166"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="PodcastEpisodesBackButton"
                                    Padding="12,7"
                                    Margin="0,0,16,0"
                                    VerticalAlignment="Center"
                                    Theme="{StaticResource HeaderFilterButtonTheme}"
                                    Content="{DynamicResource L_Back}"
                                    Click="PodcastEpisodesBackButton_OnClick"/>
                            <Border Grid.Column="1"
                                    Width="150"
                                    Height="150"
                                    Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                    CornerRadius="0,20,0,20"
                                    ClipToBounds="True">
                                <Image x:Name="PodcastEpisodesArtwork" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource L_PodcastOverview}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="#6C63FF"/>
                                <TextBlock x:Name="PodcastEpisodesTitle"
                                           Margin="0,5,0,0"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppPrimaryTextBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="PodcastEpisodesAuthor"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                                <TextBlock x:Name="PodcastEpisodesStatistics"
                                           Margin="0,12,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppPrimaryTextBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="PodcastEpisodesMetadata"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="PodcastEpisodesDescription"
                                           Margin="0,10,0,0"
                                           MaxHeight="48"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="28,0,28,24">
                        <DataGrid x:Name="PodcastEpisodesDataGrid"
                                  Background="{DynamicResource AppContentBrush}"
                                  BorderThickness="0"
                                  RowHeight="54"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource AppGridLineBrush}"
                            AutoGenerateColumns="False"
                            CanUserResizeColumns="True"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  LoadingRow="TrackDataGrid_OnLoadingRow"
                                  DoubleTapped="PodcastEpisodesDataGrid_OnMouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource L_PodcastStatus}"
                                                    Binding="{Binding Status}"
                                                    Tag="status"
                                                    Width="90"/>
                                <DataGridTextColumn Header="{DynamicResource L_Title}"
                                                    Binding="{Binding Title}"
                                                    Tag="title"
                                                    Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource L_Published}"
                                                    Binding="{Binding Published}"
                                                    Tag="published"
                                                    Width="120"/>
                                <DataGridTextColumn Header="{DynamicResource L_Duration}"
                                                    Binding="{Binding Duration}"
                                                    Tag="duration"
                                                    Width="90"/>
                                <DataGridTextColumn Header="{DynamicResource L_Progress}"
                                                    Binding="{Binding Progress}"
                                                    Tag="progress"
                                                    Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock x:Name="PodcastEpisodesStatusTextBlock"
                                   Margin="12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </Grid>
                </Grid>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border x:Name="AlbumDetailHeader"
                        Grid.Row="0"
                        IsVisible="False"
                        Margin="24,22,24,18"
                        Padding="22"
                        HorizontalAlignment="Stretch"
                        Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="#6C63FF"
                        BorderThickness="1"
                        CornerRadius="0,24,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240"/>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="240"
                                Height="240"
                                Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{DynamicResource L_DeleteCover}"
                                              Tag="{Binding}"
                                              Click="DeleteCoverMenuItem_OnClick"/>
                                    <MenuItem Header="{DynamicResource L_ReassignCover}"
                                              Tag="{Binding}"
                                              Click="ReassignCoverMenuItem_OnClick"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid>
                                <Image Source="{Binding Artwork}" Stretch="UniformToFill"/>
                                <StackPanel IsVisible="{Binding Artwork, Converter={x:Static conv:ObjectConverters.IsNull}}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource L_CoverNotFound}"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,10"/>
                                    <Button Content="{DynamicResource L_SearchCover}"
                                            Tag="{Binding}"
                                            Padding="14,7"
                                            Background="#6C63FF"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="SearchCoverButton_OnClick"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                <Button Content="{Binding FavoriteGlyph}"
                                        Tag="{Binding}"
                                        Width="40"
                                        Height="36"
                                        Padding="0"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        FontSize="20"
                                        ToolTip.Tip="{DynamicResource L_MarkAsFavorite}"
                                        Theme="{StaticResource HeaderFilterButtonTheme}"
                                        Click="AlbumDetailFavoriteButton_OnClick"/>
                                <Button Content="{Binding Title}"
                                        Tag="{Binding}"
                                        FontSize="28"
                                        FontWeight="SemiBold"
                                        Theme="{StaticResource EntityLinkButtonTheme}"
                                        Click="AlbumLinkButton_OnClick"/>
                            </StackPanel>
                            <Button Content="{Binding Artist}"
                                    Tag="{Binding}"
                                    Margin="0,10,0,0"
                                    FontSize="17"
                                    Foreground="{DynamicResource AppSecondaryTextBrush}"
                                    Theme="{StaticResource EntityLinkButtonTheme}"
                                    Click="ArtistLinkButton_OnClick"/>
                            <TextBlock Text="{Binding Year}"
                                       Margin="0,8,0,0"
                                       FontSize="14"
                                       Foreground="{DynamicResource AppMutedTextBrush}"/>
                            <StackPanel Margin="0,12,0,0"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        Spacing="8">
                                <Button Content="{DynamicResource L_SearchCover}"
                                        Tag="{Binding}"
                                        Padding="14,7"
                                        Theme="{StaticResource HeaderFilterButtonTheme}"
                                        Click="SearchCoverButton_OnClick"/>
                                <Button Content="{DynamicResource L_SaveAlbumAsPlaylist}"
                                        Padding="14,7"
                                        Theme="{StaticResource HeaderFilterButtonTheme}"
                                        Click="AlbumSaveAsPlaylistButton_OnClick"/>
                            </StackPanel>
                            <CheckBox x:Name="ShowAllAlbumTracksCheckBox"
                                      Margin="0,18,0,0"
                                      HorizontalAlignment="Left"
                                      Theme="{StaticResource HeaderCheckBoxTheme}"
                                      Content="{DynamicResource L_ShowAllAlbumTracks}"
                                      IsVisible="False"
                                      IsCheckedChanged="ShowAllAlbumTracksCheckBox_OnChanged"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content DataGrid -->
                <DataGrid x:Name="ContentDataGrid"
                          Grid.Row="1"
                          Background="{DynamicResource AppContentBrush}"
                          BorderThickness="0"
                          RowHeight="40"
                          ColumnHeaderHeight="44"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource AppGridLineBrush}"
                          AutoGenerateColumns="False"
                          CanUserResizeColumns="True"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          FontSize="12"
                          LoadingRow="ContentDataGrid_OnLoadingRow"
                          DoubleTapped="ContentDataGrid_OnMouseDoubleClick"/>

                <ScrollViewer x:Name="AlbumFolderGroupsScrollViewer"
                              Grid.Row="1"
                              IsVisible="False"
                              Background="{DynamicResource AppContentBrush}"
                              BringIntoViewOnFocusChange="False"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="AlbumFolderGroupsPanel"
                                Margin="24,22,24,24"
                                Spacing="18"/>
                </ScrollViewer>
            </Grid>

            <ScrollViewer x:Name="SearchResultsScrollViewer"
                          Grid.Row="2"
                          IsVisible="False"
                          Background="{DynamicResource AppContentBrush}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="18">
                    <Border Background="{DynamicResource AppSurfaceBrush}"
                            CornerRadius="10"
                            Padding="14"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L_Tracks}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}"
                                       Margin="0,0,0,10"/>
                            <DataGrid x:Name="SearchTracksDataGrid"
                                      MinHeight="180"
                                      MaxHeight="280"
                                      Background="{DynamicResource AppSurfaceBrush}"
                                      BorderThickness="0"
                                      AutoGenerateColumns="False"
                                      CanUserResizeColumns="True"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource AppGridLineBrush}"
                                      LoadingRow="TrackDataGrid_OnLoadingRow"
                                      DoubleTapped="SearchTracksDataGrid_OnMouseDoubleClick"/>
                            <TextBlock x:Name="SearchTracksEmptyTextBlock"
                                       IsVisible="False"
                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       Margin="2,10,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource AppSurfaceBrush}"
                            CornerRadius="10"
                            Padding="14"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L_Albums}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}"
                                       Margin="0,0,0,10"/>
                            <DataGrid x:Name="SearchAlbumsDataGrid"
                                      MinHeight="160"
                                      MaxHeight="240"
                                      Background="{DynamicResource AppSurfaceBrush}"
                                      BorderThickness="0"
                                      AutoGenerateColumns="False"
                                      CanUserResizeColumns="True"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource AppGridLineBrush}"
                                      LoadingRow="PlaylistDataGrid_OnLoadingRow"
                                      DoubleTapped="SearchAlbumsDataGrid_OnMouseDoubleClick"/>
                            <TextBlock x:Name="SearchAlbumsEmptyTextBlock"
                                       IsVisible="False"
                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       Margin="2,10,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource AppSurfaceBrush}"
                            CornerRadius="10"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L_Artists}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}"
                                       Margin="0,0,0,10"/>
                            <DataGrid x:Name="SearchArtistsDataGrid"
                                      MinHeight="140"
                                      MaxHeight="220"
                                      Background="{DynamicResource AppSurfaceBrush}"
                                      BorderThickness="0"
                                      AutoGenerateColumns="False"
                                      CanUserResizeColumns="True"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource AppGridLineBrush}"
                                      DoubleTapped="SearchArtistsDataGrid_OnMouseDoubleClick"/>
                            <TextBlock x:Name="SearchArtistsEmptyTextBlock"
                                       IsVisible="False"
                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       Margin="2,10,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Folder TreeView -->
            <TreeView x:Name="FolderTreeView"
                      Grid.Row="2"
                      Background="{DynamicResource AppContentBrush}"
                      BorderThickness="0"
                      FontSize="13"
                      IsVisible="False"
                      DoubleTapped="FolderTreeView_OnMouseDoubleClick"/>

            <!-- Album artwork view -->
            <ListBox x:Name="AlbumArtworkListBox"
                     Grid.Row="2"
                     IsVisible="False"
                     Background="{DynamicResource AppContentBrush}"
                     BorderThickness="0"
                     DoubleTapped="AlbumArtworkListBox_OnMouseDoubleClick">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <controls:VirtualizingWrapPanel Margin="16"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        ItemWidth="196"
                                                        ItemHeight="292"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerTheme>
                    <ControlTheme TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="VerticalContentAlignment" Value="Top"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </ControlTheme>
                </ListBox.ItemContainerTheme>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="180"
                                MinHeight="276"
                                Margin="8"
                                Padding="10"
                                Background="{DynamicResource AppSurfaceBrush}"
                                CornerRadius="0,20,0,20">
                            <StackPanel>
                                <Border Width="160"
                                        Height="160"
                                        Background="#E4E4F0"
                                        CornerRadius="6">
                                    <Border.ContextMenu>
                                        <ContextMenu Opening="AlbumArtworkContextMenu_OnOpened">
                                            <MenuItem Header="{DynamicResource L_DeleteCover}"
                                                      Tag="{Binding}"
                                                      Click="DeleteCoverMenuItem_OnClick"/>
                                            <MenuItem Header="{DynamicResource L_ReassignCover}"
                                                      Tag="{Binding}"
                                                      Click="ReassignCoverMenuItem_OnClick"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Image Source="{Binding Artwork}"
                                               Stretch="UniformToFill"/>
                                        <StackPanel IsVisible="{Binding Artwork, Converter={x:Static conv:ObjectConverters.IsNull}}"
                                                    Width="140"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{DynamicResource L_CoverNotFound}"
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,8"/>
                                            <Button Content="{DynamicResource L_SearchCover}"
                                                    Tag="{Binding}"
                                                    Width="110"
                                                    Height="28"
                                                    HorizontalAlignment="Center"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    Padding="0"
                                                    Background="#6C63FF"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Click="SearchCoverButton_OnClick"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Button Content="{Binding Title}"
                                        Tag="{Binding}"
                                        Margin="0,10,0,0"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Theme="{StaticResource EntityLinkButtonTheme}"
                                        Click="AlbumLinkButton_OnClick"/>
                                <Button Content="{Binding Artist}"
                                        Tag="{Binding}"
                                        Margin="0,3,0,0"
                                        FontSize="11"
                                        Foreground="{DynamicResource AppSecondaryTextBrush}"
                                        Theme="{StaticResource EntityLinkButtonTheme}"
                                        Click="ArtistLinkButton_OnClick"/>
                                <TextBlock Text="{Binding Year}"
                                           Margin="0,3,0,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource AppMutedTextBrush}"/>
                                <Button Content="{Binding FavoriteGlyph}"
                                        Tag="{Binding}"
                                        Width="28"
                                        Height="24"
                                        MinWidth="0"
                                        MinHeight="0"
                                        Margin="0,2,0,0"
                                        Padding="0"
                                        HorizontalAlignment="Left"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#6C63FF"
                                        FontSize="15"
                                        Cursor="Hand"
                                        Click="FavoriteButton_OnClick"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Artist artwork view -->
            <ListBox x:Name="ArtistArtworkListBox"
                     Grid.Row="2"
                     IsVisible="False"
                     Background="{DynamicResource AppContentBrush}"
                     BorderThickness="0"
                     DoubleTapped="ArtistArtworkListBox_OnMouseDoubleClick">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <controls:VirtualizingWrapPanel Margin="16"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        ItemWidth="216"
                                                        ItemHeight="260"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerTheme>
                    <ControlTheme TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Left"/>
                        <Setter Property="VerticalContentAlignment" Value="Top"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </ControlTheme>
                </ListBox.ItemContainerTheme>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200"
                                Margin="8"
                                Padding="10"
                                Background="{DynamicResource AppSurfaceBrush}"
                                CornerRadius="0,20,0,20">
                            <Grid>
                                <StackPanel>
                                    <Border Width="180"
                                            Height="180"
                                            Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                            CornerRadius="90"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding Artwork}"
                                                   Stretch="UniformToFill"/>
                                            <TextBlock Text="♪"
                                                       FontSize="42"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       IsVisible="{Binding Artwork, Converter={x:Static conv:ObjectConverters.IsNull}}"/>
                                        </Grid>
                                    </Border>
                                    <Button Content="{Binding Title}"
                                            Tag="{Binding}"
                                            Margin="0,10,0,0"
                                            FontSize="12"
                                            FontWeight="SemiBold"
                                            HorizontalContentAlignment="Center"
                                            Theme="{StaticResource EntityLinkButtonTheme}"
                                            Click="ArtistLinkButton_OnClick"/>
                                    <Button Content="{Binding FavoriteGlyph}"
                                            Tag="{Binding}"
                                            Margin="0,6,0,0"
                                            HorizontalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="#6C63FF"
                                            FontSize="15"
                                            Cursor="Hand"
                                            Click="FavoriteButton_OnClick"/>
                                </StackPanel>
                                <!-- Info button overlay top-left -->
                                <Button Content="ℹ"
                                        Tag="{Binding}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="2,2,0,0"
                                        Padding="4,2"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#6C63FF"
                                        FontSize="13"
                                        Cursor="Hand"
                                        Click="ArtistInfoListButton_OnClick"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border x:Name="AlphabetIndexBorder"
                    Grid.Row="2"
                    Width="30"
                    Margin="0,0,8,0"
                    HorizontalAlignment="Right"
                    IsVisible="False"
                    Background="{DynamicResource AppContentBrush}"
                    BorderBrush="{DynamicResource AppGridLineBrush}"
                    BorderThickness="1,0,0,0"
                    PointerPressed="AlphabetIndexBorder_OnPreviewMouseLeftButtonDown"
                    PointerReleased="AlphabetIndexBorder_OnPreviewMouseLeftButtonUp"
                    PointerMoved="AlphabetIndexBorder_OnPreviewMouseMove"
                    ZIndex="10">
                <UniformGrid x:Name="AlphabetIndexPanel"
                             Rows="27"
                             Columns="1"
                             Margin="0,4"/>
            </Border>

            <!-- Lyrics view -->
            <Grid x:Name="LyricsView"
                  Grid.Row="1"
                  Grid.RowSpan="2"
                  IsVisible="False"
                  Background="{DynamicResource AppContentBrush}"
                  ZIndex="20"
                  ClipToBounds="True">
                <Image x:Name="LyricsBackgroundImage"
                       Stretch="Uniform"
                       Opacity="0.22"/>
                <Border Background="#B018192E"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="28,22,28,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource L_Lyrics}"
                                   VerticalAlignment="Center"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                        <Button Grid.Column="1"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                Theme="{StaticResource HeaderFilterButtonTheme}"
                                Content="{DynamicResource L_SearchLyrics}"
                                Click="SearchLyricsButton_OnClick"/>
                        <Button x:Name="RefreshLyricsButton"
                                Grid.Column="2"
                                Theme="{StaticResource TransportBtnTheme}"
                                Margin="0,0,8,0"
                                ToolTip.Tip="{DynamicResource L_RefreshLyrics}"
                                Click="RefreshLyricsButton_OnClick">
                            <TextBlock Text="↻" FontSize="18"/>
                        </Button>
                        <Button Grid.Column="3"
                                Theme="{StaticResource TransportBtnTheme}"
                                ToolTip.Tip="{DynamicResource L_CloseLyrics}"
                                Click="CloseLyricsButton_OnClick">
                            <TextBlock Text="×" FontSize="20"/>
                        </Button>
                    </Grid>
                    <Grid Grid.Row="1">
                        <ListBox x:Name="LyricsListBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="80,26,80,60"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerTheme>
                                <ControlTheme TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#B8B8D0"/>
                                    <Setter Property="FontSize" Value="24"/>
                                    <Setter Property="FontWeight" Value="Medium"/>
                                    <Setter Property="Opacity" Value="0.78"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,5"/>
                                    <Style Selector="^:selected">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontSize" Value="30"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Opacity" Value="1"/>
                                    </Style>
                                </ControlTheme>
                            </ListBox.ItemContainerTheme>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Text}"
                                               Padding="16,10"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                               Opacity="{Binding Opacity, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                               FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                               FontWeight="{Binding FontWeight, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock x:Name="LyricsStatusTextBlock"
                                   Margin="60"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="White"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Podcast info view -->
            <Grid x:Name="PodcastInfoView"
                  Grid.Row="1"
                  Grid.RowSpan="2"
                  IsVisible="False"
                  Background="{DynamicResource AppContentBrush}"
                  ZIndex="21">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="60,30,60,50">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBlock Text="{DynamicResource L_PodcastInfo}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                            <Button HorizontalAlignment="Right"
                                    Theme="{StaticResource TransportBtnTheme}"
                                    ToolTip.Tip="{DynamicResource L_ClosePodcastInfo}"
                                    Click="ClosePodcastInfoButton_OnClick">
                                <TextBlock Text="×" FontSize="20"/>
                            </Button>
                        </Grid>
                        <Border Grid.Row="1"
                                Width="300"
                                Height="300"
                                Margin="0,28,0,22"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                CornerRadius="12"
                                ClipToBounds="True">
                            <Grid>
                                <Image x:Name="PodcastInfoImage"
                                       Stretch="UniformToFill"/>
                                <TextBlock x:Name="PodcastInfoImagePlaceholder"
                                           Text="◍"
                                           FontSize="72"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppMutedTextBrush}"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="PodcastInfoPodcastName"
                                   Grid.Row="2"
                                   MaxWidth="900"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                        <TextBlock x:Name="PodcastInfoEpisodeTitle"
                                   Grid.Row="3"
                                   MaxWidth="900"
                                   Margin="0,12,0,0"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   Foreground="#6C63FF"/>
                        <TextBlock x:Name="PodcastInfoMetadata"
                                   Grid.Row="4"
                                   Margin="0,10,0,24"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="{DynamicResource AppMutedTextBrush}"/>
                        <TextBlock x:Name="PodcastInfoDescription"
                                   Grid.Row="5"
                                   MaxWidth="900"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   FontSize="18"
                                   LineHeight="28"
                                   Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- Artist info view -->
            <Grid x:Name="ArtistInfoView"
                  Grid.Row="1"
                  Grid.RowSpan="2"
                  IsVisible="False"
                  Background="{DynamicResource AppContentBrush}"
                  ZIndex="21">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="60,30,60,50">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ArtistInfoTitleButton"
                                    FontSize="28"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center"
                                    Theme="{StaticResource EntityLinkButtonTheme}"
                                    Click="ArtistInfoTitleButton_OnClick"/>
                            <Button x:Name="EditArtistNameButton"
                                    Grid.Column="1"
                                    Margin="0,0,8,0"
                                    Padding="12,6"
                                    Theme="{StaticResource HeaderFilterButtonTheme}"
                                    Content="{DynamicResource L_EditArtistName}"
                                    Click="EditArtistNameButton_OnClick"/>
                            <Button x:Name="SearchArtistImageButton"
                                    Grid.Column="2"
                                    Margin="0,0,8,0"
                                    Padding="12,6"
                                    Theme="{StaticResource HeaderFilterButtonTheme}"
                                    Content="{DynamicResource L_SearchArtistImage}"
                                    Click="SearchArtistImageButton_OnClick"/>
                            <Button x:Name="RefreshArtistInfoButton"
                                    Grid.Column="3"
                                    Theme="{StaticResource TransportBtnTheme}"
                                    Margin="0,0,8,0"
                                    ToolTip.Tip="{DynamicResource L_RefreshArtistInfo}"
                                    Click="RefreshArtistInfoButton_OnClick">
                                <TextBlock Text="↻" FontSize="18"/>
                            </Button>
                            <Button Grid.Column="4"
                                    Theme="{StaticResource TransportBtnTheme}"
                                    ToolTip.Tip="{DynamicResource L_CloseArtistInfo}"
                                    Click="CloseArtistInfoButton_OnClick">
                                <TextBlock Text="×" FontSize="20"/>
                            </Button>
                        </Grid>
                        <Border Grid.Row="1"
                                Width="360"
                                Height="360"
                                Margin="0,28,0,28"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                CornerRadius="12"
                                ClipToBounds="True">
                            <Grid>
                                <Image x:Name="ArtistInfoImage"
                                       Stretch="Uniform"/>
                                <StackPanel x:Name="ArtistInfoImagePlaceholder"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="♪"
                                               FontSize="72"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource AppMutedTextBrush}"/>
                                    <TextBlock x:Name="ArtistInfoImageStatusText"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               MaxWidth="300"
                                               Margin="0,8,0,0"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               IsVisible="False"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="ArtistInfoBiographyTextBlock"
                                   Grid.Row="2"
                                   MaxWidth="900"
                                   FontSize="20"
                                   LineHeight="31"
                                   TextWrapping="Wrap"
                                   TextAlignment="Left"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                        <Button x:Name="ArtistInfoSourceButton"
                                Grid.Row="3"
                                Margin="0,26,0,0"
                                Padding="14,7"
                                HorizontalAlignment="Center"
                                IsVisible="False"
                                Theme="{StaticResource HeaderFilterButtonTheme}"
                                Content="{DynamicResource L_ArtistInfoSource}"
                                Click="ArtistInfoSourceButton_OnClick"/>
                    </Grid>
                </ScrollViewer>
                <TextBlock x:Name="ArtistInfoStatusTextBlock"
                           Margin="60"
                           FontSize="22"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppPrimaryTextBrush}"/>
            </Grid>

            <ContentControl x:Name="SettingsViewHost"
                            Grid.Row="0"
                            Grid.RowSpan="3"
                            IsVisible="False"
                            Background="{DynamicResource AppContentBrush}"
                            ZIndex="100"/>
        </Grid>

        <!-- ═══ TRANSPORT BAR ═══ -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                Background="{DynamicResource AppTransportBrush}"
                BorderThickness="0,1,0,0" BorderBrush="{DynamicResource AppTransportBorderBrush}"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Now playing -->
                <Grid VerticalAlignment="Center" Margin="0,0,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="68"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="58" Height="58" Background="{DynamicResource AppArtworkPlaceholderBrush}" CornerRadius="6">
                        <Image x:Name="NowPlayingArtworkImage" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="NowPlayingTitleBlock"
                                   Foreground="{DynamicResource AppTransportPrimaryTextBrush}" FontSize="13" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <Button x:Name="NowPlayingArtistButton"
                                Content="{Binding Text, ElementName=NowPlayingArtistBlock}"
                                Foreground="{DynamicResource AppSecondaryTextBrush}"
                                FontSize="11"
                                Margin="0,2,0,0"
                                IsEnabled="False"
                                Theme="{StaticResource EntityLinkButtonTheme}"
                                Click="NowPlayingArtistButton_OnClick"/>
                        <TextBlock x:Name="NowPlayingArtistBlock" IsVisible="False"/>
                        <TextBlock x:Name="FileInfoTextBlock"
                                   Foreground="{DynamicResource AppMutedTextBrush}" FontSize="10" Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>

                <!-- Controls -->
                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid x:Name="TransportControlsHeaderGrid"
                          Margin="0,0,0,10"
                          Loaded="TransportControlsHeaderGrid_OnLayoutChanged"
                          SizeChanged="TransportControlsHeaderGrid_OnSizeChanged">
                        <StackPanel x:Name="PlaybackControlsPanel"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <StackPanel.RenderTransform>
                                <TranslateTransform/>
                            </StackPanel.RenderTransform>
                            <Button x:Name="PreviousButton"
                                    Theme="{StaticResource TransportBtnTheme}"
                                    Margin="0,0,6,0" IsEnabled="False"
                                    Click="PreviousButton_OnClick">
                                <Grid Width="16"
                                      Height="16"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                                    <Rectangle Width="2" Height="12"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center"
                                               Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <Path Data="M 14 2 L 8 8 L 14 14 Z M 8 2 L 2 8 L 8 14 Z"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Grid>
                            </Button>
                            <Button x:Name="PlayButton"
                                    Theme="{StaticResource PlayBtnTheme}"
                                    Margin="6,0"
                                    Click="PlayButton_OnClick">
                                <Canvas Width="20"
                                        Height="20"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                    <Path x:Name="PlayPauseIcon"
                                          Data="M 8 4 L 17 10 L 8 16 Z"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Canvas>
                            </Button>
                            <Button x:Name="NextButton"
                                    Theme="{StaticResource TransportBtnTheme}"
                                    Margin="6,0,0,0" IsEnabled="False"
                                    Click="NextButton_OnClick">
                                <Grid Width="16"
                                      Height="16"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center">
                                    <Path Data="M 2 2 L 8 8 L 2 14 Z M 8 2 L 14 8 L 8 14 Z"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    <Rectangle Width="2" Height="12"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Grid>
                            </Button>
                        </StackPanel>
                        <StackPanel x:Name="TransportActionPanel"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Left">
                            <Button x:Name="ArtistInfoButton"
                                    Theme="{StaticResource TransportBtnTheme}"
                                    Margin="6,0,0,0"
                                    IsEnabled="False"
                                    ToolTip.Tip="{DynamicResource L_ShowArtistInfo}"
                                    Click="ArtistInfoButton_OnClick">
                                <TextBlock Text="i"
                                           FontFamily="Segoe UI"
                                           FontStyle="Italic"
                                           FontWeight="Bold"
                                           FontSize="15"/>
                            </Button>
                            <Button x:Name="LyricsButton"
                                    Theme="{StaticResource TransportBtnTheme}"
                                    Margin="6,0,0,0"
                                    IsEnabled="False"
                                    ToolTip.Tip="{DynamicResource L_ShowLyrics}"
                                    Click="LyricsButton_OnClick">
                                <TextBlock Text="♪" FontSize="16"/>
                            </Button>
                            <Button x:Name="NowPlayingFavoriteButton"
                                    Theme="{StaticResource TransportBtnTheme}"
                                    Margin="6,0,0,0"
                                    IsEnabled="False"
                                    ToolTip.Tip="{DynamicResource L_MarkAsFavorite}"
                                    Click="NowPlayingFavoriteButton_OnClick">
                                <TextBlock x:Name="NowPlayingFavoriteGlyph"
                                           Text="♡"
                                           FontSize="16"/>
                            </Button>
                            <Button x:Name="ShuffleButton"
                                    Theme="{StaticResource TransportBtnTheme}"
                                    Margin="6,0,0,0"
                                    ToolTip.Tip="{DynamicResource L_Shuffle}"
                                    Click="ShuffleButton_OnClick">
                                <Viewbox Width="17" Height="17">
                                    <Canvas Width="18" Height="18">
                                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.8"
                                              StrokeLineCap="Round"
                                              Data="M 2 4 H 5 C 9 4 9 14 13 14 H 15"/>
                                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.8"
                                              StrokeLineCap="Round"
                                              Data="M 2 14 H 5 C 9 14 9 4 13 4 H 15"/>
                                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Data="M 14 1 L 18 4 L 14 7 Z M 14 11 L 18 14 L 14 17 Z"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="42"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CurrentTimeTextBlock"
                                   Foreground="#6666AA" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Margin="0,0,8,0" Text="0:00"/>
                        <Slider x:Name="PositionSlider"
                                Grid.Column="1"
                                Theme="{StaticResource DarkSliderTheme}"
                                Height="30"
                                Minimum="0" Maximum="1" IsEnabled="False"
                                ValueChanged="PositionSlider_OnValueChanged"/>
                        <TextBlock x:Name="DurationTextBlock"
                                   Grid.Column="2"
                                   Foreground="#6666AA" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Left"
                                   Margin="8,0,0,0" Text="0:00"/>
                    </Grid>
                </Grid>

                <!-- EQ Picker Popup -->
                <Popup x:Name="EqPickerPopup"
                       Grid.Column="2"
                       PlacementTarget="{Binding ElementName=EqPickerButton}"
                       Placement="Top"
                       IsLightDismissEnabled="True">
                    <Border Margin="0,0,0,8"
                            Width="300"
                            Padding="14,12"
                            CornerRadius="10"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppInputBorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="EqPickerComboBox"
                                          Height="30"
                                          HorizontalAlignment="Stretch"
                                          DisplayMemberBinding="{Binding Name}"
                                          SelectionChanged="EqPickerComboBox_OnSelectionChanged"/>
                                <Button Grid.Column="1"
                                        Width="34" Height="30"
                                        Margin="8,0,0,0"
                                        Theme="{StaticResource TransportBtnTheme}"
                                        ToolTip.Tip="{DynamicResource L_Settings}"
                                        Click="EqPickerSettingsButton_OnClick">
                                    <TextBlock Text="⚙" FontSize="14"/>
                                </Button>
                            </Grid>
                            <CheckBox x:Name="EqPickerEnabledCheckBox"
                                      Margin="2,10,0,0"
                                      Theme="{StaticResource PopupCheckBoxTheme}"
                                      Content="{DynamicResource L_EqualizerEnabled}"
                                      IsCheckedChanged="EqPickerEnabledCheckBox_OnIsCheckedChanged"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <!-- Output Picker Popup -->
                <Popup x:Name="OutputPickerPopup"
                       Grid.Column="2"
                       PlacementTarget="{Binding ElementName=OutputPickerButton}"
                       Placement="Top"
                       IsLightDismissEnabled="True">
                    <Border Margin="0,0,0,8"
                            Width="300"
                            Padding="14,12"
                            CornerRadius="10"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppInputBorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="OutputPickerComboBox"
                                      Height="30"
                                      HorizontalAlignment="Stretch"
                                      DisplayMemberBinding="{Binding Name}"
                                      SelectionChanged="OutputPickerComboBox_OnSelectionChanged"/>
                            <Button Grid.Column="1"
                                    Width="34" Height="30"
                                    Margin="8,0,0,0"
                                    Theme="{StaticResource TransportBtnTheme}"
                                    ToolTip.Tip="{DynamicResource L_Settings}"
                                    Click="OutputPickerSettingsButton_OnClick">
                                <TextBlock Text="⚙" FontSize="14"/>
                            </Button>
                        </Grid>
                    </Border>
                </Popup>

                <!-- Volume + quick-pick buttons stacked vertically (right column) -->
                <StackPanel Grid.Column="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔊" Foreground="#6666AA" FontSize="13"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <Slider x:Name="VolumeSlider"
                                Theme="{StaticResource DarkSliderTheme}"
                                Width="100" Minimum="0" Maximum="1" Value="1"
                                VerticalAlignment="Center"
                                ValueChanged="VolumeSlider_OnValueChanged"/>
                        <TextBlock x:Name="VolumeValueTextBlock"
                                   Foreground="#6666AA" FontSize="11" Width="44"
                                   VerticalAlignment="Center" Margin="10,0,0,0"
                                   Text="100 %"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,6,0,0">
                        <Button x:Name="EqPickerButton"
                                Theme="{StaticResource TransportBtnTheme}"
                                ToolTip.Tip="{DynamicResource L_Equalizer}"
                                Click="EqPickerButton_OnClick">
                            <Viewbox Width="17" Height="17">
                                <Canvas Width="24" Height="24">
                                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.8"
                                          StrokeLineCap="Round"
                                          Data="M6,4 L6,20 M12,4 L12,20 M18,4 L18,20 M3,9 L9,9 M9,14 L15,14 M15,17 L21,17"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button x:Name="OutputPickerButton"
                                Theme="{StaticResource TransportBtnTheme}"
                                Margin="4,0,0,0"
                                ToolTip.Tip="{DynamicResource L_OutputDevice}"
                                Click="OutputPickerButton_OnClick">
                            <Viewbox Width="17" Height="17">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          Data="M4,9 L4,15 L8,15 L13,19 L13,5 L8,9 Z"/>
                                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.8"
                                          StrokeLineCap="Round"
                                          Fill="Transparent"
                                          Data="M16,9 Q19,12 16,15 M19,6 Q23,12 19,18"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
