<Window x:Class="Orynivo.StartupWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orynivo"
        Icon="avares://Orynivo/Assets/Orynivo.ico"
        Width="420"
        Height="340"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        ShowInTaskbar="False"
        Background="#13142A">
    <Border Padding="28" CornerRadius="12" Background="#13142A">
        <StackPanel VerticalAlignment="Center">
            <Image HorizontalAlignment="Stretch"
                   Source="{DynamicResource AppAboutLogoSource}"
                   Stretch="Uniform"/>
            <TextBlock x:Name="StatusTextBlock"
                       Margin="0,16,0,12"
                       Foreground="#CCCCEE"
                       FontSize="{DynamicResource FontSizeBody}"
                       Text="{DynamicResource L_StartupPreparingLibrary}"/>
            <ProgressBar IsIndeterminate="True"
                         Height="6"
                         Background="#252640"
                         Foreground="#6C63FF"/>
        </StackPanel>
    </Border>
</Window>
