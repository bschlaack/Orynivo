<Window x:Class="Orynivo.DailyHistoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding DialogTitle}"
        Icon="Assets/Orynivo.ico"
        Width="1040"
        Height="620"
        MinWidth="760"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppContentBrush}"
        SourceInitialized="DailyHistoryDialog_OnSourceInitialized">
    <Window.Resources>
        <Style x:Key="HistoryLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Foreground" Value="#54A0FF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding DialogTitle}"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource AppPrimaryTextBrush}"
                   Margin="0,0,0,16"/>

        <Grid Grid.Row="1">
            <TextBlock Text="{DynamicResource L_DailyHistoryNoEntries}"
                       Visibility="{Binding EmptyVisibility}"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <DataGrid ItemsSource="{Binding Rows}"
                      Visibility="{Binding GridVisibility}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeaderWidth="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{DynamicResource L_PlayedAt}"
                                        Binding="{Binding PlayedAt}"
                                        Width="90"/>
                    <DataGridTextColumn Header="{DynamicResource L_MediaType}"
                                        Binding="{Binding MediaType}"
                                        Width="90"/>
                    <DataGridTemplateColumn Header="{DynamicResource L_Title}" Width="2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Title}"
                                        IsEnabled="{Binding CanOpenTrack}"
                                        Style="{StaticResource HistoryLinkButtonStyle}"
                                        Click="TrackButton_OnClick"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="{DynamicResource L_Artist}" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Artist}"
                                        IsEnabled="{Binding CanOpenArtist}"
                                        Style="{StaticResource HistoryLinkButtonStyle}"
                                        Click="ArtistButton_OnClick"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="{DynamicResource L_Album}" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Album}"
                                        IsEnabled="{Binding CanOpenAlbum}"
                                        Style="{StaticResource HistoryLinkButtonStyle}"
                                        Click="AlbumButton_OnClick"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{DynamicResource L_ListenedDuration}"
                                        Binding="{Binding ListenedDuration}"
                                        Width="100"/>
                    <DataGridTextColumn Header="{DynamicResource L_Duration}"
                                        Binding="{Binding TotalDuration}"
                                        Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <Button Grid.Row="2"
                Content="{DynamicResource L_Close}"
                Width="100"
                Height="34"
                Margin="0,16,0,0"
                HorizontalAlignment="Right"
                IsCancel="True"
                Background="{DynamicResource AppButtonBrush}"
                Foreground="{DynamicResource AppButtonTextBrush}"
                BorderBrush="{DynamicResource AppButtonBorderBrush}"
                Click="CloseButton_OnClick"/>
    </Grid>
</Window>
