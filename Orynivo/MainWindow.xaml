<Window x:Class="Orynivo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Orynivo.Controls"
        Title="Orynivo" Icon="Assets/Orynivo.ico" Height="760" Width="1100"
        WindowState="Maximized"
        MinHeight="600" MinWidth="800">
    <Window.Resources>

        <!-- Sidebar nav item -->
        <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource AppNavTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="MaxWidth" Value="220"/>
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent"
                                Padding="21,8,12,8"
                                ClipToBounds="True">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppNavSelectedBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6C63FF" />
                                <Setter Property="Foreground" Value="{DynamicResource AppNavSelectedTextBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppNavHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AppNavHoverTextBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavSectionHeaderStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="MaxWidth" Value="220"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="24,12,14,5"
                                ClipToBounds="True">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppNavHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AppNavHoverTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavItemTextStyle" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="MaxWidth" Value="170"/>
        </Style>

        <!-- Transport secondary button -->
        <Style x:Key="TransportBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#252640" />
            <Setter Property="Foreground" Value="#CCCCEE" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#343654"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#20213A"/>
                                <Setter Property="Foreground" Value="#3A3A55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Transport primary button (play/pause) -->
        <Style x:Key="PlayBtnStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#6C63FF" CornerRadius="22">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7B73FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2B45"/>
                                <Setter Property="Foreground" Value="#3A3A55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Settings button -->
        <Style x:Key="SidebarBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AppNavTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="24,14">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppNavHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AppNavHoverTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Back navigation button -->
        <Style x:Key="HeaderIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#DDDDF5"/>
            <Setter Property="Foreground" Value="#4B4B78"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D1D1F0"/>
                                <Setter Property="Foreground" Value="#13142A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C5C5EA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Header filter button -->
        <Style x:Key="HeaderFilterButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppButtonBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppButtonTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.38"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TrackFilterExpanderStyle" TargetType="Expander">
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton x:Name="HeaderSite"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{DynamicResource AppButtonBrush}"
                                          Foreground="{DynamicResource AppButtonTextBrush}"
                                          BorderBrush="{DynamicResource AppButtonBorderBrush}"
                                          BorderThickness="1"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8"
                                                Padding="10,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="Arrow"
                                                      Width="10"
                                                      Height="10"
                                                      Margin="0,0,10,0"
                                                      VerticalAlignment="Center"
                                                      Data="M 1 3 L 5 7 L 9 3"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                                      StrokeThickness="1.8"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"/>
                                                <ContentPresenter Grid.Column="1"
                                                                  Content="{Binding Header, RelativeSource={RelativeSource AncestorType=Expander}}"
                                                                  VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppButtonHoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppButtonPressedBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="Data" Value="M 1 7 L 5 3 L 9 7"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite"
                                              Margin="10,6,0,0"
                                              Visibility="Collapsed"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark slider (transport bar) -->
        <Style x:Key="DarkSliderStyle" TargetType="Slider">
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center"
                              Background="Transparent"
                              ClipToBounds="False">
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" VerticalAlignment="Center"
                                                        Background="#6C63FF" CornerRadius="1.5"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="El" Width="14" Height="14" Fill="White"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="El" Property="Fill" Value="#DDDDFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" VerticalAlignment="Center"
                                                        Background="#2E2F4A" CornerRadius="1.5"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid column header -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource AppContentBrush}"/>
            <Setter Property="RowBackground" Value="{DynamicResource AppContentBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppGridLineBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="ScrollViewer.Background" Value="{DynamicResource AppContentBrush}"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource AppColumnHeaderBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppGridLineBrush}"/>
            <Setter Property="SeparatorBrush" Value="{DynamicResource AppGridLineBrush}"/>
        </Style>

        <!-- DataGrid row -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSurfaceSelectedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TreeView item -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
            <Setter Property="Padding"    Value="4,5"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSurfaceSelectedBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid cell -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Theme ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="16"/>
            <Setter Property="MinWidth" Value="16"/>
            <Setter Property="Background" Value="{DynamicResource AppScrollbarTrackBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="18"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="18"/>
                            </Grid.RowDefinitions>
                            <RepeatButton Grid.Row="0"
                                          Command="{x:Static ScrollBar.LineUpCommand}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False">
                                <Path Width="7"
                                      Height="4"
                                      Data="M 0 4 L 3.5 0 L 7 4"
                                      Stroke="{DynamicResource AppScrollbarThumbBrush}"
                                      StrokeThickness="1.5"
                                      StrokeLineJoin="Round"/>
                            </RepeatButton>
                            <Track x:Name="PART_Track"
                                   Grid.Row="1"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb MinHeight="42">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="Bd"
                                                        Margin="2"
                                                        Background="{DynamicResource AppScrollbarThumbBrush}"
                                                        CornerRadius="5"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppScrollbarThumbHoverBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                            <RepeatButton Grid.Row="2"
                                          Command="{x:Static ScrollBar.LineDownCommand}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False">
                                <Path Width="7"
                                      Height="4"
                                      Data="M 0 0 L 3.5 4 L 7 0"
                                      Stroke="{DynamicResource AppScrollbarThumbBrush}"
                                      StrokeThickness="1.5"
                                      StrokeLineJoin="Round"/>
                            </RepeatButton>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AlphabetIndexButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Margin="3,1"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppNavHoverBrush}"/>
                                <Setter Property="Foreground" Value="#6C63FF"/>
                            </Trigger>
                            <Trigger Property="IsDefault" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#6C63FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}"/>
                                <Setter Property="Opacity" Value="0.3"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EntityLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="Text"
                                   Text="{TemplateBinding Content}"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                   TextTrimming="CharacterEllipsis"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Text" Property="Foreground" Value="#6C63FF"/>
                                <Setter TargetName="Text" Property="TextDecorations" Value="Underline"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Segmentierter Ansichtsumschalter -->
        <Style x:Key="ViewModeRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#666688"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="18,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#6C63FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#DDDDF5"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ SIDEBAR ═══ -->
        <Grid Grid.Column="0" Grid.Row="0" Background="{DynamicResource AppSidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- App title -->
            <Border Padding="18,16,18,14" BorderThickness="0,0,0,1" BorderBrush="#1E1F38">
                <StackPanel>
                    <Border Padding="9,7"
                            CornerRadius="0,18,0,18">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="#7268A7" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Image Height="38"
                               Source="Assets/Orynivo_Logo.png"
                               Stretch="Uniform"/>
                    </Border>
                    <TextBlock x:Name="SelectedDriverTextBlock"
                               Foreground="#7777AA" FontSize="10" Margin="4,8,4,0"
                               Text="{DynamicResource L_NoDeviceSelected}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <!-- Nav -->
            <ListBox x:Name="NavListBox"
                     Grid.Row="1"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0,8,0,8"
                     FontSize="13"
                     ClipToBounds="True"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     SelectionChanged="NavListBox_OnSelectionChanged"
                     PreviewMouseLeftButtonDown="NavListBox_OnPreviewMouseLeftButtonDown"
                     PreviewMouseLeftButtonUp="NavListBox_OnPreviewMouseLeftButtonUp"
                     PreviewMouseRightButtonDown="NavListBox_OnPreviewMouseRightButtonDown">

                <ListBoxItem Tag="Dashboard" Style="{StaticResource NavItemStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⊞" Width="18" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource L_Dashboard}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>

                <ListBoxItem Tag="InternetRadio" Style="{StaticResource NavItemStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="◉" Width="18" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource L_InternetRadio}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>

                <ListBoxItem Tag="Podcasts" Style="{StaticResource NavItemStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="◍" Width="18" FontSize="13" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource L_Podcasts}" VerticalAlignment="Center"/>
                    </StackPanel>
                </ListBoxItem>

                <ListBoxItem x:Name="LocalLibraryHeaderItem"
                             Tag="Section:LocalLibrary"
                             FontSize="10"
                             FontWeight="Bold"
                             Style="{StaticResource NavSectionHeaderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource L_LocalLibrary}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Path x:Name="LocalLibraryHeaderArrow"
                              Grid.Column="1"
                              Width="8"
                              Height="5"
                              Data="M 0 0 L 4 5 L 8 0"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                              StrokeThickness="1.4"
                              RenderTransformOrigin="0.5,0.5"/>
                    </Grid>
                </ListBoxItem>
                <ListBoxItem x:Name="ArtistsNavItem" Tag="Artists" Style="{StaticResource NavItemStyle}"><TextBlock Text="{DynamicResource L_Artists}" Style="{StaticResource NavItemTextStyle}"/></ListBoxItem>
                <ListBoxItem x:Name="AlbumsNavItem" Tag="Albums" Style="{StaticResource NavItemStyle}"><TextBlock Text="{DynamicResource L_Albums}" Style="{StaticResource NavItemTextStyle}"/></ListBoxItem>
                <ListBoxItem x:Name="TracksNavItem" Tag="Tracks" Style="{StaticResource NavItemStyle}"><TextBlock Text="{DynamicResource L_Tracks}" Style="{StaticResource NavItemTextStyle}"/></ListBoxItem>
                <ListBoxItem x:Name="FoldersNavItem" Tag="Folders" Style="{StaticResource NavItemStyle}"><TextBlock Text="{DynamicResource L_FolderStructure}" Style="{StaticResource NavItemTextStyle}"/></ListBoxItem>

                <ListBoxItem x:Name="OwnRadiosHeaderItem"
                             Tag="Section:OwnRadios"
                             FontSize="10"
                             FontWeight="Bold"
                             Style="{StaticResource NavSectionHeaderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource L_OwnRadios}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Path x:Name="OwnRadiosHeaderArrow"
                              Grid.Column="1"
                              Width="8"
                              Height="5"
                              Data="M 0 0 L 4 5 L 8 0"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                              StrokeThickness="1.4"
                              RenderTransformOrigin="0.5,0.5"/>
                    </Grid>
                </ListBoxItem>

                <ListBoxItem x:Name="MyPodcastsHeaderItem"
                             Tag="Section:MyPodcasts"
                             FontSize="10"
                             FontWeight="Bold"
                             Style="{StaticResource NavSectionHeaderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource L_MyPodcasts}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Path x:Name="MyPodcastsHeaderArrow"
                              Grid.Column="1"
                              Width="8"
                              Height="5"
                              Data="M 0 0 L 4 5 L 8 0"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                              StrokeThickness="1.4"
                              RenderTransformOrigin="0.5,0.5"/>
                    </Grid>
                </ListBoxItem>

                <ListBoxItem x:Name="PlexHeaderItem"
                             Tag="Section:Plex"
                             FontSize="10"
                             FontWeight="Bold"
                             Style="{StaticResource NavSectionHeaderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource L_PlexServers}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Path x:Name="PlexHeaderArrow"
                              Grid.Column="1"
                              Width="8"
                              Height="5"
                              Data="M 0 0 L 4 5 L 8 0"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                              StrokeThickness="1.4"
                              RenderTransformOrigin="0.5,0.5"/>
                    </Grid>
                </ListBoxItem>

                <ListBoxItem x:Name="PlaylistsHeaderItem"
                             Tag="Section:Playlists"
                             FontSize="10"
                             FontWeight="Bold"
                             Style="{StaticResource NavSectionHeaderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource L_Playlists}"
                                   TextTrimming="CharacterEllipsis"/>
                        <Path x:Name="PlaylistsHeaderArrow"
                              Grid.Column="1"
                              Width="8"
                              Height="5"
                              Data="M 0 0 L 4 5 L 8 0"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                              StrokeThickness="1.4"
                              RenderTransformOrigin="0.5,0.5"/>
                    </Grid>
                </ListBoxItem>
                <!-- Eigene Radios, Podcasts und Playlist-Einträge werden per Code ergänzt. -->
            </ListBox>

            <!-- Status -->
            <TextBlock x:Name="StatusTextBlock"
                       Grid.Row="2"
                       Padding="24,8"
                       Foreground="#44445A" FontSize="10"
                       TextWrapping="Wrap"/>

            <!-- Einstellungen -->
            <Button Grid.Row="3"
                    HorizontalAlignment="Stretch"
                    FontSize="13"
                    Style="{StaticResource SidebarBtnStyle}"
                    Click="AboutButton_OnClick">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="ⓘ"
                               Width="16"
                               FontSize="17"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource L_About}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Grid.Row="4"
                    HorizontalAlignment="Stretch"
                    FontSize="13"
                    Style="{StaticResource SidebarBtnStyle}"
                    Click="SettingsButton_OnClick">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="⚙"
                               Width="16"
                               FontSize="14"
                               Margin="0,0,8,0"
                               TextAlignment="Center"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource L_Settings}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ═══ CONTENT ═══ -->
        <Grid Grid.Column="1" Grid.Row="0" Background="{DynamicResource AppContentBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Background="{DynamicResource AppHeaderBrush}"
                    BorderThickness="0,0,0,1" BorderBrush="{DynamicResource AppHeaderBorderBrush}"
                    Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BackButton"
                            Width="34"
                            Height="30"
                            Margin="0,0,12,0"
                            Visibility="Collapsed"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            Click="BackButton_OnClick"
                            ToolTip="{DynamicResource L_Back}">
                        <Path Data="M 12 6 L 6 12 L 12 18"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Width="18"
                              Height="18"
                              Stretch="Uniform"/>
                    </Button>
                    <TextBlock x:Name="ContentTitleTextBlock"
                               Grid.Column="1"
                               FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource AppPrimaryTextBrush}"
                               VerticalAlignment="Center"/>
                    <Button x:Name="TrackFilterButton"
                            Grid.Column="2"
                            Margin="14,0,0,0"
                            Padding="12,5"
                            VerticalAlignment="Center"
                            Visibility="Collapsed"
                            Style="{StaticResource HeaderFilterButtonStyle}"
                            Content="{DynamicResource L_Filter}"
                            Click="TrackFilterButton_OnClick"/>
                    <Button x:Name="SaveSmartPlaylistButton"
                            Grid.Column="3"
                            Margin="8,0,0,0"
                            Padding="12,5"
                            VerticalAlignment="Center"
                            Visibility="Collapsed"
                            IsEnabled="False"
                            Style="{StaticResource HeaderFilterButtonStyle}"
                            ToolTip="{DynamicResource L_SaveSmartPlaylistDisabledTooltip}"
                            ToolTipService.ShowOnDisabled="True"
                            Click="SaveSmartPlaylistButton_OnClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚡" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource L_SaveSmartPlaylist}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="ContentCountTextBlock"
                               Grid.Column="4"
                               Margin="14,0,0,0"
                               FontSize="12" Foreground="{DynamicResource AppMutedTextBrush}"
                               VerticalAlignment="Center"/>
                    <TextBox x:Name="SearchTextBox"
                             Grid.Column="5"
                             Width="240"
                             Height="30"
                             Margin="20,0,0,0"
                             VerticalContentAlignment="Center"
                             Background="{DynamicResource AppInputBrush}"
                             Foreground="{DynamicResource AppPrimaryTextBrush}"
                             BorderBrush="{DynamicResource AppInputBorderBrush}"
                             ToolTip="{DynamicResource L_Search}"
                             TextChanged="SearchTextBox_OnTextChanged"/>
                    <Border x:Name="AlbumViewModeBorder"
                            Grid.Column="6"
                            Margin="20,0,0,0"
                            Padding="3"
                            Background="#252640"
                            CornerRadius="9"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="AlbumTableViewRadioButton"
                                         GroupName="AlbumViewMode"
                                         Style="{StaticResource ViewModeRadioStyle}"
                                         MinWidth="88"
                                         Content="{DynamicResource L_Table}"
                                         IsChecked="True"
                                         Checked="AlbumViewModeRadioButton_OnChecked"/>
                            <RadioButton x:Name="AlbumArtworkViewRadioButton"
                                         GroupName="AlbumViewMode"
                                         Style="{StaticResource ViewModeRadioStyle}"
                                         MinWidth="88"
                                         Content="{DynamicResource L_Artwork}"
                                         Checked="AlbumViewModeRadioButton_OnChecked"/>
                        </StackPanel>
                    </Border>
                    <Border x:Name="PlexViewModeBorder"
                            Grid.Column="6"
                            Margin="20,0,0,0"
                            Padding="3"
                            Background="#252640"
                            CornerRadius="9"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="PlexArtistsViewRadioButton"
                                         GroupName="PlexViewMode"
                                         Style="{StaticResource ViewModeRadioStyle}"
                                         MinWidth="76"
                                         Content="{DynamicResource L_Artists}"
                                         IsChecked="True"
                                         Tag="Artists"
                                         Checked="PlexViewModeRadioButton_OnChecked"/>
                            <RadioButton GroupName="PlexViewMode"
                                         Style="{StaticResource ViewModeRadioStyle}"
                                         MinWidth="76"
                                         Content="{DynamicResource L_Albums}"
                                         Tag="Albums"
                                         Checked="PlexViewModeRadioButton_OnChecked"/>
                            <RadioButton GroupName="PlexViewMode"
                                         Style="{StaticResource ViewModeRadioStyle}"
                                         MinWidth="76"
                                         Content="{DynamicResource L_Tracks}"
                                         Tag="Tracks"
                                         Checked="PlexViewModeRadioButton_OnChecked"/>
                            <RadioButton GroupName="PlexViewMode"
                                         Style="{StaticResource ViewModeRadioStyle}"
                                         MinWidth="92"
                                         Content="{DynamicResource L_FolderStructure}"
                                         Tag="Folders"
                                         Checked="PlexViewModeRadioButton_OnChecked"/>
                            <Button x:Name="PlexLoadMoreButton"
                                    Margin="5,0,0,0"
                                    Padding="10,3"
                                    Visibility="Collapsed"
                                    Style="{StaticResource HeaderFilterButtonStyle}"
                                    Content="{DynamicResource L_LoadMore}"
                                    Click="PlexLoadMoreButton_OnClick"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Popup x:Name="TrackFilterPopup"
                   Grid.Row="0"
                   PlacementTarget="{Binding ElementName=TrackFilterButton}"
                   Placement="Bottom"
                   StaysOpen="False"
                   AllowsTransparency="True">
                <Border Margin="0,8,0,0"
                        Width="640"
                        MaxHeight="430"
                        Padding="14"
                        CornerRadius="10"
                        Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="{DynamicResource AppInputBorderBrush}"
                        BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="TrackFilterPanel"/>
                    </ScrollViewer>
                </Border>
            </Popup>

            <!-- Dashboard -->
            <ScrollViewer x:Name="DashboardScrollViewer"
                          Grid.Row="1"
                          Visibility="Collapsed"
                          Background="{DynamicResource AppContentBrush}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="DashboardPanel" Margin="28,24,28,28"/>
            </ScrollViewer>

            <Grid x:Name="InternetRadioView"
                  Grid.Row="1"
                  Visibility="Collapsed"
                  Background="{DynamicResource AppContentBrush}"
                  Panel.ZIndex="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border x:Name="RadioNowPlayingPanel"
                        Margin="28,24,28,14"
                        Padding="24"
                        Visibility="Collapsed"
                        Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="#6C63FF"
                        BorderThickness="1"
                        CornerRadius="0,24,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="160"
                                Height="160"
                                Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                CornerRadius="0,22,0,22"
                                ClipToBounds="True">
                            <Grid>
                                <TextBlock Text="◉"
                                           FontSize="52"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Image x:Name="RadioNowPlayingLogo"
                                       Stretch="Uniform"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Text="{DynamicResource L_RadioNowPlaying}"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Foreground="#6C63FF"/>
                            <TextBlock x:Name="RadioNowPlayingStation"
                                       Margin="0,7,0,0"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="RadioNowPlayingTitle"
                                       Margin="0,12,0,0"
                                       FontSize="21"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="RadioNowPlayingArtist"
                                       Margin="0,5,0,0"
                                       FontSize="16"
                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="RadioNowPlayingDescription"
                                       Margin="0,10,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="28,0,28,14"
                        Padding="20"
                        Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="{DynamicResource AppGridLineBrush}"
                        BorderThickness="1"
                        CornerRadius="0,20,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L_RadioDirectory}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                            <TextBlock Text="{DynamicResource L_RadioDirectoryHint}"
                                       Margin="0,7,20,0"
                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="◉"
                                   FontSize="38"
                                   Foreground="#6C63FF"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="28,0,28,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="RadioSearchTextBox"
                             Height="36"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             Background="{DynamicResource AppInputBrush}"
                             Foreground="{DynamicResource AppPrimaryTextBrush}"
                             BorderBrush="{DynamicResource AppInputBorderBrush}"
                             ToolTip="{DynamicResource L_RadioSearch}"
                             KeyDown="RadioSearchTextBox_OnKeyDown"/>
                    <Button x:Name="RadioGenreFilterButton"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            Padding="14,7"
                            Style="{StaticResource HeaderFilterButtonStyle}"
                            Content="{DynamicResource L_RadioGenres}"
                            Click="RadioGenreFilterButton_OnClick"/>
                    <Button Grid.Column="2"
                            Margin="10,0,0,0"
                            Padding="18,7"
                            Style="{StaticResource HeaderFilterButtonStyle}"
                            Content="{DynamicResource L_RadioSearch}"
                            Click="RadioSearchButton_OnClick"/>
                </Grid>

                <Popup x:Name="RadioGenreFilterPopup"
                       PlacementTarget="{Binding ElementName=RadioGenreFilterButton}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Margin="0,8,0,0"
                            Width="320"
                            MaxHeight="420"
                            Padding="14"
                            CornerRadius="10"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppInputBorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource L_RadioGenres}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppPrimaryTextBrush}"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Padding="9,4"
                                        Style="{StaticResource HeaderFilterButtonStyle}"
                                        Content="{DynamicResource L_ClearFilter}"
                                        Click="ClearRadioGenreFilterButton_OnClick"/>
                            </Grid>
                            <ScrollViewer Grid.Row="1"
                                          Margin="0,10,0,0"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel x:Name="RadioGenreFilterPanel"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Popup>

                <Grid Grid.Row="3" Margin="28,0,28,24">
                    <DataGrid x:Name="RadioStationsDataGrid"
                              Background="{DynamicResource AppContentBrush}"
                              BorderThickness="0"
                              RowHeight="54"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource AppGridLineBrush}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserResizeRows="False"
                              MouseDoubleClick="RadioStationsDataGrid_OnMouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="38"
                                                Height="38"
                                                CornerRadius="8"
                                                Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                                ClipToBounds="True">
                                            <Grid>
                                                <TextBlock Text="♪"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource AppMutedTextBrush}"/>
                                                <Image Source="{Binding Favicon}" Stretch="UniformToFill"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource L_RadioStation}"
                                                Binding="{Binding Name}"
                                                Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource L_Country}"
                                                Binding="{Binding CountryCode}"
                                                Width="90"/>
                            <DataGridTextColumn Header="{DynamicResource L_Genre}"
                                                Binding="{Binding GenreSummary}"
                                                Width="180"/>
                            <DataGridTextColumn Header="{DynamicResource L_Format}"
                                                Binding="{Binding FormatSummary}"
                                                Width="120"/>
                            <DataGridTemplateColumn Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{DynamicResource L_PlayRadio}"
                                                Tag="{Binding}"
                                                Padding="10,5"
                                                Style="{StaticResource HeaderFilterButtonStyle}"
                                                Click="PlayRadioButton_OnClick"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{DynamicResource L_AddToOwnRadios}"
                                                Tag="{Binding}"
                                                Padding="10,5"
                                                Style="{StaticResource HeaderFilterButtonStyle}"
                                                Click="AddRadioButton_OnClick"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="RadioStatusTextBlock"
                               Margin="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </Grid>
            </Grid>

            <Grid x:Name="PodcastView"
                  Grid.Row="1"
                  Visibility="Collapsed"
                  Background="{DynamicResource AppContentBrush}"
                  Panel.ZIndex="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Margin="28,24,28,14"
                        Padding="20"
                        Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="{DynamicResource AppGridLineBrush}"
                        BorderThickness="1"
                        CornerRadius="0,20,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L_PodcastDirectory}"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                            <TextBlock Text="{DynamicResource L_PodcastDirectoryHint}"
                                       Margin="0,7,20,0"
                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="◍"
                                   FontSize="38"
                                   Foreground="#6C63FF"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="28,0,28,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PodcastSearchTextBox"
                             Height="36"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             Background="{DynamicResource AppInputBrush}"
                             Foreground="{DynamicResource AppPrimaryTextBrush}"
                             BorderBrush="{DynamicResource AppInputBorderBrush}"
                             ToolTip="{DynamicResource L_PodcastSearch}"
                             KeyDown="PodcastSearchTextBox_OnKeyDown"/>
                    <Button x:Name="PodcastCategoryFilterButton"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            Padding="14,7"
                            Style="{StaticResource HeaderFilterButtonStyle}"
                            Content="{DynamicResource L_PodcastCategories}"
                            Click="PodcastCategoryFilterButton_OnClick"/>
                    <Button x:Name="PodcastLanguageFilterButton"
                            Grid.Column="2"
                            Margin="10,0,0,0"
                            Padding="14,7"
                            Style="{StaticResource HeaderFilterButtonStyle}"
                            Content="{DynamicResource L_PodcastLanguages}"
                            Click="PodcastLanguageFilterButton_OnClick"/>
                    <Button Grid.Column="3"
                            Margin="10,0,0,0"
                            Padding="18,7"
                            Style="{StaticResource HeaderFilterButtonStyle}"
                            Content="{DynamicResource L_PodcastSearch}"
                            Click="PodcastSearchButton_OnClick"/>
                </Grid>

                <Popup x:Name="PodcastCategoryFilterPopup"
                       PlacementTarget="{Binding ElementName=PodcastCategoryFilterButton}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Margin="0,8,0,0"
                            Width="320"
                            MaxHeight="420"
                            Padding="14"
                            CornerRadius="10"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppInputBorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource L_PodcastCategories}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                                <Button Grid.Column="1"
                                        Padding="9,4"
                                        Style="{StaticResource HeaderFilterButtonStyle}"
                                        Content="{DynamicResource L_ClearFilter}"
                                        Click="ClearPodcastCategoryFilterButton_OnClick"/>
                            </Grid>
                            <ScrollViewer Grid.Row="1"
                                          Margin="0,10,0,0"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="PodcastCategoryFilterPanel"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Popup>

                <Popup x:Name="PodcastLanguageFilterPopup"
                       PlacementTarget="{Binding ElementName=PodcastLanguageFilterButton}"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Margin="0,8,0,0"
                            Width="280"
                            MaxHeight="420"
                            Padding="14"
                            CornerRadius="10"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppInputBorderBrush}"
                            BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{DynamicResource L_PodcastLanguages}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                                <Button Grid.Column="1"
                                        Padding="9,4"
                                        Style="{StaticResource HeaderFilterButtonStyle}"
                                        Content="{DynamicResource L_ClearFilter}"
                                        Click="ClearPodcastLanguageFilterButton_OnClick"/>
                            </Grid>
                            <ScrollViewer Grid.Row="1"
                                          Margin="0,10,0,0"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="PodcastLanguageFilterPanel"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Popup>

                <Grid Grid.Row="2" Margin="28,0,28,24">
                    <DataGrid x:Name="PodcastsDataGrid"
                              Background="{DynamicResource AppContentBrush}"
                              BorderThickness="0"
                              RowHeight="64"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource AppGridLineBrush}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              CanUserResizeRows="False"
                              MouseDoubleClick="PodcastsDataGrid_OnMouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="78">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="48"
                                                Height="48"
                                                CornerRadius="8"
                                                Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                                ClipToBounds="True">
                                            <Grid>
                                                <TextBlock Text="◍"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource AppMutedTextBrush}"/>
                                                <Image Source="{Binding ArtworkUrl}" Stretch="UniformToFill"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="{DynamicResource L_Podcast}"
                                                Binding="{Binding Name}"
                                                Width="*"/>
                            <DataGridTextColumn Header="{DynamicResource L_PodcastAuthor}"
                                                Binding="{Binding Author}"
                                                Width="220"/>
                            <DataGridTextColumn Header="{DynamicResource L_Genre}"
                                                Binding="{Binding Genre}"
                                                Width="150"/>
                            <DataGridTextColumn Header="{DynamicResource L_PodcastLanguage}"
                                                Binding="{Binding LanguageDisplay}"
                                                Width="110"/>
                            <DataGridTemplateColumn Width="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{DynamicResource L_ShowEpisodes}"
                                                Tag="{Binding}"
                                                Padding="10,5"
                                                Style="{StaticResource HeaderFilterButtonStyle}"
                                                Click="ShowPodcastEpisodesButton_OnClick"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Width="180">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{DynamicResource L_AddToMyPodcasts}"
                                                Tag="{Binding}"
                                                Padding="10,5"
                                                Style="{StaticResource HeaderFilterButtonStyle}"
                                                Click="AddPodcastButton_OnClick"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock x:Name="PodcastStatusTextBlock"
                               Margin="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </Grid>

                <Grid x:Name="PodcastEpisodesView"
                      Grid.Row="0"
                      Grid.RowSpan="3"
                      Visibility="Collapsed"
                      Background="{DynamicResource AppContentBrush}"
                      Panel.ZIndex="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Margin="28,24,28,14"
                            Padding="24"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="#6C63FF"
                            BorderThickness="1"
                            CornerRadius="0,24,0,24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="166"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="PodcastEpisodesBackButton"
                                    Padding="12,7"
                                    Margin="0,0,16,0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource HeaderFilterButtonStyle}"
                                    Content="{DynamicResource L_Back}"
                                    Click="PodcastEpisodesBackButton_OnClick"/>
                            <Border Grid.Column="1"
                                    Width="150"
                                    Height="150"
                                    Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                    CornerRadius="0,20,0,20"
                                    ClipToBounds="True">
                                <Image x:Name="PodcastEpisodesArtwork" Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="2" Margin="16,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource L_PodcastOverview}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="#6C63FF"/>
                                <TextBlock x:Name="PodcastEpisodesTitle"
                                           Margin="0,5,0,0"
                                           FontSize="28"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppPrimaryTextBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="PodcastEpisodesAuthor"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                                <TextBlock x:Name="PodcastEpisodesStatistics"
                                           Margin="0,12,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppPrimaryTextBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="PodcastEpisodesMetadata"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock x:Name="PodcastEpisodesDescription"
                                           Margin="0,10,0,0"
                                           MaxHeight="48"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="28,0,28,24">
                        <DataGrid x:Name="PodcastEpisodesDataGrid"
                                  Background="{DynamicResource AppContentBrush}"
                                  BorderThickness="0"
                                  RowHeight="54"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource AppGridLineBrush}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  CanUserResizeRows="False"
                                  MouseDoubleClick="PodcastEpisodesDataGrid_OnMouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource L_PodcastStatus}"
                                                    Binding="{Binding Status}"
                                                    Width="90"/>
                                <DataGridTextColumn Header="{DynamicResource L_Title}"
                                                    Binding="{Binding Title}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="{DynamicResource L_Published}"
                                                    Binding="{Binding Published}"
                                                    Width="120"/>
                                <DataGridTextColumn Header="{DynamicResource L_Duration}"
                                                    Binding="{Binding Duration}"
                                                    Width="90"/>
                                <DataGridTextColumn Header="{DynamicResource L_Progress}"
                                                    Binding="{Binding Progress}"
                                                    Width="130"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock x:Name="PodcastEpisodesStatusTextBlock"
                                   Margin="12"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </Grid>
                </Grid>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border x:Name="AlbumDetailHeader"
                        Grid.Row="0"
                        Visibility="Collapsed"
                        Margin="24,22,24,18"
                        Padding="22"
                        HorizontalAlignment="Center"
                        MaxWidth="920"
                        Background="{DynamicResource AppSurfaceBrush}"
                        BorderBrush="{DynamicResource AppGridLineBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240"/>
                            <ColumnDefinition Width="44"/>
                            <ColumnDefinition Width="360"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Width="240"
                                Height="240"
                                Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                CornerRadius="8"
                                ClipToBounds="True">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="{DynamicResource L_DeleteCover}"
                                              Tag="{Binding}"
                                              Click="DeleteCoverMenuItem_OnClick"/>
                                    <MenuItem Header="{DynamicResource L_ReassignCover}"
                                              Tag="{Binding}"
                                              Click="ReassignCoverMenuItem_OnClick"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid>
                                <Image Source="{Binding Artwork}" Stretch="UniformToFill"/>
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Artwork}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="{DynamicResource L_CoverNotFound}"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,10"/>
                                    <Button Content="{DynamicResource L_SearchCover}"
                                            Tag="{Binding}"
                                            Padding="14,7"
                                            Background="#6C63FF"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Click="SearchCoverButton_OnClick"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <Button Content="{Binding Title}"
                                    Tag="{Binding}"
                                    FontSize="28"
                                    FontWeight="SemiBold"
                                    Style="{StaticResource EntityLinkButtonStyle}"
                                    Click="AlbumLinkButton_OnClick"/>
                            <Button Content="{Binding Artist}"
                                    Tag="{Binding}"
                                    Margin="0,10,0,0"
                                    FontSize="17"
                                    Foreground="{DynamicResource AppSecondaryTextBrush}"
                                    Style="{StaticResource EntityLinkButtonStyle}"
                                    Click="ArtistLinkButton_OnClick"/>
                            <TextBlock Text="{Binding Year}"
                                       Margin="0,8,0,0"
                                       FontSize="14"
                                       Foreground="{DynamicResource AppMutedTextBrush}"/>
                            <Button Content="{DynamicResource L_SearchCover}"
                                    Tag="{Binding}"
                                    Margin="0,22,0,0"
                                    Padding="14,7"
                                    HorizontalAlignment="Left"
                                    Style="{StaticResource HeaderFilterButtonStyle}"
                                    Click="SearchCoverButton_OnClick"/>
                            <CheckBox x:Name="ShowAllAlbumTracksCheckBox"
                                      Margin="0,18,0,0"
                                      HorizontalAlignment="Left"
                                      Foreground="{DynamicResource AppPrimaryTextBrush}"
                                      Content="{DynamicResource L_ShowAllAlbumTracks}"
                                      Visibility="Collapsed"
                                      Checked="ShowAllAlbumTracksCheckBox_OnChanged"
                                      Unchecked="ShowAllAlbumTracksCheckBox_OnChanged"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Content DataGrid -->
                <DataGrid x:Name="ContentDataGrid"
                          Grid.Row="1"
                          Background="{DynamicResource AppContentBrush}"
                          BorderThickness="0"
                          RowHeight="38"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource AppGridLineBrush}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          FontSize="13"
                          CanUserResizeRows="False"
                          LoadingRow="ContentDataGrid_OnLoadingRow"
                          MouseDoubleClick="ContentDataGrid_OnMouseDoubleClick"
                          PreviewMouseRightButtonDown="ContentDataGrid_OnPreviewMouseRightButtonDown"/>
            </Grid>

            <ScrollViewer x:Name="SearchResultsScrollViewer"
                          Grid.Row="1"
                          Visibility="Collapsed"
                          Background="{DynamicResource AppContentBrush}"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="18">
                    <Border Background="{DynamicResource AppSurfaceBrush}"
                            CornerRadius="10"
                            Padding="14"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L_Tracks}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}"
                                       Margin="0,0,0,10"/>
                            <DataGrid x:Name="SearchTracksDataGrid"
                                      MinHeight="180"
                                      MaxHeight="280"
                                      Background="{DynamicResource AppSurfaceBrush}"
                                      BorderThickness="0"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource AppGridLineBrush}"
                                      MouseDoubleClick="SearchTracksDataGrid_OnMouseDoubleClick"
                                      PreviewMouseRightButtonDown="SearchTracksDataGrid_OnPreviewMouseRightButtonDown"/>
                            <TextBlock x:Name="SearchTracksEmptyTextBlock"
                                       Visibility="Collapsed"
                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       Margin="2,10,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource AppSurfaceBrush}"
                            CornerRadius="10"
                            Padding="14"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L_Albums}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}"
                                       Margin="0,0,0,10"/>
                            <DataGrid x:Name="SearchAlbumsDataGrid"
                                      MinHeight="160"
                                      MaxHeight="240"
                                      Background="{DynamicResource AppSurfaceBrush}"
                                      BorderThickness="0"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource AppGridLineBrush}"
                                      MouseDoubleClick="SearchAlbumsDataGrid_OnMouseDoubleClick"
                                      PreviewMouseRightButtonDown="SearchAlbumsDataGrid_OnPreviewMouseRightButtonDown"/>
                            <TextBlock x:Name="SearchAlbumsEmptyTextBlock"
                                       Visibility="Collapsed"
                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       Margin="2,10,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource AppSurfaceBrush}"
                            CornerRadius="10"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource L_Artists}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}"
                                       Margin="0,0,0,10"/>
                            <DataGrid x:Name="SearchArtistsDataGrid"
                                      MinHeight="140"
                                      MaxHeight="220"
                                      Background="{DynamicResource AppSurfaceBrush}"
                                      BorderThickness="0"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="{DynamicResource AppGridLineBrush}"
                                      MouseDoubleClick="SearchArtistsDataGrid_OnMouseDoubleClick"/>
                            <TextBlock x:Name="SearchArtistsEmptyTextBlock"
                                       Visibility="Collapsed"
                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                       Margin="2,10,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Folder TreeView (nur für Ordnerstruktur) -->
            <TreeView x:Name="FolderTreeView"
                      Grid.Row="1"
                      Background="{DynamicResource AppContentBrush}"
                      BorderThickness="0"
                      FontSize="13"
                      Visibility="Collapsed"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True"
                      MouseDoubleClick="FolderTreeView_OnMouseDoubleClick"
                      PreviewMouseRightButtonDown="FolderTreeView_OnPreviewMouseRightButtonDown"/>

            <!-- Album-Artworkansicht -->
            <ListBox x:Name="AlbumArtworkListBox"
                     Grid.Row="1"
                     Visibility="Collapsed"
                     Background="{DynamicResource AppContentBrush}"
                     BorderThickness="0"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.IsDeferredScrollingEnabled="False"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     MouseDoubleClick="AlbumArtworkListBox_OnMouseDoubleClick">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <controls:VirtualizingWrapPanel Margin="16"
                                                        ItemWidth="196"
                                                        ItemHeight="270"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <EventSetter Event="Loaded" Handler="AlbumArtworkItem_OnLoaded"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="180"
                                Margin="8"
                                Padding="10"
                                Background="{DynamicResource AppSurfaceBrush}"
                                CornerRadius="0,20,0,20">
                            <StackPanel>
                                <Border Width="160"
                                        Height="160"
                                        Background="#E4E4F0"
                                        CornerRadius="6">
                                    <Border.ContextMenu>
                                        <ContextMenu Opened="AlbumArtworkContextMenu_OnOpened">
                                            <MenuItem Header="{DynamicResource L_DeleteCover}"
                                                      Tag="{Binding}"
                                                      Click="DeleteCoverMenuItem_OnClick"/>
                                            <MenuItem Header="{DynamicResource L_ReassignCover}"
                                                      Tag="{Binding}"
                                                      Click="ReassignCoverMenuItem_OnClick"/>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <Grid>
                                        <Image Source="{Binding Artwork}"
                                               Stretch="UniformToFill"/>
                                        <StackPanel x:Name="MissingArtworkPanel"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Visibility="Collapsed">
                                            <TextBlock Text="{DynamicResource L_CoverNotFound}"
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,0,0,8"/>
                                            <Button Content="{DynamicResource L_SearchCover}"
                                                    Tag="{Binding}"
                                                    Width="110"
                                                    Height="28"
                                                    Background="#6C63FF"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    Cursor="Hand"
                                                    Click="SearchCoverButton_OnClick"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Button Content="{Binding Title}"
                                        Tag="{Binding}"
                                        Margin="0,10,0,0"
                                        FontWeight="SemiBold"
                                        Style="{StaticResource EntityLinkButtonStyle}"
                                        Click="AlbumLinkButton_OnClick"/>
                                <Button Content="{Binding Artist}"
                                        Tag="{Binding}"
                                        Margin="0,3,0,0"
                                        Foreground="{DynamicResource AppSecondaryTextBrush}"
                                        Style="{StaticResource EntityLinkButtonStyle}"
                                        Click="ArtistLinkButton_OnClick"/>
                                <TextBlock Text="{Binding Year}"
                                           Margin="0,3,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"/>
                                <Button Content="{Binding FavoriteGlyph}"
                                        Tag="{Binding}"
                                        Margin="0,6,0,0"
                                        HorizontalAlignment="Left"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#6C63FF"
                                        FontSize="16"
                                        Cursor="Hand"
                                        Click="FavoriteButton_OnClick"/>
                            </StackPanel>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding Artwork}" Value="{x:Null}">
                                <Setter TargetName="MissingArtworkPanel" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Künstler-Bildansicht -->
            <ListBox x:Name="ArtistArtworkListBox"
                     Grid.Row="1"
                     Visibility="Collapsed"
                     Background="{DynamicResource AppContentBrush}"
                     BorderThickness="0"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.IsDeferredScrollingEnabled="False"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     MouseDoubleClick="ArtistArtworkListBox_OnMouseDoubleClick">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <controls:VirtualizingWrapPanel Margin="16"
                                                        ItemWidth="216"
                                                        ItemHeight="260"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <EventSetter Event="Loaded" Handler="ArtistArtworkItem_OnLoaded"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200"
                                Margin="8"
                                Padding="10"
                                Background="{DynamicResource AppSurfaceBrush}"
                                CornerRadius="0,20,0,20">
                            <Grid>
                                <StackPanel>
                                    <Border Width="180"
                                            Height="180"
                                            Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                            CornerRadius="90"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding Artwork}"
                                                   Stretch="UniformToFill"/>
                                            <TextBlock Text="♪"
                                                       FontSize="42"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource AppMutedTextBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Artwork}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                    <Button Content="{Binding Title}"
                                            Tag="{Binding}"
                                            Margin="0,10,0,0"
                                            FontSize="15"
                                            FontWeight="SemiBold"
                                            HorizontalContentAlignment="Center"
                                            Style="{StaticResource EntityLinkButtonStyle}"
                                            Click="ArtistLinkButton_OnClick"/>
                                    <Button Content="{Binding FavoriteGlyph}"
                                            Tag="{Binding}"
                                            Margin="0,6,0,0"
                                            HorizontalAlignment="Center"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Foreground="#6C63FF"
                                            FontSize="17"
                                            Cursor="Hand"
                                            Click="FavoriteButton_OnClick"/>
                                </StackPanel>
                                <!-- Info-Button als Overlay oben links über dem Bild -->
                                <Button Content="ℹ"
                                        Tag="{Binding}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Top"
                                        Margin="2,2,0,0"
                                        Padding="4,2"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Foreground="#6C63FF"
                                        FontSize="15"
                                        Cursor="Hand"
                                        Click="ArtistInfoListButton_OnClick"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border x:Name="AlphabetIndexBorder"
                    Grid.Row="1"
                    Width="34"
                    Margin="0,0,16,0"
                    HorizontalAlignment="Right"
                    Visibility="Collapsed"
                    Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppGridLineBrush}"
                    BorderThickness="1,0,0,0"
                    PreviewMouseLeftButtonDown="AlphabetIndexBorder_OnPreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="AlphabetIndexBorder_OnPreviewMouseLeftButtonUp"
                    PreviewMouseMove="AlphabetIndexBorder_OnPreviewMouseMove"
                    Panel.ZIndex="10">
                <UniformGrid x:Name="AlphabetIndexPanel"
                             Rows="27"
                             Columns="1"
                             Margin="0,4"/>
            </Border>

            <!-- Songtextansicht -->
            <Grid x:Name="LyricsView"
                  Grid.Row="1"
                  Visibility="Collapsed"
                  Background="{DynamicResource AppContentBrush}"
                  Panel.ZIndex="20"
                  ClipToBounds="True">
                <Image x:Name="LyricsBackgroundImage"
                       Stretch="Uniform"
                       Opacity="0.22"/>
                <Border Background="#B018192E"/>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="28,22,28,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{DynamicResource L_Lyrics}"
                                   VerticalAlignment="Center"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                        <Button Grid.Column="1"
                                Padding="12,6"
                                Margin="0,0,8,0"
                                Style="{StaticResource HeaderFilterButtonStyle}"
                                Content="{DynamicResource L_SearchLyrics}"
                                Click="SearchLyricsButton_OnClick"/>
                        <Button x:Name="RefreshLyricsButton"
                                Grid.Column="2"
                                Style="{StaticResource TransportBtnStyle}"
                                Margin="0,0,8,0"
                                ToolTip="{DynamicResource L_RefreshLyrics}"
                                Click="RefreshLyricsButton_OnClick">
                            <TextBlock Text="↻" FontSize="18"/>
                        </Button>
                        <Button Grid.Column="3"
                                Style="{StaticResource TransportBtnStyle}"
                                ToolTip="{DynamicResource L_CloseLyrics}"
                                Click="CloseLyricsButton_OnClick">
                            <TextBlock Text="×" FontSize="20"/>
                        </Button>
                    </Grid>
                    <Grid Grid.Row="1">
                        <ListBox x:Name="LyricsListBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="80,26,80,60"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,5"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Text}"
                                               Padding="16,10"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#B8B8D0"/>
                                                <Setter Property="Opacity" Value="0.78"/>
                                                <Setter Property="FontSize" Value="24"/>
                                                <Setter Property="FontWeight" Value="Medium"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="FontSize" Value="30"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock x:Name="LyricsStatusTextBlock"
                                   Margin="60"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="White"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Podcast-Infoansicht -->
            <Grid x:Name="PodcastInfoView"
                  Grid.Row="1"
                  Visibility="Collapsed"
                  Background="{DynamicResource AppContentBrush}"
                  Panel.ZIndex="21">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="60,30,60,50">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBlock Text="{DynamicResource L_PodcastInfo}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                            <Button HorizontalAlignment="Right"
                                    Style="{StaticResource TransportBtnStyle}"
                                    ToolTip="{DynamicResource L_ClosePodcastInfo}"
                                    Click="ClosePodcastInfoButton_OnClick">
                                <TextBlock Text="×" FontSize="20"/>
                            </Button>
                        </Grid>
                        <Border Grid.Row="1"
                                Width="300"
                                Height="300"
                                Margin="0,28,0,22"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                CornerRadius="12"
                                ClipToBounds="True">
                            <Grid>
                                <Image x:Name="PodcastInfoImage"
                                       Stretch="UniformToFill"/>
                                <TextBlock x:Name="PodcastInfoImagePlaceholder"
                                           Text="◍"
                                           FontSize="72"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppMutedTextBrush}"/>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="PodcastInfoPodcastName"
                                   Grid.Row="2"
                                   MaxWidth="900"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                        <TextBlock x:Name="PodcastInfoEpisodeTitle"
                                   Grid.Row="3"
                                   MaxWidth="900"
                                   Margin="0,12,0,0"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   Foreground="#6C63FF"/>
                        <TextBlock x:Name="PodcastInfoMetadata"
                                   Grid.Row="4"
                                   Margin="0,10,0,24"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   FontSize="12"
                                   Foreground="{DynamicResource AppMutedTextBrush}"/>
                        <TextBlock x:Name="PodcastInfoDescription"
                                   Grid.Row="5"
                                   MaxWidth="900"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   FontSize="18"
                                   LineHeight="28"
                                   Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- Künstlerinfoansicht -->
            <Grid x:Name="ArtistInfoView"
                  Grid.Row="1"
                  Visibility="Collapsed"
                  Background="{DynamicResource AppContentBrush}"
                  Panel.ZIndex="21">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="60,30,60,50">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ArtistInfoTitleButton"
                                    FontSize="28"
                                    FontWeight="SemiBold"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource EntityLinkButtonStyle}"
                                    Click="ArtistInfoTitleButton_OnClick"/>
                            <Button Grid.Column="1"
                                    Margin="0,0,8,0"
                                    Padding="12,6"
                                    Style="{StaticResource HeaderFilterButtonStyle}"
                                    Content="{DynamicResource L_EditArtistName}"
                                    Click="EditArtistNameButton_OnClick"/>
                            <Button Grid.Column="2"
                                    Margin="0,0,8,0"
                                    Padding="12,6"
                                    Style="{StaticResource HeaderFilterButtonStyle}"
                                    Content="{DynamicResource L_SearchArtistImage}"
                                    Click="SearchArtistImageButton_OnClick"/>
                            <Button x:Name="RefreshArtistInfoButton"
                                    Grid.Column="3"
                                    Style="{StaticResource TransportBtnStyle}"
                                    Margin="0,0,8,0"
                                    ToolTip="{DynamicResource L_RefreshArtistInfo}"
                                    Click="RefreshArtistInfoButton_OnClick">
                                <TextBlock Text="↻" FontSize="18"/>
                            </Button>
                            <Button Grid.Column="4"
                                    Style="{StaticResource TransportBtnStyle}"
                                    ToolTip="{DynamicResource L_CloseArtistInfo}"
                                    Click="CloseArtistInfoButton_OnClick">
                                <TextBlock Text="×" FontSize="20"/>
                            </Button>
                        </Grid>
                        <Border Grid.Row="1"
                                Width="360"
                                Height="360"
                                Margin="0,28,0,28"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                CornerRadius="12"
                                ClipToBounds="True">
                            <Grid>
                                <Image x:Name="ArtistInfoImage"
                                       Stretch="Uniform"/>
                                <StackPanel x:Name="ArtistInfoImagePlaceholder"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="♪"
                                               FontSize="72"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource AppMutedTextBrush}"/>
                                    <TextBlock x:Name="ArtistInfoImageStatusText"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               MaxWidth="300"
                                               Margin="0,8,0,0"
                                               HorizontalAlignment="Center"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Visibility="Collapsed"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="ArtistInfoBiographyTextBlock"
                                   Grid.Row="2"
                                   MaxWidth="900"
                                   FontSize="20"
                                   LineHeight="31"
                                   TextWrapping="Wrap"
                                   TextAlignment="Left"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                        <Button x:Name="ArtistInfoSourceButton"
                                Grid.Row="3"
                                Margin="0,26,0,0"
                                Padding="14,7"
                                HorizontalAlignment="Center"
                                Visibility="Collapsed"
                                Style="{StaticResource HeaderFilterButtonStyle}"
                                Content="{DynamicResource L_ArtistInfoSource}"
                                Click="ArtistInfoSourceButton_OnClick"/>
                    </Grid>
                </ScrollViewer>
                <TextBlock x:Name="ArtistInfoStatusTextBlock"
                           Margin="60"
                           FontSize="22"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppPrimaryTextBrush}"/>
            </Grid>
        </Grid>

        <!-- ═══ TRANSPORT BAR ═══ -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                Background="{DynamicResource AppTransportBrush}"
                BorderThickness="0,1,0,0" BorderBrush="{DynamicResource AppTransportBorderBrush}"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Now playing -->
                <Grid VerticalAlignment="Center" Margin="0,0,16,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="42" Height="42" Background="{DynamicResource AppArtworkPlaceholderBrush}" CornerRadius="5">
                        <Image x:Name="NowPlayingArtworkImage" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="NowPlayingTitleBlock"
                                   Foreground="{DynamicResource AppTransportPrimaryTextBrush}" FontSize="13" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <Button x:Name="NowPlayingArtistButton"
                                Content="{Binding Text, ElementName=NowPlayingArtistBlock}"
                                Foreground="#6666AA"
                                FontSize="11"
                                Margin="0,2,0,0"
                                IsEnabled="False"
                                Style="{StaticResource EntityLinkButtonStyle}"
                                Click="NowPlayingArtistButton_OnClick"/>
                        <TextBlock x:Name="NowPlayingArtistBlock" Visibility="Collapsed"/>
                        <TextBlock x:Name="FileInfoTextBlock"
                                   Foreground="#44445A" FontSize="10" Margin="0,2,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>

                <!-- Controls -->
                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid x:Name="TransportControlsHeaderGrid"
                          Margin="0,0,0,10"
                          Loaded="TransportControlsHeaderGrid_OnLayoutChanged"
                          SizeChanged="TransportControlsHeaderGrid_OnLayoutChanged">
                        <StackPanel x:Name="PlaybackControlsPanel"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <StackPanel.RenderTransform>
                                <TranslateTransform x:Name="PlaybackControlsTranslate"/>
                            </StackPanel.RenderTransform>
                        <Button x:Name="PreviousButton"
                                Style="{StaticResource TransportBtnStyle}"
                                Margin="0,0,6,0" IsEnabled="False"
                                Click="PreviousButton_OnClick">
                            <Grid Width="16" Height="16">
                                <Rectangle Width="2" Height="12"
                                           HorizontalAlignment="Left"
                                           Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Path Data="M 14 2 L 8 8 L 14 14 Z M 8 2 L 2 8 L 8 14 Z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </Grid>
                        </Button>
                        <Button x:Name="PlayButton"
                                Style="{StaticResource PlayBtnStyle}"
                                Margin="6,0"
                                Click="PlayButton_OnClick">
                            <Path x:Name="PlayPauseIcon"
                                  Data="M 4 2 L 14 8 L 4 14 Z"
                                  Width="16"
                                  Height="16"
                                  Stretch="Uniform"
                                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                        </Button>
                        <Button x:Name="NextButton"
                                Style="{StaticResource TransportBtnStyle}"
                                Margin="6,0,0,0" IsEnabled="False"
                                Click="NextButton_OnClick">
                            <Grid Width="16" Height="16">
                                <Path Data="M 2 2 L 8 8 L 2 14 Z M 8 2 L 14 8 L 8 14 Z"
                                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                <Rectangle Width="2" Height="12"
                                           HorizontalAlignment="Right"
                                           Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                            </Grid>
                        </Button>
                        </StackPanel>
                        <StackPanel x:Name="TransportActionPanel"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Left">
                            <Button x:Name="ArtistInfoButton"
                                    Style="{StaticResource TransportBtnStyle}"
                                    Margin="6,0,0,0"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource L_ShowArtistInfo}"
                                    Click="ArtistInfoButton_OnClick">
                                <TextBlock Text="i"
                                           FontFamily="Segoe UI"
                                           FontStyle="Italic"
                                           FontWeight="Bold"
                                           FontSize="15"/>
                            </Button>
                            <Button x:Name="LyricsButton"
                                    Style="{StaticResource TransportBtnStyle}"
                                    Margin="6,0,0,0"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource L_ShowLyrics}"
                                    Click="LyricsButton_OnClick">
                                <TextBlock Text="♪" FontSize="16"/>
                            </Button>
                            <Button x:Name="NowPlayingFavoriteButton"
                                    Style="{StaticResource TransportBtnStyle}"
                                    Margin="6,0,0,0"
                                    IsEnabled="False"
                                    ToolTip="{DynamicResource L_MarkAsFavorite}"
                                    Click="NowPlayingFavoriteButton_OnClick">
                                <TextBlock x:Name="NowPlayingFavoriteGlyph"
                                           Text="♡"
                                           FontSize="16"/>
                            </Button>
                            <Button x:Name="ShuffleButton"
                                    Style="{StaticResource TransportBtnStyle}"
                                    Margin="6,0,0,0"
                                    ToolTip="{DynamicResource L_Shuffle}"
                                    Click="ShuffleButton_OnClick">
                                <Viewbox Width="17" Height="17">
                                    <Canvas Width="18" Height="18">
                                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M 2 4 H 5 C 9 4 9 14 13 14 H 15"/>
                                        <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Data="M 2 14 H 5 C 9 14 9 4 13 4 H 15"/>
                                        <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                              Data="M 14 1 L 18 4 L 14 7 Z M 14 11 L 18 14 L 14 17 Z"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="42"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CurrentTimeTextBlock"
                                   Foreground="#6666AA" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Margin="0,0,8,0" Text="0:00"/>
                        <Slider x:Name="PositionSlider"
                                Grid.Column="1"
                                Style="{StaticResource DarkSliderStyle}"
                                Height="30"
                                Minimum="0" Maximum="1" IsEnabled="False"
                                PreviewMouseLeftButtonDown="PositionSlider_OnPreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="PositionSlider_OnPreviewMouseLeftButtonUp"
                                ValueChanged="PositionSlider_OnValueChanged"/>
                        <TextBlock x:Name="DurationTextBlock"
                                   Grid.Column="2"
                                   Foreground="#6666AA" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Left"
                                   Margin="8,0,0,0" Text="0:00"/>
                    </Grid>
                </Grid>

                <!-- Volume -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="🔊" Foreground="#6666AA" FontSize="13"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Slider x:Name="VolumeSlider"
                            Style="{StaticResource DarkSliderStyle}"
                            Width="100" Minimum="0" Maximum="1" Value="1"
                            VerticalAlignment="Center"
                            ValueChanged="VolumeSlider_OnValueChanged"/>
                    <TextBlock x:Name="VolumeValueTextBlock"
                               Foreground="#6666AA" FontSize="11" Width="44"
                               VerticalAlignment="Center" Margin="10,0,0,0"
                               Text="100 %"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
