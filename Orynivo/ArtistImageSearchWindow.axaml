<Window x:Class="Orynivo.ArtistImageSearchWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L_ArtistImageSearchTitle}"
        Icon="avares://Orynivo/Assets/Orynivo.ico"
        Height="620"
        Width="560"
        MinHeight="440"
        MinWidth="480"
        Background="{DynamicResource AppContentBrush}"
        Foreground="{DynamicResource AppPrimaryTextBrush}">
    <Window.Styles>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#6C63FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="ListBoxItem">
        </Style>
    </Window.Styles>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock x:Name="BusyIndicatorTextBlock"
                       Text="⠋"
                       FontSize="16"
                       Margin="0,0,8,0"/>
            <TextBlock x:Name="StatusTextBlock"
                       Text="{DynamicResource L_ArtistImageSearchRunning}"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{DynamicResource L_ArtistImageSearchQuery}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="QueryTextBox"
                         Height="28"
                         VerticalContentAlignment="Center"/>
            </StackPanel>
            <Button Classes="accent"
                    Grid.Column="1"
                    Width="110"
                    Height="28"
                    Margin="10,20,0,0"
                    Content="{DynamicResource L_SearchAgain}"
                    Click="SearchAgainButton_OnClick"/>
        </Grid>
        <ListBox x:Name="ResultsListBox"
                 Grid.Row="2"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,8"
                            Padding="10"
                            Background="{DynamicResource AppSurfaceBrush}"
                            CornerRadius="0,14,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="112"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="96"
                                    Height="96"
                                    Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                    ClipToBounds="True">
                                <Image Source="{Binding Image}"
                                       Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Attribution}"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding License}"
                                           Margin="0,4,0,0"
                                           FontSize="11"
                                           Foreground="{DynamicResource AppMutedTextBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button Classes="accent"
                Grid.Row="3"
                Width="220"
                Height="30"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Content="{DynamicResource L_UseSelectedArtistImage}"
                Click="UseSelectedImageButton_OnClick"/>
    </Grid>
</Window>
