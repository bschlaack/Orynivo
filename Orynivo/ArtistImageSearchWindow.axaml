<Window x:Class="Orynivo.ArtistImageSearchWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L_ArtistImageSearchTitle}"
        Icon="avares://Orynivo/Assets/Orynivo.ico"
        Height="620"
        Width="560"
        MinHeight="440"
        MinWidth="480"
        Background="{DynamicResource AppContentBrush}"
        Foreground="{DynamicResource AppPrimaryTextBrush}">
    <Window.Styles>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#6C63FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Styles>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock x:Name="BusyIndicatorTextBlock"
                       Text="⠋"
                       FontSize="{DynamicResource FontSizeSubtitle}"
                       Margin="0,0,8,0"/>
            <TextBlock x:Name="StatusTextBlock"
                       Text="{DynamicResource L_ArtistImageSearchRunning}"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{DynamicResource L_ArtistImageSearchQuery}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="QueryTextBox"
                         Height="28"
                         VerticalContentAlignment="Center"/>
            </StackPanel>
            <Button Classes="accent"
                    Grid.Column="1"
                    MinWidth="126"
                    Height="30"
                    Margin="10,0,0,0"
                    Padding="12,0"
                    VerticalAlignment="Bottom"
                    Click="SearchAgainButton_OnClick">
                <StackPanel Orientation="Horizontal" Spacing="7">
                    <Path Width="14"
                          Height="14"
                          Stretch="Uniform"
                          Fill="White"
                          Data="M9.5,3 C5.9,3 3,5.9 3,9.5 C3,13.1 5.9,16 9.5,16 C11,16 12.4,15.5 13.5,14.6 L18,19.1 L19.1,18 L14.6,13.5 C15.5,12.4 16,11 16,9.5 C16,5.9 13.1,3 9.5,3 Z M9.5,4.6 C12.2,4.6 14.4,6.8 14.4,9.5 C14.4,12.2 12.2,14.4 9.5,14.4 C6.8,14.4 4.6,12.2 4.6,9.5 C4.6,6.8 6.8,4.6 9.5,4.6 Z"/>
                    <TextBlock Text="{DynamicResource L_SearchAgain}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
        <ListBox x:Name="ResultsListBox"
                 Grid.Row="2"
                 Background="Transparent"
                 BorderThickness="0"
                 ItemContainerTheme="{StaticResource AppSearchResultItemTheme}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="112"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="96"
                                    Height="96"
                                    Background="{DynamicResource AppArtworkPlaceholderBrush}"
                                    ClipToBounds="True">
                                <Image Source="{Binding Image}"
                                       Stretch="UniformToFill"/>
                            </Border>
                            <StackPanel Grid.Column="1"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Attribution}"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding License}"
                                           Margin="0,4,0,0"
                                           FontSize="{DynamicResource FontSizeMeta}"
                                           Foreground="{DynamicResource AppMutedTextBrush}"/>
                            </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button Classes="accent"
                Grid.Row="3"
                Width="220"
                Height="30"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Content="{DynamicResource L_UseSelectedArtistImage}"
                Click="UseSelectedImageButton_OnClick"/>
    </Grid>
</Window>
