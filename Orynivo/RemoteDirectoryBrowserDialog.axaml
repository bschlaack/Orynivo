<Window x:Class="Orynivo.RemoteDirectoryBrowserDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L_OrynivoServerDirectoryBrowserTitle}"
        Icon="avares://Orynivo/Assets/Orynivo.ico"
        Width="560"
        Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppSurfaceBrush}"
        Foreground="{DynamicResource AppPrimaryTextBrush}">
    <Window.Resources>
        <ControlTheme x:Key="ServerDialogButtonTheme" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppButtonBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppButtonTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#ButtonBorder">
                <Setter Property="Background" Value="{DynamicResource AppButtonHoverBrush}"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#ButtonBorder">
                <Setter Property="Background" Value="{DynamicResource AppButtonPressedBrush}"/>
            </Style>
            <Style Selector="^:disabled">
                <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}"/>
                <Setter Property="Opacity" Value="0.65"/>
            </Style>
        </ControlTheme>
        <ControlTheme x:Key="ServerDialogPrimaryButtonTheme"
                      TargetType="Button"
                      BasedOn="{StaticResource ServerDialogButtonTheme}">
            <Setter Property="Background" Value="{DynamicResource AppTransportPlayBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style Selector="^:pointerover /template/ Border#ButtonBorder">
                <Setter Property="Background" Value="{DynamicResource AppTransportPlayHoverBrush}"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#ButtonBorder">
                <Setter Property="Background" Value="{DynamicResource AppTransportPlayBrush}"/>
            </Style>
        </ControlTheme>
        <ControlTheme x:Key="ServerDirectoryListItemTheme" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#ItemBorder">
                <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}"/>
            </Style>
            <Style Selector="^:selected">
                <Setter Property="Background" Value="{DynamicResource AppSurfaceSelectedBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
            </Style>
            <Style Selector="^:selected /template/ Border#ItemBorder">
                <Setter Property="Background" Value="{DynamicResource AppSurfaceSelectedBrush}"/>
            </Style>
        </ControlTheme>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBox x:Name="CurrentPathTextBox"
                 Height="34"
                 Padding="10,0"
                 VerticalContentAlignment="Center"
                 IsReadOnly="True"
                 Background="{DynamicResource AppInputBrush}"
                 Foreground="{DynamicResource AppPrimaryTextBrush}"
                 BorderBrush="{DynamicResource AppInputBorderBrush}"
                 Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,0,0,8">
            <Button x:Name="RootButton"
                    Content="{DynamicResource L_OrynivoServerDirectoryRoots}"
                    Width="120"
                    Height="30"
                    Margin="0,0,8,0"
                    Theme="{StaticResource ServerDialogButtonTheme}"
                    Click="RootButton_OnClick"/>
        </StackPanel>

        <ListBox x:Name="DirectoryListBox"
                 Grid.Row="2"
                 Background="{DynamicResource AppInputBrush}"
                 Foreground="{DynamicResource AppPrimaryTextBrush}"
                 BorderBrush="{DynamicResource AppInputBorderBrush}"
                 BorderThickness="1"
                 ItemContainerTheme="{StaticResource ServerDirectoryListItemTheme}"
                 DoubleTapped="DirectoryListBox_OnDoubleTapped"/>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="3"
                   MinHeight="22"
                   Foreground="{DynamicResource AppMutedTextBrush}"
                   TextWrapping="Wrap"
                   Margin="0,10,0,8"/>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="{DynamicResource L_Cancel}"
                    Width="90"
                    Height="34"
                    Margin="0,0,8,0"
                    Theme="{StaticResource ServerDialogButtonTheme}"
                    Click="CancelButton_OnClick"/>
            <Button x:Name="SelectButton"
                    Content="{DynamicResource L_OrynivoSelectServerDirectory}"
                    Width="140"
                    Height="34"
                    Theme="{StaticResource ServerDialogPrimaryButtonTheme}"
                    Click="SelectButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
