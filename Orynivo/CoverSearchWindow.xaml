<Window x:Class="Orynivo.CoverSearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L_CoverSearchTitle}"
        Icon="Assets/Orynivo.ico"
        Height="560"
        Width="520"
        MinHeight="420"
        MinWidth="460"
        Background="{DynamicResource AppContentBrush}"
        Foreground="{DynamicResource AppPrimaryTextBrush}"
        SourceInitialized="CoverSearchWindow_OnSourceInitialized">
    <Window.Resources>
        <Style x:Key="DialogButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6C63FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,12">
            <TextBlock x:Name="BusyIndicatorTextBlock"
                       Text="⠋"
                       FontSize="16"
                       Margin="0,0,8,0"/>
            <TextBlock x:Name="StatusTextBlock"
                       Text="{DynamicResource L_CoverSearchRunning}"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{DynamicResource L_CoverSearchQuery}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="QueryTextBox"
                         Height="28"
                         VerticalContentAlignment="Center"/>
            </StackPanel>
            <Button Grid.Column="1"
                    Width="110"
                    Height="28"
                    Margin="10,20,0,0"
                    Style="{StaticResource DialogButtonStyle}"
                    Content="{DynamicResource L_SearchAgain}"
                    Click="SearchAgainButton_OnClick"/>
        </Grid>
        <ListBox x:Name="ResultsListBox"
                 Grid.Row="2"
                 Background="Transparent"
                 BorderThickness="0"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,8"
                            Padding="10"
                            MaxWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ListBox}}"
                            Background="{DynamicResource AppSurfaceBrush}"
                            CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Width="80"
                                   Height="80"
                                   Source="{Binding Image}"
                                   Stretch="UniformToFill"/>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                                <TextBlock Text="{Binding Artist}"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Width="220"
                    Height="30"
                    Style="{StaticResource DialogButtonStyle}"
                    Content="{DynamicResource L_UseSelectedCover}"
                    Click="UseSelectedCoverButton_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
