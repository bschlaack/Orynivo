<Window x:Class="Orynivo.EditArtistNameDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L_EditArtistName}"
        Icon="avares://Orynivo/Assets/Orynivo.ico"
        Width="420"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppSurfaceBrush}">
    <Window.Resources>
        <ControlTheme x:Key="DialogButtonTheme" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppButtonBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppButtonTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="ButtonBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#ButtonBorder">
                <Setter Property="Background" Value="{DynamicResource AppButtonHoverBrush}"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#ButtonBorder">
                <Setter Property="Background" Value="{DynamicResource AppButtonPressedBrush}"/>
            </Style>
        </ControlTheme>
        <ControlTheme x:Key="DialogPrimaryButtonTheme"
                      TargetType="Button"
                      BasedOn="{StaticResource DialogButtonTheme}">
            <Setter Property="Background" Value="{DynamicResource AppTransportPlayBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style Selector="^:pointerover /template/ Border#ButtonBorder">
                <Setter Property="Background" Value="{DynamicResource AppTransportPlayHoverBrush}"/>
            </Style>
            <Style Selector="^:pressed /template/ Border#ButtonBorder">
                <Setter Property="Background" Value="{DynamicResource AppTransportPlayBrush}"/>
            </Style>
        </ControlTheme>
    </Window.Resources>
    <Grid Margin="24,20,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="{DynamicResource L_ArtistName}"
                   FontSize="12"
                   Foreground="{DynamicResource AppMutedTextBrush}"
                   Margin="0,0,0,6"/>
        <TextBox x:Name="NameTextBox"
                 Grid.Row="1"
                 Height="34"
                 Padding="10,0"
                 VerticalContentAlignment="Center"
                 Background="{DynamicResource AppInputBrush}"
                 Foreground="{DynamicResource AppPrimaryTextBrush}"
                 BorderBrush="{DynamicResource AppInputBorderBrush}"
                 Margin="0,0,0,20"
                 TextChanged="NameTextBox_OnTextChanged"
                 KeyDown="NameTextBox_OnKeyDown"/>
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="CancelButton"
                    Content="{DynamicResource L_Cancel}"
                    Width="100"
                    Height="34"
                    Margin="0,0,8,0"
                    Theme="{StaticResource DialogButtonTheme}"
                    Click="CancelButton_OnClick"/>
            <Button x:Name="RenameButton"
                    Content="{DynamicResource L_RenameArtist}"
                    Width="120"
                    Height="34"
                    Theme="{StaticResource DialogPrimaryButtonTheme}"
                    Click="RenameButton_OnClick"/>
        </StackPanel>
        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="3"
                   Margin="0,12,0,0"
                   Foreground="{DynamicResource AppMutedTextBrush}"
                   TextWrapping="Wrap"
                   IsVisible="False"/>
    </Grid>
</Window>
