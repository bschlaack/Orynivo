<Application x:Class="Orynivo.App"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Orynivo.Controls">
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        <Style Selector="Window">
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
        </Style>
        <Style Selector="Window ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
        </Style>
        <Style Selector="Window ListBoxItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
        </Style>
    </Application.Styles>
    <Application.Resources>
        <ResourceDictionary>
            <!-- ── Theme brushes (overwritten at runtime by ThemeManager) ── -->
            <SolidColorBrush x:Key="AppAccentBrush"              Color="#4FDDBD"/>
            <SolidColorBrush x:Key="AppAccentTextBrush"          Color="#102033"/>
            <SolidColorBrush x:Key="AppAccentSoftBrush"          Color="#163E3C"/>
            <SolidColorBrush x:Key="AppSidebarBrush"             Color="#0E1116"/>
            <SolidColorBrush x:Key="AppHeaderBrush"              Color="#11151B"/>
            <SolidColorBrush x:Key="AppHeaderBorderBrush"        Color="#20262E"/>
            <SolidColorBrush x:Key="AppContentBrush"             Color="#141922"/>
            <SolidColorBrush x:Key="AppSurfaceBrush"             Color="#1A2029"/>
            <SolidColorBrush x:Key="AppSurfaceHoverBrush"        Color="#222B36"/>
            <SolidColorBrush x:Key="AppSurfaceSelectedBrush"     Color="#26333E"/>
            <SolidColorBrush x:Key="AppNowPlayingRowBrush"       Color="#173B38"/>
            <SolidColorBrush x:Key="AppNavHoverBrush"            Color="#171D25"/>
            <SolidColorBrush x:Key="AppNavSelectedBrush"         Color="#1B2F35"/>
            <SolidColorBrush x:Key="AppNavTextBrush"             Color="#98A2B3"/>
            <SolidColorBrush x:Key="AppNavHoverTextBrush"        Color="#D6DEE8"/>
            <SolidColorBrush x:Key="AppNavSelectedTextBrush"     Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AppPrimaryTextBrush"         Color="#F4F7FA"/>
            <SolidColorBrush x:Key="AppSecondaryTextBrush"       Color="#AAB4C3"/>
            <SolidColorBrush x:Key="AppMutedTextBrush"           Color="#6F7B8B"/>
            <SolidColorBrush x:Key="AppGridLineBrush"            Color="#27313D"/>
            <SolidColorBrush x:Key="AppColumnHeaderBrush"        Color="#161D26"/>
            <SolidColorBrush x:Key="AppTransportBrush"           Color="#0E1116"/>
            <SolidColorBrush x:Key="AppTransportBorderBrush"     Color="#20262E"/>
            <SolidColorBrush x:Key="AppTransportPrimaryTextBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AppTransportButtonBrush"     Color="#1A2029"/>
            <SolidColorBrush x:Key="AppTransportButtonHoverBrush" Color="#26313D"/>
            <SolidColorBrush x:Key="AppTransportButtonDisabledBrush" Color="#171D25"/>
            <SolidColorBrush x:Key="AppTransportButtonTextBrush" Color="#D6DEE8"/>
            <SolidColorBrush x:Key="AppTransportButtonHoverTextBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="AppTransportButtonDisabledTextBrush" Color="#3A3A55"/>
            <SolidColorBrush x:Key="AppTransportPlayBrush"       Color="#4FDDBD"/>
            <SolidColorBrush x:Key="AppTransportPlayHoverBrush"  Color="#67E8CC"/>
            <SolidColorBrush x:Key="AppTransportPlayDisabledBrush" Color="#26313D"/>
            <SolidColorBrush x:Key="AppTransportPlayDisabledTextBrush" Color="#3A3A55"/>
            <SolidColorBrush x:Key="AppArtworkPlaceholderBrush"  Color="#222A35"/>
            <SolidColorBrush x:Key="AppScrollbarTrackBrush"      Color="#171D25"/>
            <SolidColorBrush x:Key="AppScrollbarThumbBrush"      Color="#344150"/>
            <SolidColorBrush x:Key="AppScrollbarThumbHoverBrush" Color="#465568"/>
            <SolidColorBrush x:Key="AppButtonBrush"              Color="#1B232D"/>
            <SolidColorBrush x:Key="AppButtonHoverBrush"         Color="#26313D"/>
            <SolidColorBrush x:Key="AppButtonPressedBrush"       Color="#31404E"/>
            <SolidColorBrush x:Key="AppButtonTextBrush"          Color="#F4F7FA"/>
            <SolidColorBrush x:Key="AppButtonBorderBrush"        Color="#344150"/>
            <SolidColorBrush x:Key="AppInputBrush"               Color="#111820"/>
            <SolidColorBrush x:Key="AppInputBorderBrush"         Color="#344150"/>
            <SolidColorBrush x:Key="TextControlBackground"       Color="#111820"/>
            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#141C25"/>
            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#111820"/>
            <SolidColorBrush x:Key="TextControlForeground"       Color="#F4F7FA"/>
            <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="#F4F7FA"/>
            <SolidColorBrush x:Key="TextControlForegroundFocused" Color="#F4F7FA"/>
            <SolidColorBrush x:Key="TextControlBorderBrush"      Color="#344150"/>
            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="#465568"/>
            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="#4FDDBD"/>
            <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="#6F7B8B"/>
            <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#6F7B8B"/>
            <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused" Color="#6F7B8B"/>
            <SolidColorBrush x:Key="AppDsdSupportedBrush"        Color="#F7F7FF"/>
            <SolidColorBrush x:Key="AppDsdUnsupportedBrush"      Color="#5B5D79"/>
            <SolidColorBrush x:Key="TreeViewItemForeground" Color="#A0A0C8"/>
            <SolidColorBrush x:Key="TreeViewItemForegroundPointerOver" Color="#F7F7FF"/>
            <SolidColorBrush x:Key="TreeViewItemForegroundPressed" Color="#F7F7FF"/>
            <SolidColorBrush x:Key="TreeViewItemForegroundSelected" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TreeViewItemBackgroundSelected" Color="#343654"/>
            <SolidColorBrush x:Key="TreeViewItemBackgroundPointerOver" Color="#292B47"/>

            <!-- ── Typography scale (font-size tokens) ──
                 Shared modular scale so views stop using ad-hoc pixel sizes.
                 Roles: Meta (muted captions), Caption (small labels), Body
                 (tables/text), BodyStrong (emphasised body/section labels),
                 Subtitle, Title (headers), TitleLarge, Headline (card titles),
                 Display (immersive detail titles), DisplayLarge/Hero (decorative). -->
            <x:Double x:Key="FontSizeMeta">11</x:Double>
            <x:Double x:Key="FontSizeCaption">12</x:Double>
            <x:Double x:Key="FontSizeBody">13</x:Double>
            <x:Double x:Key="FontSizeBodyStrong">15</x:Double>
            <x:Double x:Key="FontSizeSubtitle">17</x:Double>
            <x:Double x:Key="FontSizeTitle">20</x:Double>
            <x:Double x:Key="FontSizeTitleLarge">24</x:Double>
            <x:Double x:Key="FontSizeHeadline">28</x:Double>
            <x:Double x:Key="FontSizeDisplay">34</x:Double>
            <x:Double x:Key="FontSizeDisplayLarge">52</x:Double>
            <x:Double x:Key="FontSizeHero">72</x:Double>

            <!-- ── Global control overrides ── -->

            <!-- InitialsAvatar: gradient + initials placeholder for missing artwork -->
            <ControlTheme x:Key="{x:Type controls:InitialsAvatar}" TargetType="controls:InitialsAvatar">
                <Setter Property="FontSize" Value="{DynamicResource FontSizeDisplay}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#F2F5FA"/>
                <Setter Property="Template">
                    <ControlTemplate>
                        <Border Background="{TemplateBinding Background}"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch">
                            <TextBlock Text="{TemplateBinding Initials}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Opacity="0.92"/>
                        </Border>
                    </ControlTemplate>
                </Setter>
            </ControlTheme>

            <!-- StatusBadge: pill with a coloured dot + short label -->
            <ControlTheme x:Key="{x:Type controls:StatusBadge}" TargetType="controls:StatusBadge">
                <Setter Property="FontSize" Value="{DynamicResource FontSizeMeta}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Template">
                    <ControlTemplate>
                        <Border Background="{DynamicResource AppSurfaceHoverBrush}"
                                BorderBrush="{DynamicResource AppInputBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="9,3">
                            <StackPanel Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Ellipse Width="8"
                                         Height="8"
                                         VerticalAlignment="Center"
                                         Fill="{TemplateBinding DotBrush}"/>
                                <TextBlock Text="{TemplateBinding Text}"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="{TemplateBinding FontSize}"
                                           FontWeight="SemiBold"
                                           Foreground="{TemplateBinding Foreground}"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter>
            </ControlTheme>

            <!-- ContextMenu -->
            <ControlTheme x:Key="{x:Type ContextMenu}" TargetType="ContextMenu">
                <Setter Property="Background"      Value="{DynamicResource AppSurfaceBrush}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource AppInputBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius"    Value="8"/>
                <Setter Property="Padding"         Value="0,4"/>
                <Setter Property="Template">
                    <ControlTemplate>
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter>
            </ControlTheme>

            <!-- MenuItem -->
            <ControlTheme x:Key="{x:Type MenuItem}" TargetType="MenuItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
                <Setter Property="Padding"    Value="14,7"/>
                <Setter Property="Template">
                    <ControlTemplate>
                        <Border Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter Content="{TemplateBinding Header}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter>
                <Style Selector="^:pointerover /template/ Border#Bd">
                    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}"/>
                </Style>
                <Style Selector="^:disabled">
                    <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}"/>
                </Style>
            </ControlTheme>

            <!-- Separator -->
            <ControlTheme x:Key="{x:Type Separator}" TargetType="Separator">
                <Setter Property="Template">
                    <ControlTemplate>
                        <Border Height="1" Margin="8,4"
                                Background="{DynamicResource AppGridLineBrush}"/>
                    </ControlTemplate>
                </Setter>
            </ControlTheme>

            <ControlTheme x:Key="AppMenuFlyoutPresenterTheme"
                          TargetType="MenuFlyoutPresenter"
                          BasedOn="{StaticResource {x:Type MenuFlyoutPresenter}}">
                <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource AppInputBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="0,4"/>
            </ControlTheme>

            <ControlTheme x:Key="AppMenuFlyoutItemTheme" TargetType="MenuItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="CornerRadius" Value="5"/>
                <Setter Property="Padding" Value="14,7"/>
                <Setter Property="Template">
                    <ControlTemplate>
                        <Border x:Name="PART_LayoutRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="PART_HeaderPresenter"
                                              Content="{TemplateBinding Header}"
                                              Foreground="{TemplateBinding Foreground}"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter>
                <Style Selector="^:selected /template/ Border#PART_LayoutRoot">
                    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}"/>
                </Style>
                <Style Selector="^:pressed /template/ Border#PART_LayoutRoot">
                    <Setter Property="Background" Value="{DynamicResource AppButtonPressedBrush}"/>
                </Style>
                <Style Selector="^:disabled">
                    <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}"/>
                </Style>
            </ControlTheme>

            <ControlTheme x:Key="AppSearchResultItemTheme" TargetType="ListBoxItem">
                <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="10"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <ControlTemplate>
                        <Border x:Name="ResultBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              DataContext="{TemplateBinding DataContext}"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              HorizontalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter>
                <Style Selector="^:pointerover">
                    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}"/>
                </Style>
                <Style Selector="^:selected">
                    <Setter Property="Background" Value="{DynamicResource AppSurfaceSelectedBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}"/>
                </Style>
            </ControlTheme>

            <!-- ScrollBar thumb, page-track, and arrow buttons are separate themes.
                 DataGrid discovers the named PART_* buttons and assigns small/large scrolling. -->
            <ControlTheme x:Key="AppScrollBarThumb" TargetType="Thumb">
                <Setter Property="Template">
                    <ControlTemplate>
                        <Border Name="ThumbBd"
                                Margin="2"
                                Background="{DynamicResource AppScrollbarThumbBrush}"
                                CornerRadius="5"/>
                    </ControlTemplate>
                </Setter>
                <Style Selector="^:pointerover /template/ Border#ThumbBd">
                    <Setter Property="Background" Value="{DynamicResource AppScrollbarThumbHoverBrush}"/>
                </Style>
            </ControlTheme>

            <ControlTheme x:Key="AppScrollBarPageButton" TargetType="RepeatButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="VerticalAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <ControlTemplate>
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter>
            </ControlTheme>

            <ControlTheme x:Key="AppScrollBarLineButton" TargetType="RepeatButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="Template">
                    <ControlTemplate>
                        <Border Background="Transparent">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter>
            </ControlTheme>

            <ControlTheme x:Key="{x:Type ScrollBar}" TargetType="ScrollBar">
                <Setter Property="Width" Value="16"/>
                <Setter Property="MinWidth" Value="16"/>
                <Setter Property="Background" Value="{DynamicResource AppScrollbarTrackBrush}"/>
                <Style Selector="^:vertical">
                    <Setter Property="Template">
                        <ControlTemplate>
                            <Grid RowDefinitions="18,*,18"
                                  Background="{TemplateBinding Background}">
                                <RepeatButton Name="PART_LineUpButton"
                                              Grid.Row="0"
                                              Theme="{StaticResource AppScrollBarLineButton}">
                                    <Path Width="7"
                                          Height="4"
                                          Data="M 0 4 L 3.5 0 L 7 4"
                                          Stroke="{DynamicResource AppScrollbarThumbBrush}"
                                          StrokeThickness="1.5"/>
                                </RepeatButton>
                                <Track Grid.Row="1"
                                       Minimum="{TemplateBinding Minimum}"
                                       Maximum="{TemplateBinding Maximum}"
                                       Value="{TemplateBinding Value, Mode=TwoWay}"
                                       DeferThumbDrag="{TemplateBinding ScrollViewer.IsDeferredScrollingEnabled}"
                                       ViewportSize="{TemplateBinding ViewportSize}"
                                       Orientation="{TemplateBinding Orientation}"
                                       IsDirectionReversed="True">
                                    <Track.DecreaseButton>
                                        <RepeatButton Name="PART_PageUpButton"
                                                      Classes="largeIncrease"
                                                      Theme="{StaticResource AppScrollBarPageButton}"/>
                                    </Track.DecreaseButton>
                                    <Track.Thumb>
                                        <Thumb MinHeight="42"
                                               Theme="{StaticResource AppScrollBarThumb}"/>
                                    </Track.Thumb>
                                    <Track.IncreaseButton>
                                        <RepeatButton Name="PART_PageDownButton"
                                                      Classes="largeIncrease"
                                                      Theme="{StaticResource AppScrollBarPageButton}"/>
                                    </Track.IncreaseButton>
                                </Track>
                                <RepeatButton Name="PART_LineDownButton"
                                              Grid.Row="2"
                                              Theme="{StaticResource AppScrollBarLineButton}">
                                    <Path Width="7"
                                          Height="4"
                                          Data="M 0 0 L 3.5 4 L 7 0"
                                          Stroke="{DynamicResource AppScrollbarThumbBrush}"
                                          StrokeThickness="1.5"/>
                                </RepeatButton>
                            </Grid>
                        </ControlTemplate>
                    </Setter>
                </Style>
            </ControlTheme>

            <!-- ── Localisation string resources (initial German; overwritten by LocalizationManager) ── -->
            <x:String x:Key="L_LocalLibrary">BIBLIOTHEK</x:String>
            <x:String x:Key="L_LocalMedia">Lokal</x:String>
            <x:String x:Key="L_LibraryEmptyHint">Noch keine Medienquelle eingerichtet. Lege in den Einstellungen lokale Verzeichnisse oder einen oder mehrere Orynivo Server an.</x:String>
            <x:String x:Key="L_Artists">Künstler</x:String>
            <x:String x:Key="L_Albums">Alben</x:String>
            <x:String x:Key="L_Tracks">Tracks</x:String>
            <x:String x:Key="L_Title">Titel</x:String>
            <x:String x:Key="L_Artist">Künstler</x:String>
            <x:String x:Key="L_Album">Album</x:String>
            <x:String x:Key="L_Duration">Dauer</x:String>
            <x:String x:Key="L_CwAsioOutputDevice">cwASIO-Ausgabegerät</x:String>
            <x:String x:Key="L_DailyHistoryTitle">Hörverlauf</x:String>
            <x:String x:Key="L_PlayedAt">Gehört um</x:String>
            <x:String x:Key="L_ListenedDuration">Gehört</x:String>
            <x:String x:Key="L_MediaType">Typ</x:String>
            <x:String x:Key="L_Close">Schließen</x:String>
            <x:String x:Key="L_DailyHistoryNoEntries">Für diesen Tag sind keine Wiedergaben vorhanden.</x:String>
            <x:String x:Key="L_FolderStructure">Ordnerstruktur</x:String>
            <x:String x:Key="L_Playlists">Playlists</x:String>
            <x:String x:Key="L_Settings">⚙   Einstellungen</x:String>
            <x:String x:Key="L_Table">Tabelle</x:String>
            <x:String x:Key="L_Artwork">Artwork</x:String>
            <x:String x:Key="L_Appearance">Darstellung</x:String>
            <x:String x:Key="L_ColorScheme">Farbschema</x:String>
            <x:String x:Key="L_Language">Sprache</x:String>
            <x:String x:Key="L_Playback">WIEDERGABE</x:String>
            <x:String x:Key="L_OutputDevice">Ausgabegerät</x:String>
            <x:String x:Key="L_Library">BIBLIOTHEK</x:String>
            <x:String x:Key="L_Directories">Verzeichnisse</x:String>
            <x:String x:Key="L_AddDirectory">+ Verzeichnis hinzufügen</x:String>
            <x:String x:Key="L_Streaming">STREAMING</x:String>
            <x:String x:Key="L_StreamingServices">Streamingdienste</x:String>
            <x:String x:Key="L_Qobuz">Qobuz</x:String>
            <x:String x:Key="L_QobuzApplicationId">Qobuz-Anwendungs-ID</x:String>
            <x:String x:Key="L_QobuzIntegrationHint">Die Qobuz-Integration ist vorbereitet. Katalog und Wiedergabe werden nach Freigabe des Partnerzugangs aktiviert.</x:String>
            <x:String x:Key="L_QobuzCredentialsHint">Geheime Schlüssel und Anmeldetokens werden benutzergebunden durch Windows geschützt.</x:String>
            <x:String x:Key="L_DatabaseMaintenance">Datenbankwartung</x:String>
            <x:String x:Key="L_LibraryBackup">Bibliothek sichern</x:String>
            <x:String x:Key="L_LibraryBackupHint">Datenbank, Playlists, Verlauf und Cover als ZIP exportieren. Audiodateien sind nicht enthalten.</x:String>
            <x:String x:Key="L_ExportLibrary">Bibliothek exportieren</x:String>
            <x:String x:Key="L_ImportLibrary">Bibliothek importieren</x:String>
            <x:String x:Key="L_Lyrics">Songtext</x:String>
            <x:String x:Key="L_ShowLyrics">Songtext anzeigen</x:String>
            <x:String x:Key="L_RefreshLyrics">Songtext neu laden</x:String>
            <x:String x:Key="L_CloseLyrics">Songtext schließen</x:String>
            <x:String x:Key="L_ArtistInfo">Künstlerinfo</x:String>
            <x:String x:Key="L_ShowArtistInfo">Künstlerinfo anzeigen</x:String>
            <x:String x:Key="L_RefreshArtistInfo">Künstlerinfo neu laden</x:String>
            <x:String x:Key="L_CloseArtistInfo">Künstlerinfo schließen</x:String>
            <x:String x:Key="L_ArtistInfoSource">Quelle: Wikipedia</x:String>
            <x:String x:Key="L_SearchArtistImage">Künstlerbild suchen</x:String>
            <x:String x:Key="L_ArtistImageSearchTitle">Künstlerbild suchen</x:String>
            <x:String x:Key="L_ArtistImageSearchRunning">Passende Künstlerbilder werden gesucht …</x:String>
            <x:String x:Key="L_ArtistImageSearchNoResults">Keine Künstlerbilder gefunden.</x:String>
            <x:String x:Key="L_ArtistImageSearchQuery">Suchbegriff</x:String>
            <x:String x:Key="L_ArtistImageSearchFailed">Die Künstlerbildsuche ist fehlgeschlagen.</x:String>
            <x:String x:Key="L_UseSelectedArtistImage">Ausgewähltes Bild übernehmen</x:String>
            <x:String x:Key="L_ArtistImageDownloadFailed">Das ausgewählte Künstlerbild konnte nicht gespeichert werden.</x:String>
            <x:String x:Key="L_EditArtistName">Künstlername ändern</x:String>
            <x:String x:Key="L_ArtistName">Künstlername</x:String>
            <x:String x:Key="L_RenameArtist">Umbenennen</x:String>
            <x:String x:Key="L_MergeArtistsTitle">Künstler zusammenführen</x:String>
            <x:String x:Key="L_Shuffle">Zufallswiedergabe</x:String>
            <x:String x:Key="L_SearchLyrics">Songtext suchen</x:String>
            <x:String x:Key="L_LyricsSearchTitle">Songtext suchen</x:String>
            <x:String x:Key="L_LyricsSearchRunning">Passende Songtexte werden gesucht …</x:String>
            <x:String x:Key="L_LyricsSearchNoResults">Keine passenden Songtexte gefunden.</x:String>
            <x:String x:Key="L_LyricsSearchFailed">Die Songtextsuche ist fehlgeschlagen.</x:String>
            <x:String x:Key="L_UseSelectedLyrics">Ausgewählten Songtext übernehmen</x:String>
            <x:String x:Key="L_SelectLyricsResult">Wähle links einen Songtext für die Vorschau aus.</x:String>
            <x:String x:Key="L_ShowAllAlbumTracks">Alle Tracks des Albums anzeigen</x:String>
            <x:String x:Key="L_OptimizeDatabase">Datenbank optimieren</x:String>
            <x:String x:Key="L_RepairAlbumArtwork">Album-Cover reparieren</x:String>
            <x:String x:Key="L_Save">Speichern</x:String>
            <x:String x:Key="L_Cancel">Abbrechen</x:String>
            <x:String x:Key="L_About">Über Orynivo</x:String>
            <x:String x:Key="L_Author">Autor</x:String>
            <x:String x:Key="L_Licenses">Lizenzen</x:String>
            <x:String x:Key="L_DeviceInfo">Geräteinformationen</x:String>
            <x:String x:Key="L_ReplayGain">ReplayGain-Lautstärkeanpassung</x:String>
            <x:String x:Key="L_ReplayGainHint">Gilt für PCM-Wiedergabe. Native DSD-Ausgabe bleibt bitgenau.</x:String>
