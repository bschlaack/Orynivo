            <x:String x:Key="L_SelectColumns">Spalten auswählen</x:String>
            <x:String x:Key="L_Codec">Codec</x:String>
            <x:String x:Key="L_Tags">Tags</x:String>
            <x:String x:Key="L_Homepage">Homepage</x:String>
            <x:String x:Key="L_FeedUrl">Feed-Adresse</x:String>
            <x:String x:Key="L_DevicePcmSampleRates">PCM-Abtastraten</x:String>
            <x:String x:Key="L_DeviceDsdRates">DSD-Raten</x:String>
            <x:String x:Key="L_DevicePcmFormats">PCM-Formate</x:String>
            <x:String x:Key="L_DeviceDsdFormats">DSD-Formate</x:String>
            <x:String x:Key="L_NewPlaylistDialogTitle">Neue Playlist</x:String>
            <x:String x:Key="L_NewPlaylistNameLabel">Playlist-Name</x:String>
            <x:String x:Key="L_CreatePlaylist">Erstellen</x:String>
            <x:String x:Key="L_PlexServerDialogTitle">Plex-Server konfigurieren</x:String>
            <x:String x:Key="L_PlexServerName">Servername</x:String>
            <x:String x:Key="L_PlexServerUrl">Server-URL</x:String>
            <x:String x:Key="L_PlexToken">Plex-Token</x:String>
            <x:String x:Key="L_PlexTestConnection">Verbindung testen</x:String>
            <x:String x:Key="L_StartupPreparingLibrary">Bibliothek wird vorbereitet …</x:String>
        </ResourceDictionary>
    </Application.Resources>
</Application>
