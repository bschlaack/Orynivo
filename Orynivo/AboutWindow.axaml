<Window x:Class="Orynivo.AboutWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L_About}"
        Icon="avares://Orynivo/Assets/Orynivo.ico"
        Width="560"
        Height="620"
        MinWidth="480"
        MinHeight="440"
        Background="{DynamicResource AppContentBrush}"
        Foreground="{DynamicResource AppPrimaryTextBrush}">
    <Window.Styles>
        <Style Selector="TextBlock.license">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="LineHeight" Value="20"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Styles>
    <Grid Margin="22"
          RowDefinitions="Auto,Auto,Auto,*">
        <Image Grid.Row="0"
               HorizontalAlignment="Stretch"
               Source="{DynamicResource AppAboutLogoSource}"
               Stretch="Uniform"/>

        <StackPanel Grid.Row="1"
                    Margin="0,18,0,0">
            <TextBlock FontWeight="SemiBold"
                       Text="{DynamicResource L_Author}"/>
            <TextBlock Margin="0,4,0,0"
                       Text="Björn Schlaack"/>
            <TextBlock Margin="0,4,0,0"
                       Text="Copyright © 2026 Björn Schlaack"/>
        </StackPanel>

        <TextBlock Grid.Row="2"
                   Margin="0,22,0,10"
                   FontWeight="SemiBold"
                   Text="{DynamicResource L_Licenses}"/>

        <ScrollViewer Grid.Row="3"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,12,0">
                <TextBlock Classes="license"
                           FontWeight="SemiBold"
                           Text="Orynivo — Apache License 2.0"/>
                <TextBlock Classes="license"
                           Text="The Orynivo name, wordmark, logo, and application icon are not granted as trademarks by the Apache License."/>
                <TextBlock Classes="license" Text="cwASIO — MIT License"/>
                <TextBlock Classes="license" Text="Avalonia 11.2.0 — MIT License"/>
                <TextBlock Classes="license" Text="SkiaSharp 2.88.9 — MIT License"/>
                <TextBlock Classes="license" Text="Lucene.NET 4.8.0-beta00017 — Apache License 2.0"/>
                <TextBlock Classes="license" Text="ModelContextProtocol C# SDK 1.4.0 — Apache License 2.0"/>
                <TextBlock Classes="license" Text="Microsoft.Data.Sqlite 9.0.5 — MIT License"/>
                <TextBlock Classes="license" Text="NAudio 2.3.0 — MIT License"/>
                <TextBlock Classes="license" Text="TagLibSharp 2.3.0 — LGPL-2.1-only"/>
                <TextBlock Classes="license" Text="SQLitePCLRaw / e_sqlite3 2.1.10 — Apache License 2.0 / SQLite public domain dedication"/>
                <TextBlock Classes="license" Text="FFmpeg — separate LGPL essentials executable; exact terms depend on the downloaded build"/>
                <TextBlock Classes="license" Text="ASIO is a trademark and software of Steinberg Media Technologies GmbH. The optional Steinberg ASIO SDK is licensed separately and is not included in the repository."/>
                <TextBlock Margin="0,8,0,0"
                           Classes="license"
                           Text="Complete notices and license texts: THIRD_PARTY_NOTICES.md and the licenses directory next to Orynivo.exe."/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
