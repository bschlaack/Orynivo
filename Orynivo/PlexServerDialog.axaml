<Window x:Class="Orynivo.PlexServerDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L_PlexServerDialogTitle}"
        Icon="avares://Orynivo/Assets/Orynivo.ico"
        Width="460"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppSurfaceBrush}"
        Foreground="{DynamicResource AppPrimaryTextBrush}">
    <Grid Margin="24,20,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{DynamicResource L_PlexServerName}"
                   Foreground="{DynamicResource AppMutedTextBrush}"
                   Margin="0,0,0,6"/>
        <TextBox x:Name="NameTextBox"
                 Grid.Row="1"
                 Height="34"
                 Padding="10,0"
                 VerticalContentAlignment="Center"
                 Background="{DynamicResource AppInputBrush}"
                 Foreground="{DynamicResource AppPrimaryTextBrush}"
                 BorderBrush="{DynamicResource AppInputBorderBrush}"
                 Margin="0,0,0,14"/>

        <TextBlock Grid.Row="2"
                   Text="{DynamicResource L_PlexServerUrl}"
                   Foreground="{DynamicResource AppMutedTextBrush}"
                   Margin="0,0,0,6"/>
        <TextBox x:Name="UrlTextBox"
                 Grid.Row="3"
                 Height="34"
                 Padding="10,0"
                 VerticalContentAlignment="Center"
                 Background="{DynamicResource AppInputBrush}"
                 Foreground="{DynamicResource AppPrimaryTextBrush}"
                 BorderBrush="{DynamicResource AppInputBorderBrush}"
                 Margin="0,0,0,14"/>

        <TextBlock Grid.Row="4"
                   Text="{DynamicResource L_PlexToken}"
                   Foreground="{DynamicResource AppMutedTextBrush}"
                   Margin="0,0,0,6"/>
        <TextBox x:Name="TokenTextBox"
                 Grid.Row="5"
                 Height="34"
                 Padding="10,0"
                 VerticalContentAlignment="Center"
                 PasswordChar="&#x2022;"
                 Background="{DynamicResource AppInputBrush}"
                 Foreground="{DynamicResource AppPrimaryTextBrush}"
                 BorderBrush="{DynamicResource AppInputBorderBrush}"
                 Margin="0,0,0,8"/>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="6"
                   MinHeight="18"
                   Foreground="{DynamicResource AppMutedTextBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <Grid Grid.Row="7">
            <Button x:Name="TestConnectionButton"
                    Content="{DynamicResource L_PlexTestConnection}"
                    MinWidth="170"
                    Height="34"
                    Padding="14,0"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource AppButtonBrush}"
                    Foreground="{DynamicResource AppButtonTextBrush}"
                    BorderBrush="{DynamicResource AppButtonBorderBrush}"
                    BorderThickness="1"
                    Click="TestConnectionButton_OnClick"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{DynamicResource L_Cancel}"
                        Width="90"
                        Height="34"
                        Margin="0,0,8,0"
                        Background="{DynamicResource AppButtonBrush}"
                        Foreground="{DynamicResource AppButtonTextBrush}"
                        BorderBrush="{DynamicResource AppButtonBorderBrush}"
                        BorderThickness="1"
                        Click="CancelButton_OnClick"/>
                <Button Content="{DynamicResource L_Save}"
                        Width="90"
                        Height="34"
                        Background="#6C63FF"
                        Foreground="White"
                        BorderThickness="0"
                        Click="SaveButton_OnClick"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
