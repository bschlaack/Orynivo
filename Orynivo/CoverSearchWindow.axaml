<Window x:Class="Orynivo.CoverSearchWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L_CoverSearchTitle}"
        Icon="avares://Orynivo/Assets/Orynivo.ico"
        Height="560"
        Width="520"
        MinHeight="420"
        MinWidth="460"
        Background="{DynamicResource AppContentBrush}"
        Foreground="{DynamicResource AppPrimaryTextBrush}">
    <Window.Styles>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#6C63FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="ListBoxItem">
        </Style>
    </Window.Styles>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock x:Name="BusyIndicatorTextBlock"
                       Text="⠋"
                       FontSize="16"
                       Margin="0,0,8,0"/>
            <TextBlock x:Name="StatusTextBlock"
                       Text="{DynamicResource L_CoverSearchRunning}"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{DynamicResource L_CoverSearchQuery}"
                           Margin="0,0,0,4"/>
                <TextBox x:Name="QueryTextBox"
                         Height="28"
                         VerticalContentAlignment="Center"/>
            </StackPanel>
            <Button Classes="accent"
                    Grid.Column="1"
                    Width="110"
                    Height="28"
                    Margin="10,20,0,0"
                    Content="{DynamicResource L_SearchAgain}"
                    Click="SearchAgainButton_OnClick"/>
        </Grid>
        <ListBox x:Name="ResultsListBox"
                 Grid.Row="2"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,8"
                            Padding="10"
                            Background="{DynamicResource AppSurfaceBrush}"
                            CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Width="80"
                                   Height="80"
                                   Source="{Binding Image}"
                                   Stretch="UniformToFill"/>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                                <TextBlock Text="{Binding Artist}"
                                           Margin="0,4,0,0"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button Classes="accent"
                Grid.Row="3"
                Width="220"
                Height="30"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Content="{DynamicResource L_UseSelectedCover}"
                Click="UseSelectedCoverButton_OnClick"/>
    </Grid>
</Window>
