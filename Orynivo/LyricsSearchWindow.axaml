<Window x:Class="Orynivo.LyricsSearchWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L_LyricsSearchTitle}"
        Icon="avares://Orynivo/Assets/Orynivo.ico"
        Width="700"
        Height="650"
        MinWidth="560"
        MinHeight="480"
        Background="{DynamicResource AppContentBrush}"
        Foreground="{DynamicResource AppPrimaryTextBrush}">
    <Window.Styles>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#6C63FF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Styles>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock x:Name="BusyIndicatorTextBlock"
                       Text="⠋"
                       FontSize="{DynamicResource FontSizeSubtitle}"
                       Margin="0,0,8,0"/>
            <TextBlock x:Name="StatusTextBlock"
                       Text="{DynamicResource L_LyricsSearchRunning}"/>
        </StackPanel>
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="{DynamicResource L_Title}" Margin="0,0,0,4"/>
                <TextBox x:Name="TrackNameTextBox"
                         Height="30"
                         Padding="8,0"
                         VerticalContentAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="{DynamicResource L_Artist}" Margin="0,0,0,4"/>
                <TextBox x:Name="ArtistNameTextBox"
                         Height="30"
                         Padding="8,0"
                         VerticalContentAlignment="Center"/>
            </StackPanel>
            <Button Classes="accent"
                    Grid.Column="3"
                    Width="110"
                    Height="30"
                    Margin="12,20,0,0"
                    Content="{DynamicResource L_SearchAgain}"
                    Click="SearchAgainButton_OnClick"/>
        </Grid>
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.9*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="1.1*"/>
            </Grid.ColumnDefinitions>
            <ListBox x:Name="ResultsListBox"
                     Background="Transparent"
                     BorderThickness="0"
                     ItemContainerTheme="{StaticResource AppSearchResultItemTheme}"
                     SelectionChanged="ResultsListBox_OnSelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                                <TextBlock Text="{Binding TrackName}"
                                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding ArtistName}"
                                           Margin="0,3,0,0"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                                <TextBlock Text="{Binding Details}"
                                           Margin="0,3,0,0"
                                           FontSize="{DynamicResource FontSizeMeta}"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Border Grid.Column="2"
                    Padding="16"
                    Background="{DynamicResource AppSurfaceBrush}"
                    CornerRadius="0,14,0,14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="PreviewTextBlock"
                               Text="{DynamicResource L_SelectLyricsResult}"
                               TextWrapping="Wrap"
                               LineHeight="23"
                               Foreground="{DynamicResource AppPrimaryTextBrush}"/>
                </ScrollViewer>
            </Border>
        </Grid>
        <Button Classes="accent"
                Grid.Row="3"
                Width="240"
                Height="32"
                Margin="0,12,0,0"
                HorizontalAlignment="Right"
                Content="{DynamicResource L_UseSelectedLyrics}"
                Click="UseSelectedLyricsButton_OnClick"/>
    </Grid>
</Window>
