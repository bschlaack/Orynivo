<Window x:Class="Player.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Player"
        Width="420"
        Height="180"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="#13142A">
    <Border Padding="28" CornerRadius="12" Background="#13142A">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="♪  Player"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"/>
            <TextBlock x:Name="StatusTextBlock"
                       Margin="0,18,0,12"
                       Foreground="#CCCCEE"
                       FontSize="13"
                       Text="Bibliothek wird vorbereitet …"/>
            <ProgressBar IsIndeterminate="True"
                         Height="6"
                         Background="#252640"
                         Foreground="#6C63FF"/>
        </StackPanel>
    </Border>
</Window>
