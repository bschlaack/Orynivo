<Window x:Class="Player.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einstellungen"
        Height="340"
        Width="460"
        MinHeight="340"
        MinWidth="460">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Ausgabeart"
                       FontSize="14"
                       FontWeight="SemiBold" />
            <ComboBox x:Name="OutputBackendComboBox"
                      Margin="0,8,0,16"
                      Height="30"
                      SelectionChanged="OutputBackendComboBox_OnSelectionChanged" />

            <TextBlock x:Name="DeviceLabelTextBlock"
                       Text="ASIO-Ausgabegerät"
                       FontSize="14"
                       FontWeight="SemiBold" />
            <ComboBox x:Name="DriverComboBox"
                      Margin="0,8,0,8"
                      Height="30"
                      SelectionChanged="DriverComboBox_OnSelectionChanged" />
            <Button x:Name="DeviceInfoButton"
                    Width="130"
                    Height="28"
                    HorizontalAlignment="Left"
                    Click="DeviceInfoButton_OnClick"
                    Content="Geräteinfo"
                    Visibility="Collapsed" />
        </StackPanel>

        <TextBlock x:Name="StatusTextBlock"
                   Grid.Row="1"
                   Margin="0,16,0,0"
                   TextWrapping="Wrap"
                   Foreground="#555" />

        <StackPanel Grid.Row="2"
                    Margin="0,18,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
            <Button Width="90"
                    Height="30"
                    Margin="0,0,10,0"
                    Click="CancelButton_OnClick"
                    Content="Abbrechen" />
            <Button Width="90"
                    Height="30"
                    Click="SaveButton_OnClick"
                    Content="Speichern" />
        </StackPanel>
    </Grid>
</Window>
