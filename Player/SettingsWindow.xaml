<Window x:Class="Player.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource L_Settings}"
        Width="720"
        Height="500"
        MinWidth="600"
        MinHeight="400"
        ResizeMode="CanResize"
        Background="{DynamicResource AppContentBrush}"
        Foreground="{DynamicResource AppPrimaryTextBrush}"
        SourceInitialized="SettingsWindow_OnSourceInitialized">
    <Window.Resources>
        <Style x:Key="SettingsNavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource AppNavTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent"
                                Padding="21,8,12,8">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppNavSelectedBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6C63FF" />
                                <Setter Property="Foreground" Value="{DynamicResource AppNavSelectedTextBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppNavHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AppNavHoverTextBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AppButtonBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppButtonTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="28"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1"
                                                      Width="10"
                                                      Height="6"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Fill="{DynamicResource AppPrimaryTextBrush}"
                                                      Data="M 0 0 L 5 6 L 10 0 Z"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Margin="10,0,32,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              IsHitTestVisible="False"/>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="{DynamicResource AppInputBrush}"
                                        BorderBrush="{DynamicResource AppInputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer Margin="0">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource AppInputBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryTextBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSurfaceHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSurfaceSelectedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="1" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Linke Navigation -->
        <ListBox x:Name="NavListBox"
                 Grid.Column="0"
                 Grid.Row="0"
                 Background="{DynamicResource AppSidebarBrush}"
                 BorderThickness="0"
                 Padding="0,8,0,0"
                 SelectionChanged="NavListBox_OnSelectionChanged">

            <!-- Oberpunkt: Wiedergabe -->
            <ListBoxItem IsHitTestVisible="False"
                         Focusable="False"
                         Padding="12,10,0,4"
                         FontSize="10"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AppMutedTextBrush}">
                <TextBlock Text="{DynamicResource L_Playback}"/>
            </ListBoxItem>
            <ListBoxItem Tag="AudioDevice"
                         FontSize="13"
                         Style="{StaticResource SettingsNavItemStyle}">
                <TextBlock Text="{DynamicResource L_OutputDevice}"/>
            </ListBoxItem>

            <!-- Oberpunkt: Bibliothek -->
            <ListBoxItem IsHitTestVisible="False"
                         Focusable="False"
                         Padding="12,14,0,4"
                         FontSize="10"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AppMutedTextBrush}">
                <TextBlock Text="{DynamicResource L_Library}"/>
            </ListBoxItem>
            <ListBoxItem Tag="Library"
                         FontSize="13"
                         Style="{StaticResource SettingsNavItemStyle}">
                <TextBlock Text="{DynamicResource L_Directories}"/>
            </ListBoxItem>

            <!-- Oberpunkt: Darstellung -->
            <ListBoxItem IsHitTestVisible="False"
                         Focusable="False"
                         Padding="12,14,0,4"
                         FontSize="10"
                         FontWeight="Bold"
                         Foreground="{DynamicResource AppMutedTextBrush}">
                <TextBlock Text="{DynamicResource L_Appearance}"/>
            </ListBoxItem>
            <ListBoxItem Tag="Appearance"
                         FontSize="13"
                         Style="{StaticResource SettingsNavItemStyle}">
                <TextBlock Text="{DynamicResource L_Appearance}"/>
            </ListBoxItem>
        </ListBox>

        <!-- Vertikale Trennlinie -->
        <Rectangle Grid.Column="1"
                   Grid.Row="0"
                   Fill="{DynamicResource AppHeaderBorderBrush}" />

        <!-- Rechter Inhaltsbereich -->
        <ScrollViewer Grid.Column="2"
                      Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="28,24,28,16">

                <!-- Panel: Ausgabegerät -->
                <StackPanel x:Name="AudioDevicePanel"
                            Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L_OutputDevice}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20" />

                    <TextBlock Text="Ausgabeart"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <ComboBox x:Name="OutputBackendComboBox"
                              Height="30"
                              Style="{StaticResource SettingsComboBoxStyle}"
                              Margin="0,0,0,18"
                              SelectionChanged="OutputBackendComboBox_OnSelectionChanged" />

                    <TextBlock x:Name="DeviceLabelTextBlock"
                               Text="ASIO-Ausgabegerät"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <ComboBox x:Name="DriverComboBox"
                              Height="30"
                              Style="{StaticResource SettingsComboBoxStyle}"
                              Margin="0,0,0,8"
                              SelectionChanged="DriverComboBox_OnSelectionChanged" />
                    <Button x:Name="DeviceInfoButton"
                            Width="130"
                            Height="28"
                            HorizontalAlignment="Left"
                            Style="{StaticResource SettingsButtonStyle}"
                            Click="DeviceInfoButton_OnClick"
                            Content="Geräteinfo"
                            Visibility="Collapsed" />

                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               Foreground="#555555" />
                </StackPanel>

                <!-- Panel: Verzeichnisse -->
                <StackPanel x:Name="LibraryPanel"
                            Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L_Directories}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20" />

                    <ScrollViewer MaxHeight="320"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="DirectoriesPanel" />
                    </ScrollViewer>

                    <Button x:Name="AddDirectoryButton"
                            Width="180"
                            Height="28"
                            HorizontalAlignment="Left"
                            Margin="0,10,0,0"
                            Style="{StaticResource SettingsButtonStyle}"
                            Content="{DynamicResource L_AddDirectory}"
                            Click="AddDirectoryButton_OnClick" />

                    <Separator Margin="0,18,0,14"/>

                    <TextBlock Text="{DynamicResource L_DatabaseMaintenance}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6" />
                    <TextBlock Text="Freigegebene Seiten werden entfernt; danach ist die Datei physisch kleiner."
                               FontSize="11"
                               Foreground="#666666"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>
                    <Button x:Name="OptimizeDatabaseButton"
                            Width="180"
                            Height="28"
                            HorizontalAlignment="Left"
                            Style="{StaticResource SettingsButtonStyle}"
                            Content="{DynamicResource L_OptimizeDatabase}"
                            Click="OptimizeDatabaseButton_OnClick" />
                    <Button x:Name="RepairAlbumArtworkButton"
                            Width="180"
                            Height="28"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Style="{StaticResource SettingsButtonStyle}"
                            Content="{DynamicResource L_RepairAlbumArtwork}"
                            Click="RepairAlbumArtworkButton_OnClick" />
                    <Button x:Name="DownloadMissingArtworkButton"
                            Width="260"
                            Height="28"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"
                            Style="{StaticResource SettingsButtonStyle}"
                            Content="{DynamicResource L_DownloadMissingArtwork}"
                            Click="DownloadMissingArtworkButton_OnClick" />
                    <TextBlock Text="{DynamicResource L_DownloadMissingArtworkHint}"
                               FontSize="11"
                               Foreground="#666666"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0"/>
                    <TextBlock x:Name="DatabaseMaintenanceStatusTextBlock"
                               Margin="0,8,0,0"
                               FontSize="11"
                               Foreground="#555555"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Panel: Darstellung -->
                <StackPanel x:Name="AppearancePanel"
                            Visibility="Collapsed">
                    <TextBlock Text="{DynamicResource L_Appearance}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Margin="0,0,0,20" />
                    <TextBlock Text="{DynamicResource L_ColorScheme}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="ThemeComboBox"
                              Height="30"
                              HorizontalAlignment="Stretch"
                              Style="{StaticResource SettingsComboBoxStyle}"
                              Margin="0,0,0,12"/>

                    <TextBlock Text="{DynamicResource L_Language}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ComboBox x:Name="LanguageComboBox"
                              Height="30"
                              HorizontalAlignment="Stretch"
                              Style="{StaticResource SettingsComboBoxStyle}"/>
                </StackPanel>

            </Grid>
        </ScrollViewer>

        <!-- Untere Leiste: Speichern / Abbrechen -->
        <Border Grid.Column="0"
                Grid.ColumnSpan="3"
                Grid.Row="1"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource AppHeaderBorderBrush}"
                Padding="16,10">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Width="90"
                        Height="30"
                        Margin="0,0,10,0"
                        Style="{StaticResource SettingsButtonStyle}"
                        Click="CancelButton_OnClick"
                        Content="{DynamicResource L_Cancel}" />
                <Button Width="90"
                        Height="30"
                        Style="{StaticResource SettingsButtonStyle}"
                        Click="SaveButton_OnClick"
                        Content="{DynamicResource L_Save}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
