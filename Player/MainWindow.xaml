<Window x:Class="Player.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Player.Controls"
        Title="Player" Height="760" Width="1100"
        MinHeight="600" MinWidth="800">
    <Window.Resources>

        <!-- Sidebar nav item -->
        <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#9999BB" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="Transparent"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent"
                                Padding="21,8,12,8">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252640" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#6C63FF" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#1F2038" />
                                <Setter Property="Foreground" Value="#CCCCEE" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Transport secondary button -->
        <Style x:Key="TransportBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#9999BB" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="17">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252640"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#3A3A55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Transport primary button (play/pause) -->
        <Style x:Key="PlayBtnStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="#6C63FF" CornerRadius="22">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#7B73FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#2A2B45"/>
                                <Setter Property="Foreground" Value="#3A3A55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Settings button -->
        <Style x:Key="SidebarBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#7777AA" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="24,14">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F2038"/>
                                <Setter Property="Foreground" Value="#CCCCEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Back navigation button -->
        <Style x:Key="HeaderIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#DDDDF5"/>
            <Setter Property="Foreground" Value="#4B4B78"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D1D1F0"/>
                                <Setter Property="Foreground" Value="#13142A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C5C5EA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark slider (transport bar) -->
        <Style x:Key="DarkSliderStyle" TargetType="Slider">
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center" ClipToBounds="False">
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" VerticalAlignment="Center"
                                                        Background="#6C63FF" CornerRadius="1.5"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="El" Width="14" Height="14" Fill="White"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="El" Property="Fill" Value="#DDDDFF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" VerticalAlignment="Center"
                                                        Background="#2E2F4A" CornerRadius="1.5"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid column header -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EAEAF5"/>
            <Setter Property="Foreground" Value="#7777AA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#D8D8EE"/>
            <Setter Property="SeparatorBrush" Value="#D8D8EE"/>
        </Style>

        <!-- DataGrid row -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#F8F8FD"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#1A1A2E"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EAEAFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DDDDF5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TreeView item -->
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#1A1A2E"/>
            <Setter Property="Padding"    Value="4,5"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DDDDF5"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EAEAFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- DataGrid cell -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Segmentierter Ansichtsumschalter -->
        <Style x:Key="ViewModeRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#666688"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="18,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#6C63FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#DDDDF5"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ SIDEBAR ═══ -->
        <Grid Grid.Column="0" Grid.Row="0" Background="#13142A">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- App title -->
            <Border Padding="24,22,24,18" BorderThickness="0,0,0,1" BorderBrush="#1E1F38">
                <StackPanel>
                    <TextBlock Text="♪  Player"
                               Foreground="White" FontSize="17" FontWeight="Bold"/>
                    <TextBlock x:Name="SelectedDriverTextBlock"
                               Foreground="#44445A" FontSize="10" Margin="0,4,0,0"
                               Text="Kein Gerät ausgewählt."
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <!-- Nav -->
            <ListBox x:Name="NavListBox"
                     Grid.Row="1"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="0,8,0,8"
                     FontSize="13"
                     SelectionChanged="NavListBox_OnSelectionChanged"
                     PreviewMouseLeftButtonUp="NavListBox_OnPreviewMouseLeftButtonUp">

                <ListBoxItem IsHitTestVisible="False" Focusable="False"
                             Foreground="#44445A" FontSize="10" FontWeight="Bold"
                             Padding="24,12,0,4">
                    LOKALE BIBLIOTHEK
                </ListBoxItem>
                <ListBoxItem Tag="Artists"  Style="{StaticResource NavItemStyle}">Künstler</ListBoxItem>
                <ListBoxItem Tag="Albums"   Style="{StaticResource NavItemStyle}">Alben</ListBoxItem>
                <ListBoxItem Tag="Tracks"   Style="{StaticResource NavItemStyle}">Tracks</ListBoxItem>
                <ListBoxItem Tag="Folders"  Style="{StaticResource NavItemStyle}">Ordnerstruktur</ListBoxItem>

                <ListBoxItem IsHitTestVisible="False" Focusable="False"
                             Foreground="#44445A" FontSize="10" FontWeight="Bold"
                             Padding="24,16,0,4">
                    PLAYLISTS
                </ListBoxItem>
                <!-- Playlist-Einträge werden per Code ergänzt (Index 6+) -->
            </ListBox>

            <!-- Status -->
            <TextBlock x:Name="StatusTextBlock"
                       Grid.Row="2"
                       Padding="24,8"
                       Foreground="#44445A" FontSize="10"
                       TextWrapping="Wrap"/>

            <!-- Einstellungen -->
            <Button Grid.Row="3"
                    HorizontalAlignment="Stretch"
                    FontSize="13"
                    Style="{StaticResource SidebarBtnStyle}"
                    Click="SettingsButton_OnClick"
                    Content="⚙   Einstellungen"/>
        </Grid>

        <!-- ═══ CONTENT ═══ -->
        <Grid Grid.Column="1" Grid.Row="0" Background="#F2F2FA">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Background="#EAEAF5"
                    BorderThickness="0,0,0,1" BorderBrush="#D8D8EE"
                    Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BackButton"
                            Width="34"
                            Height="30"
                            Margin="0,0,12,0"
                            Visibility="Collapsed"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            Click="BackButton_OnClick"
                            ToolTip="Zurück">
                        <Path Data="M 12 6 L 6 12 L 12 18"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Width="18"
                              Height="18"
                              Stretch="Uniform"/>
                    </Button>
                    <TextBlock x:Name="ContentTitleTextBlock"
                               Grid.Column="1"
                               FontSize="18" FontWeight="SemiBold" Foreground="#13142A"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ContentCountTextBlock"
                               Grid.Column="2"
                               FontSize="12" Foreground="#9999BB"
                               VerticalAlignment="Center"/>
                    <Border x:Name="AlbumViewModeBorder"
                            Grid.Column="3"
                            Margin="20,0,0,0"
                            Padding="3"
                            Background="#E1E1F0"
                            CornerRadius="9"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="AlbumTableViewRadioButton"
                                         GroupName="AlbumViewMode"
                                         Style="{StaticResource ViewModeRadioStyle}"
                                         MinWidth="88"
                                         Content="Tabelle"
                                         IsChecked="True"
                                         Checked="AlbumViewModeRadioButton_OnChecked"/>
                            <RadioButton x:Name="AlbumArtworkViewRadioButton"
                                         GroupName="AlbumViewMode"
                                         Style="{StaticResource ViewModeRadioStyle}"
                                         MinWidth="88"
                                         Content="Artwork"
                                         Checked="AlbumViewModeRadioButton_OnChecked"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Content DataGrid -->
            <DataGrid x:Name="ContentDataGrid"
                      Grid.Row="1"
                      Background="#F2F2FA"
                      BorderThickness="0"
                      RowHeight="38"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E4E4F0"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      FontSize="13"
                      CanUserResizeRows="False"
                      MouseDoubleClick="ContentDataGrid_OnMouseDoubleClick"/>

            <!-- Folder TreeView (nur für Ordnerstruktur) -->
            <TreeView x:Name="FolderTreeView"
                      Grid.Row="1"
                      Background="#F2F2FA"
                      BorderThickness="0"
                      FontSize="13"
                      Visibility="Collapsed"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True"
                      MouseDoubleClick="FolderTreeView_OnMouseDoubleClick"/>

            <!-- Album-Artworkansicht -->
            <ListBox x:Name="AlbumArtworkListBox"
                     Grid.Row="1"
                     Visibility="Collapsed"
                     Background="#F2F2FA"
                     BorderThickness="0"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.IsDeferredScrollingEnabled="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     MouseDoubleClick="AlbumArtworkListBox_OnMouseDoubleClick">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <controls:VirtualizingWrapPanel Margin="16"
                                                        ItemWidth="196"
                                                        ItemHeight="270"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <EventSetter Event="Loaded" Handler="AlbumArtworkItem_OnLoaded"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Width="180"
                                Margin="8"
                                Padding="10"
                                Background="#F8F8FD"
                                CornerRadius="8">
                            <StackPanel>
                                <Border Width="160"
                                        Height="160"
                                        Background="#E4E4F0"
                                        CornerRadius="6">
                                    <Image Source="{Binding Artwork}"
                                           Stretch="UniformToFill"/>
                                </Border>
                                <TextBlock Text="{Binding Title}"
                                           Margin="0,10,0,0"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Artist}"
                                           Margin="0,3,0,0"
                                           Foreground="#666688"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Year}"
                                           Margin="0,3,0,0"
                                           Foreground="#9999BB"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- ═══ TRANSPORT BAR ═══ -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                Background="#13142A"
                BorderThickness="0,1,0,0" BorderBrush="#1E1F38"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Now playing -->
                <StackPanel VerticalAlignment="Center" Margin="0,0,16,0">
                    <TextBlock x:Name="NowPlayingTitleBlock"
                               Foreground="White" FontSize="13" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="NowPlayingArtistBlock"
                               Foreground="#6666AA" FontSize="11" Margin="0,2,0,0"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="FileInfoTextBlock"
                               Foreground="#44445A" FontSize="10" Margin="0,2,0,0"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <!-- Controls -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,10">
                        <Button x:Name="StopButton"
                                Style="{StaticResource TransportBtnStyle}"
                                Margin="0,0,6,0" IsEnabled="False"
                                Click="StopButton_OnClick" Content="⏹"/>
                        <Button x:Name="PlayButton"
                                Style="{StaticResource PlayBtnStyle}"
                                Margin="6,0"
                                Click="PlayButton_OnClick" Content="▶"/>
                        <Button x:Name="PauseButton"
                                Style="{StaticResource TransportBtnStyle}"
                                Margin="6,0,0,0" IsEnabled="False"
                                Click="PauseButton_OnClick" Content="⏸"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="42"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="42"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CurrentTimeTextBlock"
                                   Foreground="#6666AA" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Margin="0,0,8,0" Text="0:00"/>
                        <Slider x:Name="PositionSlider"
                                Grid.Column="1"
                                Style="{StaticResource DarkSliderStyle}"
                                Minimum="0" Maximum="1" IsEnabled="False"
                                PreviewMouseLeftButtonUp="PositionSlider_OnPreviewMouseLeftButtonUp"
                                ValueChanged="PositionSlider_OnValueChanged"/>
                        <TextBlock x:Name="DurationTextBlock"
                                   Grid.Column="2"
                                   Foreground="#6666AA" FontSize="11"
                                   VerticalAlignment="Center" HorizontalAlignment="Left"
                                   Margin="8,0,0,0" Text="0:00"/>
                    </Grid>
                </StackPanel>

                <!-- Volume -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="🔊" Foreground="#6666AA" FontSize="13"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Slider x:Name="VolumeSlider"
                            Style="{StaticResource DarkSliderStyle}"
                            Width="100" Minimum="0" Maximum="1" Value="1"
                            VerticalAlignment="Center"
                            ValueChanged="VolumeSlider_OnValueChanged"/>
                    <TextBlock x:Name="VolumeValueTextBlock"
                               Foreground="#6666AA" FontSize="11" Width="44"
                               VerticalAlignment="Center" Margin="10,0,0,0"
                               Text="100 %"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
